{
  "name": "angel-suero-archive",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--require=./scripts/rollup-native-preload.cjs astro dev",
    "build": "NODE_OPTIONS=--require=./scripts/rollup-native-preload.cjs astro build",
    "preview": "NODE_OPTIONS=--require=./scripts/rollup-native-preload.cjs astro preview",
    "ig:manifest": "node scripts/generate-ig-manifest.mjs",
    "sync:agi": "node scripts/sync-agi-timeline.mjs",
    "sync:linktree": "node scripts/sync-linktree.mjs",
    "sync:x": "node scripts/sync-x.mjs",
    "sync:youtube": "node scripts/sync-youtube.mjs",
    "sync:chess": "node scripts/sync-chess.mjs",
    "sync:data": "npm run sync:agi && npm run sync:linktree && npm run sync:x && npm run sync:youtube && npm run sync:chess"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/tailwind": "^6.0.2",
    "astro": "^5.17.2",
    "rss-parser": "^3.13.0",
    "zod": "^3.23.8"
  },
  "overrides": {
    "shiki": "3.21.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "tailwindcss": "^3.4.17"
  }
}
