---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import SubstackPanel from '../../components/SubstackPanel.astro';
import { isPostReady } from '../../lib/post-readiness';

const posts = (await getCollection('posts')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const dateFormatter = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric'
});
const fullDateFormatter = new Intl.DateTimeFormat('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric'
});
const allTags = [...new Set(posts.flatMap((post) => post.data.tags.map((tag) => tag.trim().toLowerCase())))]
  .filter(Boolean)
  .sort((a, b) => a.localeCompare(b));
const readyPosts = posts.filter(isPostReady);
const featuredPosts = posts.filter((post) => post.data.featured);
const readyFeaturedPosts = featuredPosts.filter(isPostReady);
const featuredPost = readyFeaturedPosts[0] ?? featuredPosts[0] ?? readyPosts[0] ?? posts[0] ?? null;
const supportingPosts = featuredPost ? posts.filter((post) => post.id !== featuredPost.id) : [];
const corpusConstellations = [
  {
    title: 'Philosophical Inquiry',
    band: 'Theory',
    summary: 'A sustained argument with skepticism, moral genealogy, dualism, fear, consciousness, and the question of a livable good.',
    tension: 'How can a person think clearly enough to judge, act, and avoid inherited moral traps?',
    anchors: 'Descartes Essay Outline, Nietzsche study notes, Is A Human Body Merely A Complex Physical System?, Acquiring American Happiness in the 21st Century'
  },
  {
    title: 'Power and Political Economy',
    band: 'Systems',
    summary: 'Capitalism is treated as a machinery of alienation, dispossession, and managed distraction rather than a neutral background.',
    tension: 'What does it cost a person or city to survive inside a structure built around extraction and hierarchy?',
    anchors: 'The Sacrifice of Power, Entertainment, Suffering, and the Everyday, Theorizing Politics, Housing crisis research'
  },
  {
    title: 'Urban Praxis and Newark',
    band: 'Field',
    summary: 'The writing stops being purely diagnostic and becomes logistical, geographic, and materially grounded in Newark.',
    tension: 'How does theory hold up when it has to move water, build coalitions, and face infrastructure failure directly?',
    anchors: 'Newark Water Coalition fellowship assignments, Ironbound reports, Right to the City analysis, Gallery Host Plus proposal'
  },
  {
    title: 'Identity and Acculturation',
    band: 'Identity',
    summary: 'Race, language loss, and belonging are treated as socially engineered pressures with deep psychological consequences.',
    tension: 'What happens when inherited identity weakens while dominant culture still refuses full recognition?',
    anchors: 'Impacts of Acculturation, Baldwin-centered politics work, The Bluest Eye analysis'
  },
  {
    title: 'Creative Resistance',
    band: 'Art',
    summary: 'Music, scripts, and narrative experiments become tools for recovering what rigid systems trained out of the self.',
    tension: 'How does form itself become a way of surviving, reclaiming sensation, and resisting control?',
    anchors: 'Beyond Syntax, Sensitive Child, Cocoa, End, The Art of Fighting Back / The Art of Survival'
  },
  {
    title: 'AI and Future Systems',
    band: 'Futures',
    summary: 'The later work extends systemic critique into automation, AI governance, and the defense of human cognition.',
    tension: 'How can emerging systems be used without surrendering labor dignity, memory, artists, or moral agency?',
    anchors: 'Automation Feasibility: 2025-2035 Analysis, The Singularity Horizon, Accountability Pledge, AI well-being analyses'
  }
];

const writingArc = [
  {
    period: '2015-2017',
    title: 'Formalist Survival',
    summary: 'A rigid, high-performance voice shaped by the Essay Codex, the Divorce Decree, and the need to survive restrictive academic structures.'
  },
  {
    period: '2018-2022',
    title: 'Systemic Deconstruction',
    summary: 'The archive expands into philosophy, Marxist critique, race, literature, and historical power, using research to dismantle inherited narratives.'
  },
  {
    period: '2022-2025',
    title: 'Applied Humanism',
    summary: 'Theory becomes praxis through Newark fieldwork, creative recovery, and technical writing on AI, automation, and institutional accountability.'
  }
];
---
<BaseLayout title="Writing — a_e.s_" theme="writing">
  <section class="writing-hero">
    <p class="writing-kicker">Essays / Reports / Field Notes</p>
    <h1 class="font-display text-4xl md:text-5xl">Writing</h1>
    <p class="writing-description">
      Essays and field notes on systems, Newark, identity, creative recovery, and AI futures, held as an archive that
      still wants to be read piece by piece.
    </p>
    <div class="writing-meta">
      <p>{posts.length} {posts.length === 1 ? 'entry' : 'entries'}</p>
      <p>Archive frame: 2015-2025</p>
      {posts[0] && <p>Latest: {fullDateFormatter.format(posts[0].data.date)}</p>}
    </div>
    <a class="writing-rss-link" href="/rss.xml">RSS feed</a>
  </section>
  {/* TODO: This featured slot assumes a post with enough interior to justify the prominence. */}
  {featuredPost && (
    <section class="writing-proof" aria-labelledby="writing-proof-heading">
      <div class="writing-proof-header">
        <h2 id="writing-proof-heading" class="font-display text-2xl">Start with one entry</h2>
        <p>A direct entry point before the larger archive logic underneath it.</p>
      </div>

      <div class="writing-proof-grid">
        {(() => {
          const featuredPostReady = isPostReady(featuredPost);
          return (
        <article class="writing-card writing-card--featured">
          <p class="writing-card-date">Featured entry · {fullDateFormatter.format(featuredPost.data.date)}</p>
          <h2 class="writing-proof-title">
            <a href={`/writing/${featuredPost.slug}`} class="writing-card-title">{featuredPost.data.title}</a>
          </h2>
          <p class="writing-card-summary">{featuredPostReady ? featuredPost.data.summary : '—'}</p>
          <div class="writing-card-footer">
            <div class="writing-tags">
              {featuredPost.data.tags.map((tag) => <span class="writing-tag">#{tag}</span>)}
            </div>
            {featuredPostReady && (
              <a href={`/writing/${featuredPost.slug}`} class="writing-read-link" aria-label={`Read ${featuredPost.data.title}`}>
                Read note
              </a>
            )}
          </div>
        </article>
          );
        })()}

        {supportingPosts.length > 0 && (
          <div class="writing-proof-stack">
            <p class="writing-proof-stack-label">From nearby in the archive</p>
            {supportingPosts.slice(0, 2).map((post) => (
              (() => {
                const postReady = isPostReady(post);
                return (
                  <article class="writing-proof-mini">
                    <p class="writing-card-date">{dateFormatter.format(post.data.date)}</p>
                    <h3>
                      <a href={`/writing/${post.slug}`} class="writing-card-title">{post.data.title}</a>
                    </h3>
                    <p>{postReady ? post.data.summary : '—'}</p>
                    {!postReady && (
                      <div class="writing-tags">
                        {post.data.tags.map((tag) => <span class="writing-tag">#{tag}</span>)}
                      </div>
                    )}
                  </article>
                );
              })()
            ))}
          </div>
        )}
      </div>
    </section>
  )}

  <SubstackPanel secondaryHref="#writing-list" secondaryLabel="Jump to site archive" />

  <section class="writing-archive" id="writing-list" aria-labelledby="writing-archive-heading">
    <div class="writing-archive-header">
      <h2 id="writing-archive-heading" class="font-display text-2xl">Site Archive</h2>
      {allTags.length > 0 && (
        <div class="writing-filters" role="group" aria-label="Filter posts by tag">
          <button type="button" class="writing-filter is-active" data-filter="all" aria-pressed="true">All</button>
          {allTags.map((tag) => (
            <button type="button" class="writing-filter" data-filter={tag} aria-pressed="false">#{tag}</button>
          ))}
        </div>
      )}
      <p class="writing-results" id="writing-results-count">{posts.length} {posts.length === 1 ? 'entry' : 'entries'}</p>
    </div>

    {posts.length === 0 ? (
      <p class="writing-empty">No entries published yet.</p>
    ) : (
      <>
        <ul class="writing-list" id="writing-list-items">
          {posts.map((post) => (
            (() => {
              const postReady = isPostReady(post);
              return (
                <li class="writing-item" data-tags={post.data.tags.map((tag) => tag.trim().toLowerCase()).join(' ')}>
                  <article class="writing-card">
                    <p class="writing-card-date">{dateFormatter.format(post.data.date)}</p>
                    <h3 class="font-display text-2xl">
                      <a href={`/writing/${post.slug}`} class="writing-card-title">{post.data.title}</a>
                    </h3>
                    <p class="writing-card-summary">{postReady ? post.data.summary : '—'}</p>
                    <div class="writing-card-footer">
                      <div class="writing-tags">
                        {post.data.tags.map((tag) => <span class="writing-tag">#{tag}</span>)}
                      </div>
                      {postReady && (
                        <a href={`/writing/${post.slug}`} class="writing-read-link" aria-label={`Read ${post.data.title}`}>
                          Read note
                        </a>
                      )}
                    </div>
                  </article>
                </li>
              );
            })()
          ))}
        </ul>
        <p class="writing-empty" id="writing-empty-state" hidden>No posts match this tag yet.</p>
      </>
    )}
  </section>

  <section class="writing-vault" aria-labelledby="writing-vault-heading">
    <div class="writing-vault-header">
      <h2 id="writing-vault-heading" class="font-display text-2xl">Archive Threads</h2>
      <p>Recurring lanes in the archive once you want the wider argument and not just a single note.</p>
    </div>
    <ul class="writing-vault-list">
      {corpusConstellations.map((cluster) => (
        <li>
          <article class="writing-vault-card">
            <div class="writing-vault-topline">
              <h3 class="font-display text-xl">{cluster.title}</h3>
              <span class="writing-vault-status">{cluster.band}</span>
            </div>
            <p class="writing-vault-logline">{cluster.summary}</p>
            <div class="writing-vault-meta">
              <p><strong>Central tension:</strong> {cluster.tension}</p>
              <p><strong>Anchor works:</strong> {cluster.anchors}</p>
            </div>
          </article>
        </li>
      ))}
    </ul>
  </section>

  <section class="writing-trajectory" aria-labelledby="writing-trajectory-heading">
    <div class="writing-trajectory-header">
      <h2 id="writing-trajectory-heading" class="font-display text-2xl">Intellectual Arc</h2>
      <p>The archive reads less like isolated assignments and more like a decade-long transition in method and purpose.</p>
    </div>
    <div class="writing-trajectory-grid">
      {writingArc.map((phase) => (
        <article class="writing-trajectory-card">
          <p class="writing-trajectory-period">{phase.period}</p>
          <h3 class="font-display text-xl">{phase.title}</h3>
          <p>{phase.summary}</p>
        </article>
      ))}
    </div>
  </section>

  <script is:inline>
    (() => {
      const filterButtons = Array.from(document.querySelectorAll('.writing-filter'));
      const items = Array.from(document.querySelectorAll('.writing-item'));
      const emptyState = document.getElementById('writing-empty-state');
      const results = document.getElementById('writing-results-count');
      if (!filterButtons.length || !items.length || !results) return;

      const label = (count) => `${count} ${count === 1 ? 'entry' : 'entries'}`;
      const setActive = (activeFilter) => {
        filterButtons.forEach((candidate) => {
          const active = (candidate.getAttribute('data-filter') || 'all') === activeFilter;
          candidate.classList.toggle('is-active', active);
          candidate.setAttribute('aria-pressed', String(active));
        });
      };

      const applyFilter = (filter) => {
        let visibleCount = 0;
        items.forEach((item) => {
          const tags = item.getAttribute('data-tags') || '';
          const matches = filter === 'all' || tags.split(/\s+/).includes(filter);
          item.hidden = !matches;
          if (matches) visibleCount += 1;
        });

        results.textContent = label(visibleCount);
        if (emptyState) emptyState.hidden = visibleCount !== 0;
      };

      filterButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const filter = button.getAttribute('data-filter') || 'all';
          setActive(filter);
          applyFilter(filter);
        });
      });

      setActive('all');
      applyFilter('all');
    })();
  </script>
</BaseLayout>

<style>
  .writing-hero {
    border: 1px solid var(--line2);
    border-radius: calc(var(--radius) * var(--space-scale));
    background: linear-gradient(
      120deg,
      color-mix(in srgb, var(--tone-surface-strong) 72%, transparent),
      color-mix(in srgb, var(--tone-surface) 60%, transparent)
    );
    padding: clamp(1.05rem, 2.4vw, 1.85rem);
  }

  .writing-kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.7rem;
    color: var(--tone-muted);
  }

  .writing-description {
    margin-top: 0.8rem;
    max-width: 62ch;
    color: color-mix(in srgb, var(--tone-text) 85%, var(--tone-muted) 15%);
  }

  .writing-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem 1rem;
    margin-top: 0.8rem;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: color-mix(in srgb, var(--tone-text) 78%, var(--tone-muted) 22%);
  }

  .writing-meta p {
    margin: 0;
  }

  .writing-rss-link {
    display: inline-flex;
    margin-top: 0.9rem;
    font-size: 0.9rem;
    color: var(--tone-accent-glow);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--tone-accent) 50%, transparent);
  }

  .writing-rss-link:hover,
  .writing-rss-link:focus-visible {
    border-color: color-mix(in srgb, var(--tone-accent) 80%, transparent);
  }

  .writing-archive {
    margin-top: clamp(1.3rem, 3vw, 2.4rem);
  }

  .writing-proof {
    margin-top: clamp(1.3rem, 3vw, 2.4rem);
  }

  .writing-vault {
    margin-top: clamp(1.3rem, 3vw, 2.4rem);
  }

  .writing-trajectory {
    margin-top: clamp(1.3rem, 3vw, 2.4rem);
  }

  .writing-vault-header p {
    margin: 0.55rem 0 0;
    color: var(--tone-muted);
  }

  .writing-proof-header p {
    margin: 0.55rem 0 0;
    color: var(--tone-muted);
    max-width: 62ch;
  }

  .writing-proof-grid {
    margin-top: 1rem;
    display: grid;
    gap: 0.85rem;
    grid-template-columns: minmax(0, 1.3fr) minmax(17rem, 0.9fr);
    align-items: start;
  }

  .writing-card--featured {
    background: linear-gradient(180deg, rgba(11, 16, 27, 0.78), rgba(7, 12, 20, 0.66));
  }

  .writing-proof-title {
    margin: 0.5rem 0 0;
    line-height: 1.14;
    font-size: clamp(1.55rem, 2.7vw, 2.15rem);
  }

  .writing-proof-stack {
    border: 1px solid var(--line2);
    border-radius: calc(var(--radius) * var(--space-scale));
    background: linear-gradient(180deg, rgba(10, 14, 23, 0.68), rgba(7, 11, 18, 0.56));
    padding: clamp(0.9rem, 2.2vw, 1.15rem);
    display: grid;
    gap: 0.75rem;
  }

  .writing-proof-stack-label {
    margin: 0;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--tone-accent-glow);
  }

  .writing-proof-mini {
    display: grid;
    gap: 0.4rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--line2);
  }

  .writing-proof-mini:first-of-type {
    padding-top: 0;
    border-top: 0;
  }

  .writing-proof-mini h3,
  .writing-proof-mini p:last-child {
    margin: 0;
  }

  .writing-proof-mini p:last-child {
    color: color-mix(in srgb, var(--tone-text) 84%, var(--tone-muted) 16%);
  }

  .writing-vault-list {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.85rem;
  }

  .writing-vault-card {
    border: 1px solid var(--line2);
    border-radius: calc(var(--radius) * var(--space-scale));
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--tone-surface-strong) 76%, transparent),
      color-mix(in srgb, var(--tone-surface) 66%, transparent)
    );
    padding: clamp(0.9rem, 2.2vw, 1.15rem);
  }

  .writing-vault-topline {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .writing-vault-topline h3 {
    margin: 0;
  }

  .writing-vault-status {
    border: 1px solid color-mix(in srgb, var(--tone-accent) 35%, var(--line2));
    border-radius: 999px;
    padding: 0.2rem 0.55rem;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--tone-accent-glow);
  }

  .writing-vault-logline {
    margin: 0.62rem 0 0;
    color: color-mix(in srgb, var(--tone-text) 84%, var(--tone-muted) 16%);
  }

  .writing-vault-meta {
    margin-top: 0.72rem;
    display: grid;
    gap: 0.42rem;
  }

  .writing-vault-meta p {
    margin: 0;
    color: var(--tone-muted);
    font-size: 0.86rem;
  }

  .writing-trajectory-header p {
    margin: 0.55rem 0 0;
    color: var(--tone-muted);
    max-width: 68ch;
  }

  .writing-trajectory-grid {
    display: grid;
    gap: 0.85rem;
    margin-top: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .writing-trajectory-card {
    border: 1px solid var(--line2);
    border-radius: calc(var(--radius) * var(--space-scale));
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--tone-surface-strong) 76%, transparent),
      color-mix(in srgb, var(--tone-surface) 66%, transparent)
    );
    padding: clamp(0.9rem, 2.2vw, 1.15rem);
  }

  .writing-trajectory-card h3 {
    margin: 0.42rem 0 0;
  }

  .writing-trajectory-card p:last-child {
    margin: 0.62rem 0 0;
    color: color-mix(in srgb, var(--tone-text) 84%, var(--tone-muted) 16%);
  }

  .writing-trajectory-period {
    margin: 0;
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--tone-accent-glow);
  }

  .writing-archive-header {
    display: grid;
    gap: 0.8rem;
    align-items: end;
  }

  .writing-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .writing-filter {
    border: 1px solid var(--line2);
    border-radius: 999px;
    background: color-mix(in srgb, var(--tone-surface) 52%, transparent);
    color: var(--tone-muted);
    padding: 0.33rem 0.72rem;
    font-size: 0.74rem;
    letter-spacing: 0.02em;
  }

  .writing-filter.is-active,
  .writing-filter:hover,
  .writing-filter:focus-visible {
    color: var(--tone-accent-glow);
    border-color: color-mix(in srgb, var(--tone-accent) 32%, var(--line2));
  }

  .writing-results {
    margin: 0;
    font-size: 0.82rem;
    color: color-mix(in srgb, var(--tone-text) 76%, var(--tone-muted) 24%);
  }

  .writing-list {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.85rem;
  }

  .writing-card {
    border: 1px solid var(--line2);
    border-radius: calc(var(--radius) * var(--space-scale));
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--tone-surface-strong) 74%, transparent),
      color-mix(in srgb, var(--tone-surface) 64%, transparent)
    );
    padding: clamp(0.9rem, 2.2vw, 1.2rem);
    transition: border-color 160ms ease, transform 160ms ease;
  }

  .writing-card:hover {
    border-color: color-mix(in srgb, var(--tone-accent) 28%, var(--line2));
    transform: translateY(-1px);
  }

  .writing-card-date {
    margin: 0;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--tone-text) 78%, var(--tone-muted) 22%);
  }

  .writing-card h3 {
    margin: 0.5rem 0 0;
    line-height: 1.2;
  }

  .writing-card-title {
    color: var(--tone-text);
    text-decoration: none;
  }

  .writing-card-title:hover,
  .writing-card-title:focus-visible {
    color: var(--tone-accent-glow);
  }

  .writing-card-summary {
    margin: 0.6rem 0 0;
    max-width: 70ch;
    color: color-mix(in srgb, var(--tone-text) 89%, var(--tone-muted) 11%);
  }

  .writing-card-footer {
    margin-top: 0.82rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.55rem;
  }

  .writing-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .writing-tag {
    border: 1px solid var(--line2);
    border-radius: 999px;
    font-size: 0.72rem;
    padding: 0.25rem 0.55rem;
    color: color-mix(in srgb, var(--tone-text) 80%, var(--tone-muted) 20%);
    background: color-mix(in srgb, var(--tone-surface) 56%, transparent);
  }

  .writing-read-link {
    color: var(--tone-accent-glow);
    font-size: 0.85rem;
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--tone-accent) 55%, transparent);
    white-space: nowrap;
  }

  .writing-read-link:hover,
  .writing-read-link:focus-visible {
    border-color: color-mix(in srgb, var(--tone-accent) 90%, transparent);
  }

  .writing-empty {
    margin-top: 0.8rem;
    color: var(--tone-muted);
  }

  @media (max-width: 700px) {
    .writing-proof-grid,
    .writing-trajectory-grid {
      grid-template-columns: 1fr;
    }

    .writing-card-footer {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
