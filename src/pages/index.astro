---
import BaseLayout from '../layouts/BaseLayout.astro';
import profile from '../data/profile';
import featuredThreads from '../data/featured_threads.json';
import { getCollection } from 'astro:content';
import UntitledPlayer from '../components/UntitledPlayer.astro';
import EmbedCard from '../components/EmbedCard.astro';
import AIAccountabilityPanel from '../components/AIAccountabilityPanel.astro';
import HomeTabReflections from '../components/HomeTabReflections.astro';
import HomeSocialFeeds from '../components/HomeSocialFeeds.astro';
import { LINK_HUB_CATEGORIES, type AccentColorKey, type LinkHubItem } from '../data/linkhub';
import igManifest from '../data/ig.json';
import xFallbackItems from '../data/x-fallback';

import rooms from '../data/rooms';
import agiTimelineData from '../data/agi-timeline.json';

const allProjects = await getCollection('projects');
const allPosts = (await getCollection('posts')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const threads = featuredThreads.featured_threads;
const categoryItems = new Map(LINK_HUB_CATEGORIES.map((category) => [category.id, category.items]));
const pickItems = (categoryId: string, ids: string[]): LinkHubItem[] => {
  const items = categoryItems.get(categoryId) || [];
  return ids
    .map((id) => items.find((item) => item.id === id))
    .filter((item): item is LinkHubItem => Boolean(item));
};

const nowListeningItem = pickItems('music', ['now-listening'])[0];
type SectionPanelType = 'embed' | 'ai-accountability';
type SiteToneKey =
  | 'balance'
  | 'clarity'
  | 'devotion'
  | 'contemplation'
  | 'discernment'
  | 'vitality'
  | 'grounding'
  | 'compassion'
  | 'harmony'
  | 'seva'
  | 'intensity'
  | 'presence';

interface BaseHomeSection {
  id: string;
  label: string;
  color: AccentColorKey;
  tone: SiteToneKey;
  panelType: SectionPanelType;
}

interface EmbedHomeSection extends BaseHomeSection {
  panelType: 'embed';
  items: LinkHubItem[];
}

interface AIAccountabilityHomeSection extends BaseHomeSection {
  panelType: 'ai-accountability';
}

type HomeSection = EmbedHomeSection | AIAccountabilityHomeSection;

const homeSections: HomeSection[] = [
  {
    id: 'music',
    label: 'Music',
    color: 'blue',
    tone: 'vitality',
    panelType: 'embed',
    items: pickItems('music', ['my-first-beat-tape', 'everyday-soundscape']).concat(
      pickItems('resources', ['practicing-kriya'])
    )
  },
  {
    id: 'visual',
    label: 'Visual',
    color: 'orange',
    tone: 'devotion',
    panelType: 'embed',
    items: pickItems('social', ['instagram', 'threads', 'tiktok'])
  },
  {
    id: 'video',
    label: 'Video',
    color: 'red',
    tone: 'intensity',
    panelType: 'embed',
    items: pickItems('video', ['everyday-life-video', 'youtube-channel', 'post-labor-econ-playlist'])
  },
  {
    id: 'growth',
    label: 'Growth',
    color: 'indigo',
    tone: 'compassion',
    items: pickItems('video', ['growth-happiness-journey'])
  },
  {
    id: 'newark',
    label: 'Newark',
    color: 'yellow',
    tone: 'grounding',
    panelType: 'embed',
    items: pickItems('resources', ['work-archive', 'map', 'mit-living-wage'])
  },
  {
    id: 'scraps',
    label: 'Scraps',
    color: 'violet',
    tone: 'contemplation',
    panelType: 'embed',
    items: pickItems('music', ['scraps-2023-2024']).concat(
      pickItems('writing', ['writing-archive', 'substack', 'magazine-publication'])
    )
  },
  {
    id: 'ai-accountability',
    label: 'AI Accountability',
    color: 'indigo',
    tone: 'discernment',
    panelType: 'ai-accountability'
  }
];
const shortDateFormatter = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric'
});
const pluralize = (count: number, singular: string, plural = `${singular}s`) => `${count} ${count === 1 ? singular : plural}`;
const formatDateLabel = (value: unknown, fallback: string): string => {
  let parsed: Date | null = null;

  if (value instanceof Date) {
    parsed = Number.isNaN(value.valueOf()) ? null : value;
  } else if (typeof value === 'string' || typeof value === 'number') {
    const candidate = new Date(value);
    parsed = Number.isNaN(candidate.valueOf()) ? null : candidate;
  }

  return parsed ? shortDateFormatter.format(parsed) : fallback;
};

const projectCount = allProjects.length;
const projectTypeCount = new Set(allProjects.map((project) => project.data.type)).size;
const postCount = allPosts.length;
const latestPostDateLabel = formatDateLabel(allPosts[0]?.data?.date, 'recently');
const roomList = Array.isArray(rooms) ? rooms : [];
const roomCount = roomList.length;
const machineCount = roomList.reduce((count, room) => count + (Array.isArray(room.machines) ? room.machines.length : 0), 0);
const agiSignalCount = Array.isArray(agiTimelineData?.items) ? agiTimelineData.items.length : 0;
const agiUpdatedAtLabel = formatDateLabel(agiTimelineData?.meta?.generatedAt, 'Updated recently');
const reflectionItems = [
  {
    id: 'work',
    title: 'Work',
    href: '/work',
    summary:
      projectCount > 0
        ? `${pluralize(projectCount, 'project')} across ${pluralize(projectTypeCount, 'type')}.`
        : 'No projects indexed yet.',
    meta: projectCount > 0 ? `Coverage: ${pluralize(projectTypeCount, 'type')}` : 'Coverage pending',
    cta: 'Open Work'
  },
  {
    id: 'writing',
    title: 'Writing',
    href: '/writing',
    summary:
      postCount > 0 ? `${pluralize(postCount, 'entry', 'entries')} published. Latest ${latestPostDateLabel}.` : 'No entries yet.',
    meta: postCount > 0 ? `Latest update ${latestPostDateLabel}` : 'Latest update pending',
    cta: 'Open Writing'
  },
  {
    id: 'social',
    title: 'Social',
    href: '/social',
    summary: `${pluralize(roomCount, 'room')} and ${pluralize(machineCount, 'machine')} mapped in the arcade.`,
    meta: `Index: ${pluralize(roomCount, 'room')}`,
    cta: 'Open Social'
  },
  {
    id: 'agi',
    title: 'AGI Timeline',
    href: '/agi',
    summary: agiSignalCount > 0 ? `${pluralize(agiSignalCount, 'signal')} tracked in the monitor.` : 'No AGI signals indexed yet.',
    meta: `Last sync ${agiUpdatedAtLabel}`,
    cta: 'Open AGI Timeline'
  },
  {
    id: 'contact',
    title: 'Contact',
    href: '/contact',
    summary: 'Inquiry form plus 4 quick links for direct outreach.',
    meta: 'Channels: form + socials',
    cta: 'Open Contact'
  }
];
const archivePulseItems = [
  {
    label: 'Featured now',
    value: pluralize(threads.length, 'thread')
  },
  {
    label: 'Writing archive',
    value: pluralize(postCount, 'entry', 'entries')
  },
  {
    label: 'Rooms mapped',
    value: pluralize(roomCount, 'room')
  },
  {
    label: 'Last signal',
    value: agiUpdatedAtLabel
  }
];
const xHandle = 'a_e_s_4';
const youtubeChannelId = 'UCQeJiBS72gxrZXw5GmqtocA';
const youtubeUploadsPlaylistId = `UU${youtubeChannelId.slice(2)}`;
const xPublishedAtToTimestamp = (value: string): number => {
  const parsed = Date.parse(value);
  return Number.isNaN(parsed) ? 0 : parsed;
};
const localXFallbackItems = xFallbackItems
  .map((item) => ({
    title: String(item?.title || '').trim(),
    url: String(item?.url || '').trim(),
    publishedAt: String(item?.publishedAt || '').trim(),
    summary: String(item?.summary || '').trim()
  }))
  .filter((item) => item.title && item.url);
const xFeedMode = 'fallback' as const;
const xFeedItems = localXFallbackItems
  .sort((a, b) => xPublishedAtToTimestamp(b.publishedAt) - xPublishedAtToTimestamp(a.publishedAt))
  .slice(0, 6);
const youtubeUploadsEmbedUrl = `https://www.youtube-nocookie.com/embed/videoseries?list=${youtubeUploadsPlaylistId}`;
const instagramPreview = (Array.isArray(igManifest) ? igManifest : [])
  .filter((item) => typeof item?.src === 'string' && item.src)
  .slice(0, 4)
  .map((item) => ({
    src: String(item.src),
    caption: typeof item.caption === 'string' ? item.caption : '',
    date: typeof item.date === 'string' ? item.date : ''
  }));
---

<BaseLayout title="A Path Toward Life — Archive" description={profile.short_bio} theme="archive">
  <div class="desktop-home">
    <section class="home-hero">
      <div class="home-hero__content space-y-6 text-center">
        <p class="text-xs uppercase tracking-[0.2em] text-zinc-500">Timeline / Archive</p>
        <h1 class="mx-auto max-w-3xl font-display text-4xl font-bold md:text-6xl text-accent">A Path Toward Life</h1>
        <p class="mx-auto max-w-4xl text-lg">{profile.long_bio}</p>
        <div class="flex flex-wrap justify-center gap-2" aria-label="Identity chips">
          {profile.roles.map((role) => <span class="chip rounded-full px-3 py-1 text-sm">{role}</span>)}
        </div>
        <dl class="home-hero__pulse" aria-label="Archive pulse">
          {archivePulseItems.map((item) => (
            <div class="home-hero__pulse-item">
              <dt class="home-hero__pulse-label">{item.label}</dt>
              <dd class="home-hero__pulse-value">{item.value}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <section class="mt-12 md:mt-14">
      <h2 class="font-display text-2xl">Featured Threads</h2>
      <div class="mt-4 flex gap-4 overflow-x-auto pb-2 md:grid md:grid-cols-3 md:overflow-visible">
        {threads.map((thread) => (
          <a
            href={thread.href}
            class="card threadCard min-w-[270px] p-4"
            {...(thread.external ? { target: '_blank', rel: 'noopener' } : {})}
          >
            <p class="text-xs uppercase tracking-wide text-zinc-500">{thread.year} · {thread.type}</p>
            <h3 class="mt-1 font-display text-lg">{thread.title}</h3>
            <p class="mt-2 text-sm">{thread.blurb}</p>
            <p class="mt-3 text-sm underline decoration-accent">View thread</p>
          </a>
        ))}
      </div>
    </section>

    <HomeTabReflections items={reflectionItems} sectionTitle="Tab Reflections" variant="desktop" />

    <section class="mt-12 md:mt-14">
      <h2 class="font-display text-2xl">Sections</h2>
      <div class="mt-3 section-tablist" role="tablist" aria-label="Section spotlight tabs">
        {homeSections.map((section, index) => (
          <button
            type="button"
            role="tab"
            data-section-tab={section.id}
            data-color={section.color}
            data-tone={section.tone}
            aria-selected={index === 0 ? 'true' : 'false'}
            class:list={['section-tab', index === 0 && 'is-active']}
          >
            {section.label}
          </button>
        ))}
      </div>

      <div class="mt-4 section-panels">
        {homeSections.map((section, index) => (
          <div
            class:list={['section-panel', index === 0 && 'is-active']}
            data-section-panel={section.id}
            role="tabpanel"
            aria-label={`${section.label} spotlight`}
          >
            {section.panelType === 'embed' ? (
              section.items.length > 0 ? (
                <div class="section-cards">
                  {section.items.map((item) => (
                    <div class="section-card-shell">
                      <EmbedCard item={item} showResizeHint={true} />
                    </div>
                  ))}
                </div>
              ) : (
                <p class="text-sm text-zinc-400">No spotlight links configured yet.</p>
              )
            ) : (
              <AIAccountabilityPanel />
            )}
          </div>
        ))}
      </div>
    </section>

    <HomeSocialFeeds
      xHandle={xHandle}
      xFeedItems={xFeedItems}
      xFeedMode={xFeedMode}
      youtubeUploadsEmbedUrl={youtubeUploadsEmbedUrl}
      youtubeChannelUrl={profile.social_links.youtube}
      instagramProfileUrl={profile.social_links.instagram}
      instagramArchiveUrl="/instagram"
      instagramPreview={instagramPreview}
    />

    <UntitledPlayer title="Listen" subtitle="untitled.stream" />
    {nowListeningItem && (
      <section class="mt-4">
        <h2 class="mb-3 font-display text-xl">Now Listening</h2>
        <EmbedCard item={nowListeningItem} />
      </section>
    )}
  </div>

  <script is:inline>
    (() => {
      const tablist = document.querySelector('.section-tablist');
      const tabs = Array.from(document.querySelectorAll('[data-section-tab]'));
      const panels = Array.from(document.querySelectorAll('[data-section-panel]'));
      if (!(tablist instanceof HTMLElement) || !tabs.length || !panels.length) return;

      const activate = (id, syncAccent = true) => {
        tabs.forEach((tab) => {
          const active = tab.getAttribute('data-section-tab') === id;
          tab.classList.toggle('is-active', active);
          tab.setAttribute('aria-selected', String(active));
        });
        panels.forEach((panel) => {
          const active = panel.getAttribute('data-section-panel') === id;
          panel.classList.toggle('is-active', active);
        });
        window.dispatchEvent(new CustomEvent('home:section-activated', { detail: { id } }));

        const activeTab = tabs.find((tab) => tab.getAttribute('data-section-tab') === id);
        if (activeTab instanceof HTMLElement && tablist.scrollWidth > tablist.clientWidth + 1) {
          activeTab.scrollIntoView({
            behavior: syncAccent ? 'smooth' : 'auto',
            block: 'nearest',
            inline: 'center'
          });
        }

        if (!syncAccent) return;
        const color = activeTab?.getAttribute('data-color') || 'blue';
        const tone = activeTab?.getAttribute('data-tone') || 'balance';
        window.__setSiteAccent?.(color, { animate: true, duration: 250 });
        window.__setSiteTone?.(tone, { animate: true });
      };

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const id = tab.getAttribute('data-section-tab');
          if (id) activate(id);
        });
      });

      let dragPointerId = -1;
      let dragStartX = 0;
      let dragStartScrollLeft = 0;
      let suppressClick = false;

      const endDrag = (pointerId) => {
        if (dragPointerId !== pointerId) return;
        if (tablist.hasPointerCapture(dragPointerId)) {
          tablist.releasePointerCapture(dragPointerId);
        }
        tablist.classList.remove('is-dragging');
        dragPointerId = -1;
      };

      tablist.addEventListener(
        'click',
        (event) => {
          if (!suppressClick) return;
          event.preventDefault();
          event.stopPropagation();
          suppressClick = false;
        },
        true
      );

      tablist.addEventListener('pointerdown', (event) => {
        if (event.pointerType !== 'mouse' || event.button !== 0) return;
        if (tablist.scrollWidth <= tablist.clientWidth + 1) return;

        dragPointerId = event.pointerId;
        dragStartX = event.clientX;
        dragStartScrollLeft = tablist.scrollLeft;
        suppressClick = false;

        tablist.classList.add('is-dragging');
        tablist.setPointerCapture(event.pointerId);
      });

      tablist.addEventListener('pointermove', (event) => {
        if (dragPointerId !== event.pointerId) return;

        const deltaX = event.clientX - dragStartX;
        if (!suppressClick && Math.abs(deltaX) > 4) {
          suppressClick = true;
        }

        if (!suppressClick) return;
        tablist.scrollLeft = dragStartScrollLeft - deltaX;
        event.preventDefault();
      });

      tablist.addEventListener('pointerup', (event) => {
        const dragged = suppressClick;
        endDrag(event.pointerId);
        if (dragged) {
          window.setTimeout(() => {
            suppressClick = false;
          }, 0);
        }
      });

      tablist.addEventListener('pointercancel', (event) => {
        endDrag(event.pointerId);
        suppressClick = false;
      });

      const first = tabs[0]?.getAttribute('data-section-tab');
      if (first) activate(first, false);
    })();
  </script>
</BaseLayout>

<style>
  .home-hero {
    position: relative;
    isolation: isolate;
    min-height: clamp(22rem, 42vw, 32rem);
    display: grid;
    place-items: center;
    overflow: hidden;
    border-radius: clamp(1.6rem, 3vw, 2.8rem);
    margin-bottom: clamp(1rem, 2vw, 2rem);
    border: 1px solid color-mix(in srgb, var(--tone-accent) 10%, var(--line2));
    background:
      linear-gradient(180deg, rgba(5, 9, 17, 0.26), rgba(4, 8, 15, 0.74)),
      radial-gradient(
        78% 58% at 50% 4%,
        color-mix(in srgb, var(--tone-accent) 7%, transparent),
        transparent 72%
      ),
      linear-gradient(135deg, rgba(8, 13, 22, 0.26), rgba(4, 8, 15, 0.6)),
      url('/images/bg-station.jpg');
    background-position: center;
    background-size: cover;
    box-shadow:
      0 30px 80px rgba(0, 0, 0, 0.42),
      0 1px 0 rgba(255, 255, 255, 0.03) inset;
  }

  .home-hero::before,
  .home-hero::after {
    content: '';
    position: absolute;
    pointer-events: none;
  }

  .home-hero::before {
    inset: -18% -8% 26%;
    z-index: 0;
    background:
      radial-gradient(
        34% 20% at 50% 22%,
        color-mix(in srgb, var(--tone-accent-bright) 14%, transparent),
        transparent 72%
      ),
      radial-gradient(
        26% 16% at 26% 26%,
        color-mix(in srgb, var(--tone-sky-bright) 10%, transparent),
        transparent 74%
      ),
      radial-gradient(
        26% 16% at 74% 24%,
        color-mix(in srgb, var(--tone-sky-bright) 8%, transparent),
        transparent 74%
      );
    filter: blur(32px);
    opacity: 0.8;
  }

  .home-hero::after {
    inset: 0;
    z-index: 2;
    background:
      linear-gradient(
        115deg,
        transparent 0%,
        transparent 24%,
        rgba(255, 255, 255, 0.04) 34%,
        transparent 46%,
        transparent 100%
      ),
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.022) 0 1px,
        transparent 1px 40px
      );
    mix-blend-mode: screen;
    opacity: 0.18;
  }

  .home-hero__content {
    position: relative;
    z-index: 4;
    width: min(100%, 56rem);
    padding:
      clamp(4.25rem, 8vw, 6.75rem)
      clamp(1.25rem, 5vw, 4rem)
      clamp(3.25rem, 7vw, 5.5rem);
    text-shadow: 0 10px 30px rgba(0, 0, 0, 0.28);
  }

  .home-hero__content::before,
  .home-hero__content::after {
    content: '';
    position: absolute;
    z-index: -1;
    pointer-events: none;
  }

  .home-hero__content::before {
    inset:
      clamp(1.1rem, 3vw, 2.2rem)
      clamp(0.8rem, 4vw, 2.4rem)
      clamp(1rem, 3vw, 2rem);
    border-radius: clamp(1.35rem, 3vw, 2.2rem);
    background:
      radial-gradient(
        52% 50% at 50% 34%,
        rgba(8, 13, 22, 0.08),
        rgba(8, 13, 22, 0.28) 68%,
        rgba(8, 13, 22, 0.54)
      ),
      linear-gradient(
        180deg,
        rgba(8, 13, 22, 0.03),
        rgba(8, 13, 22, 0.14) 42%,
        rgba(8, 13, 22, 0.3)
      );
    border: 1px solid rgba(255, 255, 255, 0.07);
    backdrop-filter: blur(14px) saturate(1.04);
    box-shadow:
      0 28px 56px rgba(0, 0, 0, 0.24),
      0 1px 0 rgba(255, 255, 255, 0.05) inset;
  }

  .home-hero__content::after {
    inset:
      clamp(1.45rem, 3.4vw, 2.5rem)
      clamp(1.1rem, 4.6vw, 2.8rem)
      clamp(1.35rem, 3.4vw, 2.3rem);
    border-radius: clamp(1.1rem, 2.7vw, 2rem);
    border: 1px solid rgba(255, 255, 255, 0.035);
    background:
      linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.03),
        transparent 22%,
        transparent 74%,
        rgba(242, 184, 75, 0.03)
      );
  }

  .home-hero__pulse {
    width: min(100%, 44rem);
    margin: clamp(0.25rem, 1vw, 0.6rem) auto 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(0.55rem, 1vw, 0.8rem);
  }

  .home-hero__pulse-item {
    margin: 0;
    padding: clamp(0.68rem, 1.2vw, 0.9rem) clamp(0.75rem, 1.4vw, 0.95rem);
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.05);
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.04),
        rgba(255, 255, 255, 0.015)
      ),
      color-mix(in srgb, var(--tone-bg) 84%, rgba(255, 255, 255, 0.02));
    box-shadow:
      0 14px 28px rgba(0, 0, 0, 0.22),
      0 1px 0 rgba(255, 255, 255, 0.03) inset;
    backdrop-filter: blur(12px);
  }

  .home-hero__pulse-label,
  .home-hero__pulse-value {
    margin: 0;
  }

  .home-hero__pulse-label {
    font-size: 0.66rem;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: color-mix(in srgb, var(--tone-text) 64%, var(--tone-muted) 36%);
  }

  .home-hero__pulse-value {
    margin-top: 0.32rem;
    font-family: var(--font-display);
    font-size: clamp(0.94rem, 1.7vw, 1.08rem);
    line-height: 1.22;
    color: color-mix(in srgb, var(--tone-accent-glow) 92%, white 8%);
  }

  .section-tablist {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: clamp(0.8rem, 1.3vw, 1.3rem);
    border-bottom: 1px solid var(--line2);
    padding-bottom: 0.12rem;
  }

  .section-tab {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0.2rem 0.72rem 0.44rem;
    border: 0;
    border-radius: 999px;
    background: transparent;
    box-shadow: none;
    backdrop-filter: none;
    background: color-mix(in oklab, var(--tone-accent) 0%, transparent);
    color: color-mix(in srgb, var(--tone-text) 88%, var(--tone-muted) 12%);
    font-size: 0.875rem;
    line-height: 1.15;
    cursor: pointer;
    transition:
      color var(--motion-fast) var(--ease-standard),
      background-color var(--motion-base) var(--ease-standard),
      transform var(--motion-fast) var(--ease-emphasized);
  }

  .section-tab::after {
    content: '';
    position: absolute;
    left: 0.72rem;
    right: 0.72rem;
    bottom: 7px;
    height: 1px;
    transform: scaleX(0);
    transform-origin: left center;
    background: color-mix(in srgb, var(--tone-accent) 82%, #fff 18%);
    opacity: 0.8;
    transition:
      transform var(--motion-fast) var(--ease-emphasized),
      background-color var(--motion-base) var(--ease-standard);
  }

  .section-tab:hover,
  .section-tab:focus-visible,
  .section-tab.is-active {
    color: var(--tone-accent-glow);
    background: color-mix(in srgb, var(--tone-accent) 16%, transparent);
    transform: translateY(-1px);
  }

  .section-tab:hover::after,
  .section-tab:focus-visible::after,
  .section-tab.is-active::after {
    transform: scaleX(1);
