---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeMapPreview from '../components/HomeMapPreview.astro';
import profile from '../data/profile';
import featuredThreads from '../data/featured_threads.json';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const allPosts = (await getCollection('posts')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const threads = featuredThreads.featured_threads;
const featuredThreadsPreview = threads.slice(0, 3);
const startHereCards = [
  {
    href: '/work',
    label: 'Selected Work',
    description: 'Projects and outcomes'
  },
  {
    href: '/writing',
    label: 'Writing',
    description: 'Essays and field notes'
  },
  {
    href: '/map',
    label: 'Map',
    description: 'Concept and route atlas'
  },
  {
    href: '/now',
    label: 'Now',
    description: 'Current focus and direction'
  }
];

const shortDateFormatter = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric'
});

const pluralize = (count: number, singular: string, plural = `${singular}s`) => `${count} ${count === 1 ? singular : plural}`;

const formatDateLabel = (value: unknown, fallback: string): string => {
  let parsed: Date | null = null;

  if (value instanceof Date) {
    parsed = Number.isNaN(value.valueOf()) ? null : value;
  } else if (typeof value === 'string' || typeof value === 'number') {
    const candidate = new Date(value);
    parsed = Number.isNaN(candidate.valueOf()) ? null : candidate;
  }

  return parsed ? shortDateFormatter.format(parsed) : fallback;
};

const heroPulseItems = [
  { label: 'Projects', value: pluralize(allProjects.length, 'project') },
  { label: 'Writing', value: pluralize(allPosts.length, 'entry', 'entries') },
  { label: 'Threads', value: pluralize(threads.length, 'thread') },
  { label: 'Latest note', value: formatDateLabel(allPosts[0]?.data?.date, 'Archive snapshot') }
];
---

<BaseLayout title="A Path Toward Life - Portfolio" description={profile.short_bio} theme="archive">
  <div class="desktop-home">
    <section class="home-hero">
      <div class="home-hero__content space-y-6 text-center">
        <span class="home-hero__ivy home-hero__ivy--left" aria-hidden="true"></span>
        <span class="home-hero__ivy home-hero__ivy--right" aria-hidden="true"></span>
        <p class="text-xs uppercase tracking-[0.2em] text-zinc-500">Portfolio / Archive</p>
        <h1 class="mx-auto max-w-3xl font-display text-3xl font-bold sm:text-4xl md:text-6xl text-accent">A Path Toward Life</h1>
        <p class="mx-auto max-w-4xl text-base sm:text-lg">{profile.long_bio}</p>
        <div class="flex flex-wrap justify-center gap-2" aria-label="Identity chips">
          {profile.roles.map((role) => <span class="chip rounded-full px-3 py-1 text-xs sm:text-sm">{role}</span>)}
        </div>
        <dl class="home-hero__pulse" aria-label="Portfolio pulse">
          {heroPulseItems.map((item) => (
            <div class="home-hero__pulse-item">
              <dt class="home-hero__pulse-label">{item.label}</dt>
              <dd class="home-hero__pulse-value">{item.value}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <HomeMapPreview />

    <section class="home-start mt-12 md:mt-14" aria-labelledby="home-start-heading">
      <p class="home-start-kicker">Start here</p>
      <h2 id="home-start-heading" class="home-start-title">Choose your first path</h2>
      <div class="home-start-grid">
        {startHereCards.map((card) => (
          <a class="home-start-card" href={card.href}>
            <span>{card.label}</span>
            <small>{card.description}</small>
          </a>
        ))}
      </div>
    </section>

    <section class="home-featured mt-12 md:mt-14" aria-labelledby="featured-threads-heading">
      <div class="home-featured__header">
        <div class="space-y-2">
          <p class="home-featured__kicker">Portfolio</p>
          <h2 id="featured-threads-heading" class="font-display text-2xl">Featured Threads</h2>
          <p class="home-featured__copy">
            A smaller set of anchor pieces from the archive. Deeper browsing stays on the section pages.
          </p>
        </div>
        <a href="/work" class="home-featured__link" data-color="ochre" data-tone="seva">Open Work</a>
      </div>

      <div class="home-featured__grid">
        {featuredThreadsPreview.map((thread) => (
          <a
            href={thread.href}
            class="card threadCard p-4"
            {...(thread.external ? { target: '_blank', rel: 'noopener' } : {})}
          >
            <p class="text-xs uppercase tracking-wide text-zinc-500">{thread.year} · {thread.type}</p>
            <h3 class="mt-1 font-display text-lg">{thread.title}</h3>
            <p class="mt-2 text-sm">{thread.blurb}</p>
            <p class="mt-3 text-sm underline decoration-accent">View thread</p>
          </a>
        ))}
      </div>
    </section>

    <section class="home-ai-callout mt-12 md:mt-14" aria-labelledby="home-ai-callout-heading">
      <div class="card home-ai-callout__card">
        <p class="home-ai-callout__kicker">Accountability</p>
        <h2 id="home-ai-callout-heading" class="home-ai-callout__title">AI Accountability</h2>
        <p class="home-ai-callout__copy">
          AI is physical infrastructure with public costs. The accountability work stays visible, civic, and measurable.
        </p>
        <a href="/ai-accountability-pledge" class="home-ai-callout__link">Read the pledge</a>
      </div>
    </section>

    <section class="home-now-signal mt-6" aria-label="Now signal">
      <p>
        <span class="home-now-signal__label">Now signal</span>
        Current focus, active edits, and the next move live on <a href="/now">/now</a>.
      </p>
    </section>
  </div>
</BaseLayout>

<style>
  .home-hero {
    position: relative;
    isolation: isolate;
    min-height: clamp(22rem, 42vw, 32rem);
    display: grid;
    place-items: center;
    overflow: hidden;
    border-radius: clamp(1.6rem, 3vw, 2.8rem);
    margin-bottom: clamp(1rem, 2vw, 2rem);
    border: 1px solid color-mix(in srgb, var(--tone-accent) 10%, var(--line2));
    background:
      linear-gradient(180deg, rgba(5, 9, 17, 0.26), rgba(4, 8, 15, 0.74)),
      radial-gradient(
        78% 58% at 50% 4%,
        color-mix(in srgb, var(--tone-accent) 7%, transparent),
        transparent 72%
      ),
      linear-gradient(135deg, rgba(8, 13, 22, 0.26), rgba(4, 8, 15, 0.6)),
      url('/images/bg-station.jpg');
    background-position: center;
    background-size: cover;
    box-shadow:
      0 30px 80px rgba(0, 0, 0, 0.42),
      0 1px 0 rgba(255, 255, 255, 0.03) inset;
  }

  .home-hero::before,
  .home-hero::after {
    content: '';
    position: absolute;
    pointer-events: none;
  }

  .home-hero::before {
    inset: -18% -8% 26%;
    z-index: 0;
    background:
      radial-gradient(
        34% 20% at 50% 22%,
        color-mix(in srgb, var(--tone-accent-bright) 14%, transparent),
        transparent 72%
      ),
      radial-gradient(
        26% 16% at 26% 26%,
        color-mix(in srgb, var(--tone-sky-bright) 10%, transparent),
        transparent 74%
      ),
      radial-gradient(
        26% 16% at 74% 24%,
        color-mix(in srgb, var(--tone-sky-bright) 8%, transparent),
        transparent 74%
      );
    filter: blur(32px);
    opacity: 0.8;
  }

  .home-hero::after {
    inset: 0;
    z-index: 2;
    background:
      linear-gradient(
        115deg,
        transparent 0%,
        transparent 24%,
        rgba(255, 255, 255, 0.04) 34%,
        transparent 46%,
        transparent 100%
      ),
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.022) 0 1px,
        transparent 1px 40px
      );
    mix-blend-mode: screen;
    opacity: 0.18;
  }

  .home-hero__content {
    position: relative;
    isolation: isolate;
    z-index: 4;
    width: min(100%, 56rem);
    padding:
      clamp(4.25rem, 8vw, 6.75rem)
      clamp(1.25rem, 5vw, 4rem)
      clamp(3.25rem, 7vw, 5.5rem);
    text-shadow: 0 10px 30px rgba(0, 0, 0, 0.28);
  }

  .home-hero__content::before,
  .home-hero__content::after {
    content: '';
    position: absolute;
    pointer-events: none;
  }

  .home-hero__content::before {
    z-index: 0;
    inset:
      clamp(1.1rem, 3vw, 2.2rem)
      clamp(0.8rem, 4vw, 2.4rem)
      clamp(1rem, 3vw, 2rem);
    border-radius: clamp(1.35rem, 3vw, 2.2rem);
    background:
      radial-gradient(
        52% 50% at 50% 34%,
        rgba(8, 13, 22, 0.08),
        rgba(8, 13, 22, 0.28) 68%,
        rgba(8, 13, 22, 0.54)
      ),
      linear-gradient(
        180deg,
        rgba(8, 13, 22, 0.03),
        rgba(8, 13, 22, 0.14) 42%,
        rgba(8, 13, 22, 0.3)
      );
    border: 1px solid rgba(255, 255, 255, 0.07);
    backdrop-filter: blur(14px) saturate(1.04);
    box-shadow:
      0 28px 56px rgba(0, 0, 0, 0.24),
      0 1px 0 rgba(255, 255, 255, 0.05) inset;
  }

  .home-hero__content::after {
    z-index: 2;
    inset:
      clamp(1.45rem, 3.4vw, 2.5rem)
      clamp(1.1rem, 4.6vw, 2.8rem)
      clamp(1.35rem, 3.4vw, 2.3rem);
    border-radius: clamp(1.1rem, 2.7vw, 2rem);
    border: 1px solid rgba(255, 255, 255, 0.035);
    background:
      linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.03),
        transparent 22%,
        transparent 74%,
        rgba(242, 184, 75, 0.03)
      );
  }

  .home-hero__content > :not(.home-hero__ivy) {
    position: relative;
    z-index: 3;
  }

  .home-hero__ivy {
    position: absolute;
    top: clamp(0.2rem, 1vw, 0.9rem);
    z-index: 1;
    width: clamp(104px, 14%, 148px);
    height: clamp(136px, 23%, 196px);
    pointer-events: none;
    background-repeat: no-repeat;
    background-size: contain;
    opacity: 0.7;
    filter: saturate(0.7) brightness(0.78) contrast(0.94) drop-shadow(0 10px 14px rgba(0, 0, 0, 0.16));
  }

  .home-hero__ivy--left {
    left: clamp(0.8rem, 2.4vw, 1.6rem);
    background-image: url('/images/garland/left-vine.png');
    background-position: left top;
    transform: rotate(-4deg);
    -webkit-mask-image: linear-gradient(160deg, rgba(0, 0, 0, 0.96) 18%, rgba(0, 0, 0, 0.9) 54%, transparent 100%);
    mask-image: linear-gradient(160deg, rgba(0, 0, 0, 0.96) 18%, rgba(0, 0, 0, 0.9) 54%, transparent 100%);
  }

  .home-hero__ivy--right {
    right: clamp(0.8rem, 2.4vw, 1.6rem);
    background-image: url('/images/garland/right-vine.png');
    background-position: right top;
    transform: rotate(4deg);
    -webkit-mask-image: linear-gradient(200deg, rgba(0, 0, 0, 0.96) 18%, rgba(0, 0, 0, 0.9) 54%, transparent 100%);
    mask-image: linear-gradient(200deg, rgba(0, 0, 0, 0.96) 18%, rgba(0, 0, 0, 0.9) 54%, transparent 100%);
  }

  .home-hero__pulse {
    width: min(100%, 44rem);
    margin: clamp(0.25rem, 1vw, 0.6rem) auto 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(0.55rem, 1vw, 0.8rem);
  }

  .home-hero__pulse-item {
    margin: 0;
    padding: clamp(0.68rem, 1.2vw, 0.9rem) clamp(0.75rem, 1.4vw, 0.95rem);
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.05);
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.04),
        rgba(255, 255, 255, 0.015)
      ),
      color-mix(in srgb, var(--tone-bg) 84%, rgba(255, 255, 255, 0.02));
    box-shadow:
      0 14px 28px rgba(0, 0, 0, 0.22),
      0 1px 0 rgba(255, 255, 255, 0.03) inset;
    backdrop-filter: blur(12px);
  }

  .home-hero__pulse-label,
  .home-hero__pulse-value {
    margin: 0;
  }

  .home-hero__pulse-label {
    font-size: 0.74rem;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: color-mix(in srgb, var(--tone-text) 78%, var(--tone-muted) 22%);
  }

  .home-hero__pulse-value {
    margin-top: 0.32rem;
    font-family: var(--font-display);
    font-size: clamp(0.94rem, 1.7vw, 1.08rem);
    line-height: 1.22;
    color: color-mix(in srgb, var(--tone-accent-glow) 92%, white 8%);
  }

  .home-start {
    padding: clamp(0.95rem, 1.8vw, 1.2rem);
    border: 1px solid color-mix(in srgb, var(--tone-accent) 22%, var(--line2));
    border-radius: 1rem;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--tone-accent) 11%, transparent), transparent 62%),
      color-mix(in srgb, var(--tone-surface-strong) 88%, transparent);
  }

  .home-start-kicker,
  .home-start-title,
  .home-ai-callout__kicker,
  .home-ai-callout__title,
  .home-ai-callout__copy,
  .home-now-signal p {
    margin: 0;
  }

  .home-start-kicker,
  .home-ai-callout__kicker,
  .home-now-signal__label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: color-mix(in srgb, var(--tone-text) 84%, var(--tone-muted) 16%);
  }

  .home-start-title,
  .home-ai-callout__title {
    margin-top: 0.35rem;
    font-size: clamp(1.2rem, 2vw, 1.6rem);
    line-height: 1.15;
  }

  .home-start-grid {
    margin-top: 0.75rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 0.6rem;
  }

  .home-start-card {
    border: 1px solid color-mix(in srgb, var(--tone-accent) 24%, var(--line2));
    border-radius: 0.82rem;
    padding: 0.7rem 0.74rem;
    display: grid;
    gap: 0.28rem;
    text-decoration: none;
    color: color-mix(in srgb, var(--tone-text) 92%, var(--tone-muted) 8%);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--tone-accent) 16%, transparent), transparent 64%),
      color-mix(in srgb, var(--tone-surface) 90%, transparent);
    transition:
      border-color 140ms ease,
      transform 140ms ease,
      color 140ms ease;
  }

  .home-start-card span {
    font-family: var(--font-display);
    font-size: 0.98rem;
    line-height: 1.2;
  }

  .home-start-card small {
    color: color-mix(in srgb, var(--tone-text) 80%, var(--tone-muted) 20%);
    font-size: 0.76rem;
    line-height: 1.4;
  }

  .home-start-card:hover,
  .home-start-card:focus-visible {
    border-color: color-mix(in srgb, var(--tone-accent) 58%, var(--line2));
    color: var(--tone-accent-glow);
    transform: translateY(-1px);
  }

  .home-featured {
    display: grid;
    gap: 1rem;
  }

  .home-featured__header {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
  }

  .home-featured__kicker,
  .home-featured__copy {
    margin: 0;
  }

  .home-featured__kicker {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: color-mix(in srgb, var(--tone-text) 80%, var(--tone-muted) 20%);
  }

  .home-featured__copy {
    max-width: 42rem;
    color: color-mix(in srgb, var(--tone-text) 86%, var(--tone-muted) 14%);
  }

  .home-featured__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0.55rem 0.95rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--tone-accent) 24%, var(--line2));
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--tone-accent) 12%, transparent), transparent 68%),
      color-mix(in srgb, var(--tone-surface-strong) 82%, transparent);
    color: color-mix(in srgb, var(--tone-accent-glow) 82%, white 18%);
    text-decoration: none;
    transition:
      transform 140ms ease,
      border-color 140ms ease,
      color 140ms ease;
  }

  .home-featured__link:hover,
  .home-featured__link:focus-visible {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--tone-accent) 54%, var(--line2));
    color: var(--tone-accent-glow);
  }

  .home-featured__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .threadCard {
    min-width: 0;
    height: 100%;
  }

  .home-ai-callout__card {
    display: grid;
    gap: 0.75rem;
    padding: clamp(1rem, 2vw, 1.35rem);
    border: 1px solid color-mix(in srgb, #c57d66 36%, var(--line2));
    background:
      linear-gradient(180deg, color-mix(in srgb, #c57d66 14%, transparent), transparent 68%),
      color-mix(in srgb, var(--tone-surface-strong) 90%, transparent);
  }

  .home-ai-callout__copy {
    max-width: 42rem;
    color: color-mix(in srgb, var(--tone-text) 88%, var(--tone-muted) 12%);
  }

  .home-ai-callout__link {
    width: fit-content;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    padding: 0.5rem 0.9rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, #c57d66 46%, var(--line2));
    background:
      linear-gradient(180deg, color-mix(in srgb, #c57d66 18%, transparent), transparent 70%),
      color-mix(in srgb, var(--tone-surface) 92%, transparent);
    color: color-mix(in srgb, #f3d8cf 82%, white 18%);
    text-decoration: none;
    transition:
      transform 140ms ease,
      border-color 140ms ease,
      color 140ms ease;
  }

  .home-ai-callout__link:hover,
  .home-ai-callout__link:focus-visible {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, #c57d66 76%, var(--line2));
    color: #f6e1da;
  }

  .home-now-signal {
    padding: 0.9rem 1rem;
    border: 1px solid color-mix(in srgb, var(--tone-accent) 18%, var(--line2));
    border-radius: 1rem;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--tone-accent) 8%, transparent), transparent 72%),
      color-mix(in srgb, var(--tone-surface) 90%, transparent);
  }

  .home-now-signal p {
    color: color-mix(in srgb, var(--tone-text) 90%, var(--tone-muted) 10%);
  }

  .home-now-signal__label {
    margin-right: 0.45rem;
  }

  .home-now-signal a {
    color: var(--tone-accent-glow);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--tone-accent) 55%, transparent);
    text-underline-offset: 0.14em;
  }

  @media (max-width: 1024px) {
    .home-featured__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 860px) {
    .home-hero {
      min-height: 20rem;
      border-radius: 1.35rem;
      margin-bottom: 0.8rem;
    }

    .home-hero__content {
      width: min(100%, 38rem);
      padding:
        clamp(3.5rem, 11vw, 4.6rem)
        clamp(1rem, 5vw, 1.4rem)
        clamp(2.25rem, 9vw, 3rem);
    }

    .home-hero__content::before {
      inset:
        1rem
        0.5rem
        0.75rem;
      border-radius: 1.1rem;
    }

    .home-hero__content::after {
      inset:
        1.25rem
        0.8rem
        1rem;
      border-radius: 0.95rem;
    }

    .home-hero__ivy {
      top: 0.3rem;
      width: clamp(72px, 18vw, 104px);
      height: clamp(94px, 24vw, 136px);
      opacity: 0.66;
    }

    .home-hero__ivy--left {
      left: 0.5rem;
    }

    .home-hero__ivy--right {
      right: 0.5rem;
    }

    .home-hero__pulse {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .home-featured__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
