---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/agi-timeline.css';
import type {
  AGIEvidenceType,
  AGITimelineConfidence,
  AGITimelineDomain,
  AGITimelineHorizon,
  AGITimelineItem,
  AGITimelineKind,
  AGITimelineWave
} from '../data/agi-timeline-structure';
import { getLinkCtaLabel, providerFromUrl } from '../lib/embed-resolver';
import { formatFreshnessLabel } from '../lib/freshness';

const waveOrder: Record<AGITimelineWave, number> = {
  software_disruption_now: 0,
  broad_labor_stress: 1,
  physical_economy_disruption: 2,
  scenario_territory: 3
};

const waveMeta: Record<AGITimelineWave, { title: string; years: string; thesis: string; marker: string }> = {
  software_disruption_now: {
    title: 'Software disruption now',
    years: 'Now-2027',
    thesis: 'Utility is already spreading across writing, coding, support, research, and operations.',
    marker: 'I'
  },
  broad_labor_stress: {
    title: 'Broad labor stress',
    years: '2027-2031',
    thesis: 'Transition pressure expands across sectors; painful reallocation can happen without collapse.',
    marker: 'II'
  },
  physical_economy_disruption: {
    title: 'Physical-economy disruption',
    years: '2030-2035',
    thesis: 'Robotics and autonomous logistics become plausible broad disruptors, but rollout is constrained.',
    marker: 'III'
  },
  scenario_territory: {
    title: 'Scenario territory',
    years: 'After 2035',
    thesis: 'Energy, supply chains, regulation, and reliability dominate; treat this as branching scenarios.',
    marker: 'IV'
  }
};

const validKinds: AGITimelineKind[] = ['signal', 'thesis'];
const validDomains: AGITimelineDomain[] = ['software', 'labor', 'robotics', 'energy', 'policy'];
const validConfidence: AGITimelineConfidence[] = ['low', 'medium', 'high'];
const validHorizons: AGITimelineHorizon[] = ['near', 'mid', 'long'];
const validEvidence: AGIEvidenceType[] = ['paper', 'benchmark', 'deployment', 'labor', 'policy', 'interpretation'];

async function safeJsonImport(path: string, fallback: any) {
  try {
    const mod = await import(/* @vite-ignore */ path);
    return mod?.default ?? fallback;
  } catch {
    return fallback;
  }
}

function asEnum<T extends string>(value: unknown, options: T[], fallback: T): T {
  const normalized = String(value || '').toLowerCase() as T;
  return options.includes(normalized) ? normalized : fallback;
}

function inferWave(year: number, domain: AGITimelineDomain): AGITimelineWave {
  if (year >= 2036) return 'scenario_territory';
  if (year >= 2030 && domain !== 'software') return 'physical_economy_disruption';
  if (year >= 2027) return 'broad_labor_stress';
  return 'software_disruption_now';
}

function normalizeItem(raw: any, index: number): AGITimelineItem | null {
  const headline = String(raw?.headline || raw?.title || '').trim();
  if (!headline) return null;

  const sourceName = String(raw?.sourceName || raw?.sourceId || 'Archive source');
  const sourceId = String(raw?.sourceId || 'source');
  const url = String(raw?.url || 'https://github.com/AngelESuero/Portfolio-Website-');
  const summary = String(raw?.summary || '').trim() || `Signal from ${sourceName}.`;

  let year = Number(raw?.year);
  if (!Number.isFinite(year)) {
    const published = raw?.publishedAt ? new Date(raw.publishedAt) : null;
    year = published && !Number.isNaN(published.valueOf()) ? published.getUTCFullYear() : new Date().getUTCFullYear();
  }

  const tags = Array.isArray(raw?.tags) ? raw.tags.map((tag: unknown) => String(tag)) : [];
  const domain = asEnum(raw?.domain ?? tags.find((t: string) => validDomains.includes(t as AGITimelineDomain)), validDomains, 'software');
  const phase = asEnum(raw?.phase, Object.keys(waveMeta) as AGITimelineWave[], inferWave(year, domain));
  const kind = asEnum(raw?.kind, validKinds, raw?.id?.includes('thesis') ? 'thesis' : 'signal');
  const confidence = asEnum(raw?.confidence, validConfidence, kind === 'thesis' ? 'medium' : 'low');
  const timeHorizon = asEnum(raw?.timeHorizon, validHorizons, year >= 2035 ? 'long' : year >= 2028 ? 'mid' : 'near');
  const evidenceType = asEnum(raw?.evidenceType, validEvidence, kind === 'thesis' ? 'interpretation' : 'paper');

  const citations = Array.isArray(raw?.citations)
    ? raw.citations
        .map((citation: any) => ({ label: String(citation?.label || 'Source'), url: String(citation?.url || url) }))
        .filter((citation: { label: string; url: string }) => /^https?:\/\//i.test(citation.url))
    : [{ label: 'Source', url }];

  const analystTrend = String(raw?.analyst?.trend || '').toLowerCase();
  const trend =
    analystTrend === 'improving' || analystTrend === 'stable' || analystTrend === 'concerning' ? analystTrend : 'neutral';

  return {
    id: String(raw?.id || `agi-${index}`),
    phase,
    kind,
    domain,
    confidence,
    timeHorizon,
    evidenceType,
    year,
    headline,
    url,
    sourceId,
    sourceName,
    publishedAt: String(raw?.publishedAt || new Date().toISOString()),
    summary,
    tags,
    citations,
    public: {
      summary: String(raw?.public?.summary || summary),
      implication: String(raw?.public?.implication || `Impacts ${domain} systems in the ${waveMeta[phase].title.toLowerCase()} window.`),
      analogy: raw?.public?.analogy ? String(raw.public.analogy) : undefined
    },
    analyst: {
      metric: String(raw?.analyst?.metric || 'Signal quality'),
      value: raw?.analyst?.value ?? sourceName,
      dataSource: String(raw?.analyst?.dataSource || sourceName),
      trend,
      context: raw?.analyst?.context ? String(raw.analyst.context) : summary
    },
    engineer: {
      technicalDetail: String(raw?.engineer?.technicalDetail || summary),
      architectureNote: raw?.engineer?.architectureNote ? String(raw.engineer.architectureNote) : undefined,
      bottleneck: raw?.engineer?.bottleneck ? String(raw.engineer.bottleneck) : undefined,
      references: Array.isArray(raw?.engineer?.references)
        ? raw.engineer.references
        : citations.map((citation: { label: string; url: string }) => ({ title: citation.label, link: citation.url }))
    }
  };
}

const liveData = await safeJsonImport('../data/agi-timeline.json', { items: [], meta: {} });
const curatedData = await safeJsonImport('../data/agi-curated-timeline.json', { items: [], meta: {} });

const rawItems = [...(Array.isArray(liveData?.items) ? liveData.items : []), ...(Array.isArray(curatedData?.items) ? curatedData.items : [])];

const agiItems = rawItems
  .map((raw, index) => normalizeItem(raw, index))
  .filter((item): item is AGITimelineItem => Boolean(item))
  .sort((a, b) => {
    const waveDelta = waveOrder[a.phase] - waveOrder[b.phase];
    if (waveDelta !== 0) return waveDelta;
    if (a.year !== b.year) return a.year - b.year;
    return a.headline.localeCompare(b.headline);
  });

const itemsByWave: Record<AGITimelineWave, AGITimelineItem[]> = {
  software_disruption_now: agiItems.filter((item) => item.phase === 'software_disruption_now'),
  broad_labor_stress: agiItems.filter((item) => item.phase === 'broad_labor_stress'),
  physical_economy_disruption: agiItems.filter((item) => item.phase === 'physical_economy_disruption'),
  scenario_territory: agiItems.filter((item) => item.phase === 'scenario_territory')
};

const analystItems = [...agiItems].sort((a, b) => b.year - a.year).slice(0, 24);
const domainGroups = validDomains.map((domain) => ({ domain, items: analystItems.filter((item) => item.domain === domain) }));
const bottleneckItems = agiItems.filter((item) => item.engineer.bottleneck).slice(0, 12);
const dependencyRows = [
  ['Reliable software agents', 'Broader labor substitution signals'],
  ['Labor transition institutions', 'Deployment pace in robotics + logistics'],
  ['Energy + supply-chain throughput', 'Physical-economy scale-up'],
  ['Policy + reliability standards', 'Long-horizon scenario branching']
];

const lastUpdatedLabel = formatFreshnessLabel(liveData?.meta?.generatedAt || curatedData?.meta?.generatedAt);
---

<BaseLayout title="AGI Monitor // Sober 4-Wave Timeline" description="AGI monitor with public, analyst, and engineering views." theme="agi">
  <section class="agi-monitor" id="agi-monitor">
    <nav class="agi-nav sticky top-0 z-20 py-3">
      <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 px-4 md:flex-row">
        <h1 class="text-base font-bold uppercase tracking-tight md:text-lg">AGI Monitor — Sober Timeline</h1>
        <div class="level-switcher" role="tablist" aria-label="Timeline view mode">
          <button type="button" id="btn-public" class="level-btn active" data-mode="public" role="tab" aria-selected="true" aria-controls="view-public">Public</button>
          <button type="button" id="btn-analyst" class="level-btn" data-mode="analyst" role="tab" aria-selected="false" aria-controls="view-analyst">Analyst</button>
          <button type="button" id="btn-engineer" class="level-btn" data-mode="engineer" role="tab" aria-selected="false" aria-controls="view-engineer">Engineer</button>
        </div>
      </div>
    </nav>

    <main class="mx-auto max-w-7xl px-4 py-8 md:py-12">
      <div id="view-public" class="agi-view-panel agi-public-timeline" role="tabpanel" aria-labelledby="btn-public">
        <div class="timeline-intro">
          <h2>A sober 4-wave AGI timeline</h2>
          <p class="dek">Software shock now, systemic labor shock next, physical-economy disruption earliest in the early 2030s, then scenario territory.</p>
          <p class="overlap-note">Caveat: these waves overlap and amplify each other. They do not wait politely for sequence boundaries.</p>
        </div>

        {(Object.keys(waveMeta) as AGITimelineWave[]).map((wave) => (
          <article class="act" data-phase={wave}>
            <header class="act-header">
              <div class="act-icon">{waveMeta[wave].marker}</div>
              <div>
                <h3>{waveMeta[wave].title}</h3>
                <p class="act-years">{waveMeta[wave].years}</p>
                <p class="act-theme">{waveMeta[wave].thesis}</p>
              </div>
            </header>

            {itemsByWave[wave].slice(0, 5).map((item) => (
              <article class="beat">
                <div class="beat-marker"><span class="beat-year">{item.year}</span><div class="beat-dot"></div></div>
                <div class="beat-content">
                  <h4>{item.headline}</h4>
                  <p class="beat-summary">{item.public.summary}</p>
                  <div class="beat-implication"><strong>Why it matters:</strong> {item.public.implication}</div>
                  <p class="chip-row"><span class={`chip ${item.kind}`}>{item.kind}</span><span class="chip">{item.domain}</span><span class="chip">{item.timeHorizon}</span></p>
                  <a class="beat-link" href={item.url} target="_blank" rel="noreferrer">{getLinkCtaLabel(item.url, providerFromUrl(item.url))}</a>
                </div>
              </article>
            ))}
          </article>
        ))}
      </div>

      <div id="view-analyst" class="agi-view-panel agi-analyst-view is-hidden" role="tabpanel" aria-labelledby="btn-analyst">
        <header class="analyst-header">
          <h2>Analyst view: signals vs thesis inventory</h2>
          <p class="analyst-meta">{lastUpdatedLabel} · Entries: {agiItems.length}</p>
        </header>
        <div class="metrics-grid">
          {analystItems.map((item) => (
            <article class="metric-card" data-trend={item.analyst.trend}>
              <div class="metric-header"><time>{item.year}</time><span>{item.kind}</span></div>
              <h3>{item.headline}</h3>
              <p class="chip-row"><span class="chip">{item.domain}</span><span class="chip">{item.confidence}</span><span class="chip">{item.evidenceType}</span></p>
              <p class="metric-context">{item.analyst.context}</p>
              <div class="metric-source">{item.analyst.dataSource}</div>
            </article>
          ))}
        </div>
        <section>
          <h3>Grouped by domain</h3>
          {domainGroups.map((group) => (
            group.items.length > 0 && <p><strong>{group.domain}</strong>: {group.items.length} tracked items.</p>
          ))}
        </section>
      </div>

      <div id="view-engineer" class="agi-view-panel agi-engineer-view is-hidden" role="tabpanel" aria-labelledby="btn-engineer">
        <header class="engineer-header">
          <h2>Engineer view: bottlenecks and dependencies</h2>
        </header>
        {bottleneckItems.map((item) => (
          <article class="technical-card">
            <header class="tech-header"><div><time>{item.year}</time><h3>{item.headline}</h3></div><span class="badge bottleneck">{item.phase}</span></header>
            <div class="tech-content">
              <section class="tech-section"><h4>Technical detail</h4><p>{item.engineer.technicalDetail}</p></section>
              <section class="tech-section bottleneck-section"><h4>Critical bottleneck</h4><p>{item.engineer.bottleneck}</p></section>
            </div>
          </article>
        ))}

        <section class="critical-path">
          <h3>Dependency chain (non-deterministic)</h3>
          <div class="dependency-graph">
            {dependencyRows.map((row) => (
              <div class="dependency-node"><div class="node-title">{row[0]}</div><div class="node-impact">Enables: {row[1]}</div></div>
            ))}
          </div>
        </section>
      </div>
    </main>
  </section>

  <script is:inline>
    (() => {
      const MODE_KEY = 'agi-view-mode';
      const root = document.getElementById('agi-monitor');
      if (!root) return;
      const validModes = ['public', 'analyst', 'engineer'];
      const setMode = (nextMode) => {
        const mode = validModes.includes(nextMode) ? nextMode : 'public';
        document.querySelectorAll('.agi-view-panel').forEach((panel) => panel.classList.toggle('is-hidden', panel.id !== `view-${mode}`));
        document.querySelectorAll('.level-btn').forEach((button) => {
          const active = button.getAttribute('data-mode') === mode;
          button.classList.toggle('active', active);
          button.setAttribute('aria-selected', String(active));
        });
        window.localStorage.setItem(MODE_KEY, mode);
      };
      document.querySelectorAll('.level-btn').forEach((button) => button.addEventListener('click', () => setMode(button.getAttribute('data-mode'))));
      const savedMode = window.localStorage.getItem(MODE_KEY) || 'public';
      setMode(savedMode);
    })();
  </script>
</BaseLayout>
