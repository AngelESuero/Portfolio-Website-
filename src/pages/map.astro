---
import BaseLayout from '../layouts/BaseLayout.astro';
import NeuralMap from '../components/NeuralMap.astro';
---

<BaseLayout title="Map — a_e.s_" theme="archive">
  <header class="mb-6">
    <h1 class="font-display text-4xl">Concept Atlas</h1>
    <p class="mt-2 max-w-2xl text-zinc-600 dark:text-zinc-300">
      Zoom through regions, districts, and concept bridges. Drag to travel, use the wheel to dive in, and click any region,
      district, or concept to fly there.
    </p>
  </header>

  <NeuralMap />
</BaseLayout>
