---
import BaseLayout from '../layouts/BaseLayout.astro';
import NeuralMap from '../components/NeuralMap.astro';
import { MAP_REGIONS } from '../data/map-topology';

const atlasClusters = MAP_REGIONS.map((region) => ({
  id: region.id,
  label: region.label,
  summary: region.summary,
  districts: region.districts.map((district) => district.label)
}));
---

<BaseLayout title="Organizational Atlas — a_e.s_" theme="archive">
  <div class="atlas-page" data-stage-mode="overview" data-chrome-state="full">
    <header class="atlas-page__header">
      <p class="atlas-page__eyebrow">Archive navigator</p>
      <h1 class="atlas-page__title">Organizational Atlas</h1>
      <p class="atlas-page__summary">
        A page-scale map of the archive: start at the survival-weighted perimeter, then zoom inward toward denser concept lanes.
      </p>
    </header>

    <section class="atlas-guide viewer-only" aria-label="Map orientation">
      <p class="atlas-guide__kicker">Start here</p>
      <h2 class="atlas-guide__title">Read the map in three moves</h2>
      <div class="atlas-guide__grid">
        <article>
          <h3>1. Scan clusters</h3>
          <p>Use the outer cluster labels to pick a lane before diving into concept density.</p>
        </article>
        <article>
          <h3>2. Zoom and pan</h3>
          <p>Zoom in for concept nodes, then drag the canvas to move between neighborhoods.</p>
        </article>
        <article>
          <h3>3. Inspect links</h3>
          <p>Select a node to read relationship details and cross-cluster bridges.</p>
        </article>
      </div>
      <details class="atlas-guide__clusters">
        <summary>Cluster index</summary>
        <div class="atlas-guide__cluster-list">
          {atlasClusters.map((cluster) => (
            <article>
              <h3>{cluster.label}</h3>
              <p>{cluster.summary}</p>
              <p class="atlas-guide__districts">{cluster.districts.join(' • ')}</p>
            </article>
          ))}
        </div>
      </details>
    </section>

    <NeuralMap />
  </div>
</BaseLayout>

<style>
  .atlas-page {
    margin-inline: calc(50% - 50vw + clamp(10px, 1vw, 22px));
    padding-block: clamp(0.35rem, 1.1vh, 0.9rem) clamp(1rem, 2.4vh, 1.8rem);
  }

  .atlas-page__header {
    max-width: min(72rem, 100%);
    padding-inline: clamp(0.3rem, 0.9vw, 0.9rem);
    margin-bottom: clamp(0.6rem, 1.2vw, 1rem);
    display: grid;
    gap: 0.25rem;
    transition:
      opacity 220ms ease,
      transform 220ms ease,
      margin-bottom 220ms ease;
  }

  .atlas-guide {
    max-width: min(72rem, 100%);
    padding: 0.95rem clamp(0.3rem, 0.9vw, 0.9rem) 1rem;
    margin-bottom: clamp(0.65rem, 1.3vw, 1rem);
    border: 1px solid color-mix(in srgb, var(--tone-accent) 20%, var(--line2));
    border-radius: 1rem;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--tone-accent) 10%, transparent), transparent 62%),
      color-mix(in srgb, var(--tone-surface-strong) 88%, transparent);
    display: grid;
    gap: 0.72rem;
  }

  .atlas-guide__kicker,
  .atlas-guide__title {
    margin: 0;
  }

  .atlas-guide__kicker {
    color: var(--tone-accent-glow);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .atlas-guide__title {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.4vw, 1.7rem);
    line-height: 1.15;
  }

  .atlas-guide__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 0.65rem;
  }

  .atlas-guide__grid article {
    border: 1px solid color-mix(in srgb, var(--tone-accent) 14%, var(--line2));
    border-radius: 0.8rem;
    padding: 0.7rem 0.75rem;
    background: color-mix(in srgb, var(--tone-surface) 88%, transparent);
  }

  .atlas-guide__grid h3,
  .atlas-guide__grid p {
    margin: 0;
  }

  .atlas-guide__grid h3 {
    font-size: 0.9rem;
  }

  .atlas-guide__grid p {
    margin-top: 0.42rem;
    color: var(--tone-muted);
    font-size: 0.84rem;
    line-height: 1.46;
  }

  .atlas-guide__clusters {
    border: 1px solid color-mix(in srgb, var(--tone-accent) 14%, var(--line2));
    border-radius: 0.8rem;
    padding: 0.7rem 0.75rem;
    background: color-mix(in srgb, var(--tone-surface) 84%, transparent);
  }

  .atlas-guide__clusters summary {
    cursor: pointer;
    font-size: 0.86rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--tone-text) 82%, var(--tone-muted) 18%);
  }

  .atlas-guide__cluster-list {
    margin-top: 0.72rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.65rem;
  }

  .atlas-guide__cluster-list article {
    border: 1px solid color-mix(in srgb, var(--tone-accent) 12%, var(--line2));
    border-radius: 0.72rem;
    padding: 0.62rem 0.66rem;
    background: color-mix(in srgb, var(--tone-surface) 90%, transparent);
  }

  .atlas-guide__cluster-list h3,
  .atlas-guide__cluster-list p {
    margin: 0;
  }

  .atlas-guide__cluster-list p {
    margin-top: 0.35rem;
    color: var(--tone-muted);
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .atlas-guide__districts {
    margin-top: 0.4rem;
    font-size: 0.76rem;
    color: color-mix(in srgb, var(--tone-text) 82%, var(--tone-muted) 18%);
  }

  .atlas-page :global([data-neural-atlas]) {
    width: 100%;
  }

  .atlas-page__eyebrow,
  .atlas-page__title,
  .atlas-page__summary {
    margin: 0;
  }

  .atlas-page__eyebrow {
    color: var(--tone-accent-glow);
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .atlas-page__title {
    color: var(--tone-text);
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw, 3rem);
    line-height: 0.96;
    letter-spacing: -0.03em;
  }

  .atlas-page__summary {
    max-width: 46rem;
    color: var(--tone-muted);
    font-size: clamp(0.92rem, 1vw, 1rem);
    line-height: 1.45;
  }

  .atlas-page[data-stage-mode='inspect'] .atlas-page__header {
    margin-bottom: clamp(0.4rem, 0.8vw, 0.7rem);
    opacity: 0.92;
    transform: translateY(-2px);
  }

  .atlas-page[data-stage-mode='immersive'] .atlas-page__header {
    margin-bottom: clamp(0.3rem, 0.6vw, 0.55rem);
    opacity: 0.84;
    transform: translateY(-4px);
  }

  @media (max-width: 1100px) {
    .atlas-page {
      margin-inline: 0;
      padding-block: 0 1rem;
    }

    .atlas-page__header {
      padding-inline: 0;
      margin-bottom: 0.8rem;
      opacity: 1;
      transform: none;
      transition: none;
    }

    .atlas-page__title {
      font-size: clamp(1.8rem, 8vw, 2.4rem);
    }

    .atlas-page__summary {
      max-width: 100%;
    }

    .atlas-guide {
      padding-inline: 0.8rem;
    }
  }
</style>
