---
import BaseLayout from '../layouts/BaseLayout.astro';

const items = [
  {
    id: 'A1',
    label: 'Task-level competence is strong (drafting/snippets/analysis)',
    help: 'Assist signature: AI handles individual tasks well; humans still own outcomes.',
    stage: 1,
    lens: 'Capability',
    defaultScore: 3
  },
  {
    id: 'A2',
    label: 'Humans still stitch outputs + do QA',
    help: 'If this stays high, Agent is gated by trust/verification.',
    stage: 1,
    lens: 'Capability',
    defaultScore: 3
  },
  {
    id: 'B1',
    label: 'AI budgets rising / deployments expanding beyond pilots',
    stage: 1,
    lens: 'Adoption',
    defaultScore: 2
  },
  {
    id: 'B2',
    label: 'Hiring growth slowing / optimization narrative present',
    stage: 1,
    lens: 'Adoption',
    defaultScore: 2
  },
  {
    id: 'C1',
    label: 'Broad productivity gains are measurable but modest',
    stage: 1,
    lens: 'Economics',
    defaultScore: 1
  },
  {
    id: 'D1',
    label: 'Baseline AI policies exist (data handling, disclosure, usage rules)',
    stage: 1,
    lens: 'Governance',
    defaultScore: 2
  },
  {
    id: 'A3',
    label: 'End-to-end automation is still rare (low single-digit %)',
    help: 'Agent starts when multi-step workflows run without babysitting.',
    stage: 2,
    lens: 'Capability',
    defaultScore: 1
  },
  {
    id: 'A4',
    label: 'Agents reliably run >10 steps without intervention',
    help: 'Clean gate: when this hits 2-3 broadly, Agent is here.',
    stage: 2,
    lens: 'Capability',
    defaultScore: 1
  },
  {
    id: 'A5',
    label: 'Failures cluster in planning/execution/verification (multi-step compounding)',
    stage: 2,
    lens: 'Capability',
    defaultScore: 2
  },
  {
    id: 'A6',
    label: 'Main bottlenecks: trust/QA + connectors + data quality (not compute)',
    stage: 2,
    lens: 'Capability',
    defaultScore: 2
  },
  {
    id: 'B3',
    label: 'Roles redesigned more than eliminated (tasks removed != job removed)',
    stage: 2,
    lens: 'Adoption',
    defaultScore: 2
  },
  {
    id: 'B4',
    label: 'Human overseer/QA patterns emerging (auditor, exception handler)',
    stage: 2,
    lens: 'Adoption',
    defaultScore: 1
  },
  {
    id: 'C2',
    label: 'AI gains are strong enough to justify structural workflow redesign',
    stage: 2,
    lens: 'Economics',
    defaultScore: 1
  },
  {
    id: 'C3',
    label: 'Cost curve collapsing (price/performance improving sharply)',
    stage: 2,
    lens: 'Economics',
    defaultScore: 3
  },
  {
    id: 'D2',
    label: 'Audits/incident reporting becoming routine in higher-risk domains',
    stage: 2,
    lens: 'Governance',
    defaultScore: 1
  },
  {
    id: 'A7',
    label: 'Robotics/logistics automation scaling beyond pilots',
    stage: 3,
    lens: 'Capability',
    defaultScore: 1
  },
  {
    id: 'B5',
    label: 'Public services (cities/hospitals/utilities) deploy AI operationally',
    stage: 3,
    lens: 'Adoption',
    defaultScore: 1
  },
  {
    id: 'C4',
    label: 'Physical-world automation materially lowers costs / raises capacity',
    stage: 3,
    lens: 'Economics',
    defaultScore: 1
  },
  {
    id: 'D3',
    label: 'Liability frameworks for AI-caused harm are enforceable + routine',
    stage: 3,
    lens: 'Governance',
    defaultScore: 1
  },
  {
    id: 'D4',
    label: 'Governance standardizes (transparency/audits/liability) across sectors',
    stage: 4,
    lens: 'Governance',
    defaultScore: 1
  },
  {
    id: 'D5',
    label: 'AI becomes election-level policy priority (broad legitimacy battles)',
    stage: 4,
    lens: 'Governance',
    defaultScore: 2
  },
  {
    id: 'E1',
    label: 'Profit concentration becomes dominant social signal',
    stage: 5,
    lens: 'Equity',
    defaultScore: 2
  },
  {
    id: 'E2',
    label: 'Wage-based demand weakens while productivity rises',
    stage: 5,
    lens: 'Equity',
    defaultScore: 2
  },
  {
    id: 'E3',
    label: 'Credible ownership/dividend rail exists at scale',
    help: 'Public wealth funds, statutory profit-sharing, data/compute dividends, UBI-like floors.',
    stage: 5,
    lens: 'Equity',
    defaultScore: 1
  }
] as const;
---

<BaseLayout
  title="AI Transition Dashboard - A Path Toward Life"
  description="Score AI transition stage signals, track evidence, and snapshot changes over time."
  theme="agi"
>
  <section class="page-shell">
    <div class="mode-normal aw-shell">
      <div id="ai-waves-app" class="aw-root"></div>
    </div>
  </section>

  <script type="application/json" id="ai-transition-items" set:html={JSON.stringify(items)}></script>
  <script is:inline define:vars={{ items }}>
    window.__AI_TRANSITION_ITEMS__ = items;
  </script>
  <script is:inline>
    (() => {
      const STORAGE_KEY = 'ai_transition_dashboard_v1';
      const root = document.getElementById('ai-waves-app');
      const itemsNode = document.getElementById('ai-transition-items');
      if (!root || !itemsNode) return;

      const isEmbed = new URLSearchParams(window.location.search).get('embed') === '1';
      if (isEmbed) {
        document.documentElement.classList.add('aw-embed');
        document.body.classList.add('aw-embed');
      }

      let items = [];
      try {
        items = JSON.parse(itemsNode.textContent || '[]');
      } catch {
        items = [];
      }

      const fallbackItems = Array.isArray(window.__AI_TRANSITION_ITEMS__)
        ? window.__AI_TRANSITION_ITEMS__
        : [];
      if ((!Array.isArray(items) || items.length === 0) && fallbackItems.length > 0) {
        items = fallbackItems;
      }

      if (!Array.isArray(items) || items.length === 0) {
        root.innerHTML = '<p class="aw-empty">Unable to load dashboard items.</p>';
        return;
      }

      const stageMeta = {
        1: { title: 'Assist', subtitle: 'Tasks inside jobs' },
        2: { title: 'Agent', subtitle: 'End-to-end workflows' },
        3: { title: 'Robots', subtitle: 'Physical-world operations' },
        4: { title: 'Rules', subtitle: 'Institutional and legal shift' },
        5: { title: 'Dividends', subtitle: 'Dividend and ownership rails' }
      };

      const stageOrder = [1, 2, 3, 4, 5];

      const clampScore = (value) => {
        const numeric = Number(value);
        if (!Number.isFinite(numeric)) return 0;
        return Math.max(0, Math.min(3, Math.round(numeric)));
      };

      const uid = () =>
        Math.random().toString(16).slice(2) + Date.now().toString(16);

      const escapeHtml = (value) =>
        String(value ?? '')
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#39;');

      const scoreToWord = (score) => {
        if (score === 0) return 'Not present';
        if (score === 1) return 'Early';
        if (score === 2) return 'Leading orgs';
        return 'Widespread';
      };

      const stageName = (stage) => {
        const entry = stageMeta[stage];
        return entry ? entry.title : 'Unknown';
      };

      const buildBlankBaseline = () => {
        const scores = {};
        const evidence = {};
        items.forEach((item) => {
          scores[item.id] = clampScore(item.defaultScore);
          evidence[item.id] = '';
        });
        return {
          scores,
          evidence,
          snapshots: [],
          ui: {
            compact: false,
            showHelp: true
          }
        };
      };

      const buildSeededBaseline = () => {
        const base = buildBlankBaseline();
        const seededEvidence = { ...base.evidence };

        seededEvidence.A1 =
          'US workplace adoption: Pew (Sept 2025) says 21% of US workers use AI for at least some of their work https://www.pewresearch.org/short-reads/2025/10/06/about-1-in-5-us-workers-now-use-ai-in-their-job-up-since-last-year/ | Gallup (Nov 2025) reports ~10-12% daily AI use and ~26% frequent use https://www.gallup.com/699797/indicator-artificial-intelligence.aspx | Cost curve context: Stanford AI Index shows large inference price drops (GPT-3.5-level) https://hai.stanford.edu/news/ai-index-2025-state-of-ai-in-10-charts';
        seededEvidence.A3 =
          'OpenAI CUA benchmarks: OSWorld 38.1%, WebArena 58.1%, WebVoyager 87% https://openai.com/index/computer-using-agent/';
        seededEvidence.A4 =
          'Operator/CUA reliability limits + oversight notes (system card) https://openai.com/index/operator-system-card/';
        seededEvidence.C3 =
          'Stanford AI Index 2025: inference prices fell 9x-900x per year depending on task https://hai.stanford.edu/ai-index/2025-ai-index-report/research-and-development';
        seededEvidence.A7 =
          'Robots in US ops: Amazon reached its 1 millionth robot and says DeepFleet improved robot travel time by 10% https://www.aboutamazon.com/news/operations/amazon-million-robots-ai-foundation-model | Humanoid manufacturing capacity: Agility RoboFab (Oregon) lists peak capacity 10,000 robots/year https://www.agilityrobotics.com/robofab';
        seededEvidence.D4 =
          'US regulatory patchwork / federal preemption proposals: Politico (draft EO) https://www.politico.com/news/2025/11/19/white-house-prepares-executive-order-to-block-state-ai-laws-00660719 | Reuters (EO paused) https://www.reuters.com/world/white-house-pauses-executive-order-that-would-seek-preempt-state-laws-on-ai-sources-2025-11-21/';
        seededEvidence.E3 =
          'No dividend rail at national scale yet; UBI evidence base (US): OpenResearch ORUS findings (employment not reduced) https://www.openresearchlab.org/findings/key-findings-employment-and-income';

        seededEvidence.B2 =
          'US labor market baseline: BLS Employment Situation (jobs, unemployment) https://www.bls.gov/news.release/empsit.htm | BLS CES hours (Avg weekly hours, total private) https://www.bls.gov/ces/ | BLS real earnings context via Productivity & Costs releases https://www.bls.gov/news.release/prod2.htm';
        seededEvidence.C1 =
          'US productivity signal: BLS Productivity & Costs news releases (nonfarm business productivity + unit labor costs) https://www.bls.gov/news.release/prod2.htm';
        seededEvidence.E1 =
          'US profits vs labor (proxy): BEA National Income and Product Accounts (corporate profits; compensation) https://www.bea.gov/data/income-saving/national-income-and-product-accounts';
        seededEvidence.E2 =
          'US household stress (proxy): NY Fed Household Debt and Credit (balances + delinquencies) https://www.newyorkfed.org/microeconomics/hhdc | BLS real hourly compensation appears in Productivity & Costs releases https://www.bls.gov/news.release/prod2.htm';

        return {
          ...base,
          evidence: seededEvidence,
          snapshots: [
            {
              id: `seed-${uid()}`,
              title: 'Data-checked baseline (Feb 2026)',
              dateISO: new Date().toISOString(),
              notes:
                'Baseline scores anchored to primary/credible sources. Key confirms: Assist adoption ~16.3% (1 in 6) per Microsoft; Agent benchmarks per OpenAI CUA; Robots scaling anchored to Amazon 1M robots + Agility RoboFab capacity. Items flagged for future verification: any court injunction timelines; any claims of large-scale humanoid deployments doing useful work outside controlled settings.',
              evidence: { ...seededEvidence },
              scores: { ...base.scores }
            }
          ]
        };
      };

      const normalizeSnapshot = (raw, fallback) => {
        const snapScores = { ...fallback.scores };
        const snapEvidence = { ...fallback.evidence };

        if (raw?.scores && typeof raw.scores === 'object') {
          items.forEach((item) => {
            if (Object.hasOwn(raw.scores, item.id)) {
              snapScores[item.id] = clampScore(raw.scores[item.id]);
            }
          });
        }

        if (raw?.evidence && typeof raw.evidence === 'object') {
          items.forEach((item) => {
            if (Object.hasOwn(raw.evidence, item.id)) {
              snapEvidence[item.id] = String(raw.evidence[item.id] ?? '');
            }
          });
        }

        let dateISO = '';
        if (typeof raw?.dateISO === 'string') {
          const parsed = new Date(raw.dateISO);
          dateISO = Number.isNaN(parsed.valueOf())
            ? new Date().toISOString()
            : parsed.toISOString();
        } else {
          dateISO = new Date().toISOString();
        }

        return {
          id:
            typeof raw?.id === 'string' && raw.id.trim().length > 0
              ? raw.id
              : uid(),
          title:
            typeof raw?.title === 'string' && raw.title.trim().length > 0
              ? raw.title.trim()
              : 'Update',
          dateISO,
          notes: typeof raw?.notes === 'string' ? raw.notes : '',
          scores: snapScores,
          evidence: snapEvidence
        };
      };

      const normalizeState = (raw, fallback) => {
        const normalized = {
          scores: { ...fallback.scores },
          evidence: { ...fallback.evidence },
          snapshots: [...fallback.snapshots],
          ui: {
            compact: false,
            showHelp: true
          }
        };

        if (!raw || typeof raw !== 'object') return normalized;

        if (raw.scores && typeof raw.scores === 'object') {
          items.forEach((item) => {
            if (Object.hasOwn(raw.scores, item.id)) {
              normalized.scores[item.id] = clampScore(raw.scores[item.id]);
            }
          });
        }

        if (raw.evidence && typeof raw.evidence === 'object') {
          items.forEach((item) => {
            if (Object.hasOwn(raw.evidence, item.id)) {
              normalized.evidence[item.id] = String(raw.evidence[item.id] ?? '');
            }
          });
        }

        if (Array.isArray(raw.snapshots)) {
          normalized.snapshots = raw.snapshots.map((entry) =>
            normalizeSnapshot(entry, fallback)
          );
        }

        if (raw.ui && typeof raw.ui === 'object') {
          normalized.ui.compact = Boolean(raw.ui.compact);
          normalized.ui.showHelp =
            typeof raw.ui.showHelp === 'boolean' ? raw.ui.showHelp : true;
        }

        return normalized;
      };

      const loadState = () => {
        const fallback = buildSeededBaseline();
        try {
          const raw = localStorage.getItem(STORAGE_KEY);
          if (!raw) return fallback;
          const parsed = JSON.parse(raw);
          return normalizeState(parsed, fallback);
        } catch {
          return fallback;
        }
      };

      const saveState = (value) => {
        try {
          localStorage.setItem(STORAGE_KEY, JSON.stringify(value));
        } catch {}
      };

      let state = loadState();
      let activeStage = 1;
      let query = '';
      let activeTab = 'score';
      let snapDialogOpen = false;
      let snapTitle = 'Monthly update';
      let snapNotes = '';
      let importDialogOpen = false;
      let importText = '';

      const getFilteredItems = () => {
        const q = query.trim().toLowerCase();
        return items
          .filter((item) => item.stage === activeStage)
          .filter((item) => {
            if (!q) return true;
            return (
              item.label.toLowerCase().includes(q) ||
              item.lens.toLowerCase().includes(q) ||
              item.id.toLowerCase().includes(q)
            );
          });
      };

      const getStageStats = () => {
        const byStage = {
          1: { sum: 0, max: 0, count: 0 },
          2: { sum: 0, max: 0, count: 0 },
          3: { sum: 0, max: 0, count: 0 },
          4: { sum: 0, max: 0, count: 0 },
          5: { sum: 0, max: 0, count: 0 }
        };

        items.forEach((item) => {
          const score = clampScore(
            Object.hasOwn(state.scores, item.id)
              ? state.scores[item.id]
              : item.defaultScore
          );
          byStage[item.stage].sum += score;
          byStage[item.stage].max += 3;
          byStage[item.stage].count += 1;
        });

        const strength = (stage) => {
          const bucket = byStage[stage];
          if (!bucket || bucket.max === 0) return 0;
          return bucket.sum / bucket.max;
        };

        const overallMax = stageOrder.reduce(
          (total, stage) => total + byStage[stage].max,
          0
        );
        const overallSum = stageOrder.reduce(
          (total, stage) => total + byStage[stage].sum,
          0
        );
        const overall = overallMax ? overallSum / overallMax : 0;

        let topStage = 1;
        stageOrder.forEach((stage) => {
          if (strength(stage) > strength(topStage)) {
            topStage = stage;
          }
        });

        return {
          byStage,
          strength,
          overall,
          topStage
        };
      };

      const getHeadline = (stats) => {
        const s1 = stats.strength(1);
        const s2 = stats.strength(2);

        const primary = stageName(stats.topStage);
        const secondary = stageOrder
          .filter((entry) => entry !== stats.topStage)
          .map((entry) => ({ stage: entry, value: stats.strength(entry) }))
          .sort((a, b) => b.value - a.value)[0];

        const secondaryLabel = secondary ? stageName(secondary.stage) : '';

        const nuance =
          s2 >= 0.45 && s1 >= 0.6
            ? 'Assist is mature; Agent is emerging'
            : s1 >= 0.6 && s2 < 0.45
              ? 'Assist dominates; Agent is loading'
              : stats.topStage === 2
                ? 'Agent is operationalizing'
                : 'Mixed signals across stages';

        return { primary, secondary: secondaryLabel, nuance };
      };

      const getLensPills = () => {
        const filtered = items.filter((item) => item.stage === activeStage);
        const lensMap = new Map();
        filtered.forEach((item) => {
          const score = clampScore(
            Object.hasOwn(state.scores, item.id)
              ? state.scores[item.id]
              : item.defaultScore
          );
          const current = lensMap.get(item.lens) || { sum: 0, max: 0 };
          current.sum += score;
          current.max += 3;
          lensMap.set(item.lens, current);
        });
        return Array.from(lensMap.entries())
          .map(([lens, value]) => {
            const pct = value.max ? Math.round((value.sum / value.max) * 100) : 0;
            return { lens, pct };
          })
          .sort((a, b) => b.pct - a.pct);
      };

      const exportJson = () => {
        const payload = JSON.stringify(state, null, 2);
        const blob = new Blob([payload], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const anchor = document.createElement('a');
        anchor.href = url;
        anchor.download = `ai-transition-dashboard_${new Date().toISOString().slice(0, 10)}.json`;
        anchor.click();
        URL.revokeObjectURL(url);
      };

      const importJson = () => {
        try {
          const parsed = JSON.parse(importText);
          if (!parsed || typeof parsed !== 'object') {
            throw new Error('Invalid JSON');
          }
          if (!parsed.scores || !parsed.evidence || !parsed.snapshots || !parsed.ui) {
            throw new Error('Missing keys');
          }
          const fallback = buildSeededBaseline();
          state = normalizeState(parsed, fallback);
          saveState(state);
          importDialogOpen = false;
          importText = '';
          render();
        } catch {
          window.alert('Import failed: paste a valid dashboard JSON export.');
        }
      };

      const resetToDefaults = () => {
        const fallback = buildBlankBaseline();
        state = {
          ...state,
          scores: fallback.scores,
          evidence: fallback.evidence
        };
        saveState(state);
        render();
      };

      const makeSnapshot = () => {
        const snapshot = {
          id: uid(),
          title: snapTitle.trim() || 'Update',
          dateISO: new Date().toISOString(),
          notes: snapNotes,
          evidence: { ...state.evidence },
          scores: { ...state.scores }
        };
        state = {
          ...state,
          snapshots: [snapshot, ...state.snapshots]
        };
        saveState(state);
        snapDialogOpen = false;
        snapNotes = '';
        render();
      };

      const deleteSnapshot = (id) => {
        state = {
          ...state,
          snapshots: state.snapshots.filter((snapshot) => snapshot.id !== id)
        };
        saveState(state);
        render();
      };

      const applySnapshot = (id) => {
        const match = state.snapshots.find((snapshot) => snapshot.id === id);
        if (!match) return;
        state = {
          ...state,
          scores: { ...match.scores },
          evidence: { ...match.evidence }
        };
        saveState(state);
        render();
      };

      const updateUi = (patch) => {
        state = {
          ...state,
          ui: {
            ...state.ui,
            ...patch
          }
        };
        saveState(state);
        render();
      };

      const updateScore = (itemId, score) => {
        state = {
          ...state,
          scores: {
            ...state.scores,
            [itemId]: clampScore(score)
          }
        };
        saveState(state);
        render();
      };

      const updateEvidence = (itemId, value) => {
        state = {
          ...state,
          evidence: {
            ...state.evidence,
            [itemId]: String(value ?? '')
          }
        };
        saveState(state);
      };

      const formatMultiline = (value) =>
        escapeHtml(value || '').replaceAll('\n', '<br>');

      const renderStageCard = (stage, stats) => {
        const pct = Math.round(stats.strength(stage) * 100);
        const isActive = stage === activeStage;
        const isTop = stage === stats.topStage;
        return `
          <button
            type="button"
            class="aw-wave-card ${isActive ? 'is-active' : ''}"
            data-action="set-stage"
            data-stage="${stage}"
          >
            <div class="aw-wave-head">
              <div>
                <div class="aw-wave-title-row">
                  <span class="aw-wave-title">${stageMeta[stage].title}</span>
                  ${isTop ? '<span class="aw-tag aw-tag-primary">Primary</span>' : ''}
                </div>
                <p class="aw-wave-subtitle">${escapeHtml(stageMeta[stage].subtitle)}</p>
              </div>
              <span class="aw-wave-pct">${pct}%</span>
            </div>
            <div class="aw-progress-track aw-progress-track-compact">
              <span class="aw-progress-fill" style="width:${pct}%"></span>
            </div>
          </button>
        `;
      };

      const renderScoreItems = () => {
        const filteredItems = getFilteredItems();
        if (filteredItems.length === 0) {
          return '<p class="aw-empty">No matches for this search.</p>';
        }

        return filteredItems
          .map((item) => {
            const score = clampScore(
              Object.hasOwn(state.scores, item.id)
                ? state.scores[item.id]
                : item.defaultScore
            );
            const evidence = state.evidence[item.id] || '';
            return `
              <article class="aw-item ${state.ui.compact ? 'is-compact' : ''}">
                <div class="aw-item-head">
                  <div class="aw-item-copy">
                    <div class="aw-item-topline">
                      <span class="aw-pill aw-id">${item.id}</span>
                      <p class="aw-item-label">${escapeHtml(item.label)}</p>
                    </div>
                    <div class="aw-item-meta">
                      <span class="aw-pill">${escapeHtml(item.lens)}</span>
                      <span class="aw-pill">Score: ${score} / ${escapeHtml(scoreToWord(score))}</span>
                      ${state.ui.showHelp && item.help ? `<span class="aw-help" title="${escapeHtml(item.help)}">Help</span>` : ''}
                    </div>
                  </div>
                  <div class="aw-slider-wrap">
                    <div class="aw-slider-legend">
                      <span>0</span>
                      <span>3</span>
                    </div>
                    <input
                      type="range"
                      min="0"
                      max="3"
                      step="1"
                      value="${score}"
                      data-action="set-score"
                      data-item-id="${item.id}"
                    />
                  </div>
                </div>
                ${
                  state.ui.compact
                    ? ''
                    : `
                  <div class="aw-evidence-row">
                    <label class="aw-label">Evidence (1 link or one sentence)</label>
                    <input
                      type="text"
                      value="${escapeHtml(evidence)}"
                      placeholder="Paste a link, headline, or short note..."
                      data-action="set-evidence"
                      data-item-id="${item.id}"
                    />
                  </div>
                `
                }
              </article>
            `;
          })
          .join('');
      };

      const renderSnapshots = () => {
        if (state.snapshots.length === 0) {
          return '<p class="aw-empty">No snapshots yet. Create one after a monthly update.</p>';
        }

        return state.snapshots
          .map((snapshot) => {
            const dateLabel = new Date(snapshot.dateISO).toLocaleString();
            return `
              <article class="aw-snapshot">
                <div>
                  <h4 class="aw-snapshot-title">${escapeHtml(snapshot.title)}</h4>
                  <p class="aw-muted">${escapeHtml(dateLabel)}</p>
                  ${
                    snapshot.notes
                      ? `<p class="aw-snapshot-notes">${formatMultiline(snapshot.notes)}</p>`
                      : ''
                  }
                </div>
                <div class="aw-actions-inline">
                  <button type="button" class="aw-btn aw-btn-outline" data-action="apply-snapshot" data-snapshot-id="${snapshot.id}">
                    Apply
                  </button>
                  <button type="button" class="aw-btn aw-btn-outline" data-action="delete-snapshot" data-snapshot-id="${snapshot.id}">
                    Delete
                  </button>
                </div>
              </article>
            `;
          })
          .join('');
      };

      const renderModal = () => {
        if (!snapDialogOpen && !importDialogOpen) return '';

        if (snapDialogOpen) {
          return `
            <div class="aw-modal-layer" role="dialog" aria-modal="true" aria-labelledby="aw-snapshot-title">
              <button type="button" class="aw-modal-backdrop" data-action="close-snapshot" aria-label="Close snapshot dialog"></button>
              <div class="aw-modal card">
                <header>
                  <h3 id="aw-snapshot-title">Create snapshot</h3>
                  <p>Captures all scores and evidence with a timestamp.</p>
                </header>
                <div class="aw-modal-body">
                  <label class="aw-label" for="aw-snapshot-input">Title</label>
                  <input
                    id="aw-snapshot-input"
                    type="text"
                    value="${escapeHtml(snapTitle)}"
                    placeholder="e.g., March 2026 update"
                    data-action="snapshot-title-input"
                  />
                  <label class="aw-label" for="aw-snapshot-notes">Notes (optional)</label>
                  <textarea
                    id="aw-snapshot-notes"
                    rows="6"
                    placeholder="3 key signals, any surprises, what changed..."
                    data-action="snapshot-notes-input"
                  >${escapeHtml(snapNotes)}</textarea>
                </div>
                <footer>
                  <button type="button" class="aw-btn aw-btn-outline" data-action="close-snapshot">Cancel</button>
                  <button type="button" class="aw-btn aw-btn-solid" data-action="save-snapshot">Save snapshot</button>
                </footer>
              </div>
            </div>
          `;
        }

        return `
          <div class="aw-modal-layer" role="dialog" aria-modal="true" aria-labelledby="aw-import-title">
            <button type="button" class="aw-modal-backdrop" data-action="close-import" aria-label="Close import dialog"></button>
            <div class="aw-modal card">
              <header>
                <h3 id="aw-import-title">Import dashboard JSON</h3>
                <p>Paste a prior export. This will overwrite your current state.</p>
              </header>
              <div class="aw-modal-body">
                <textarea
                  rows="12"
                  placeholder="Paste JSON here..."
                  data-action="import-text-input"
                >${escapeHtml(importText)}</textarea>
              </div>
              <footer>
                <button type="button" class="aw-btn aw-btn-outline" data-action="close-import">Cancel</button>
                <button type="button" class="aw-btn aw-btn-solid" data-action="import-json">Import</button>
              </footer>
            </div>
          </div>
        `;
      };

      const render = () => {
        const stats = getStageStats();
        const headline = getHeadline(stats);
        const activeStageStrength = Math.round(stats.strength(activeStage) * 100);
        const overallStrength = Math.round(stats.overall * 100);
        const lensPills = getLensPills();
        const tabLabel = stageName(activeStage);

        root.innerHTML = `
          <section class="aw-hero card">
            <div class="aw-hero-copy">
              <p class="aw-kicker">Drafted with AI support for clarity; reviewed and maintained by Angel.</p>
              <h1>AI Transition - Interactive Dashboard</h1>
              <p class="aw-hero-text">
                Score stage signals (0-3), attach evidence, and snapshot updates over time.
              </p>
              <div class="aw-badges">
                <span class="aw-badge">AI-assisted editorial workflow</span>
                <span class="aw-badge aw-badge-secondary">${escapeHtml(headline.nuance)}</span>
              </div>
            </div>
            <div class="aw-top-actions">
              <button type="button" class="aw-btn aw-btn-soft" data-action="open-snapshot">Snapshot</button>
              <button type="button" class="aw-btn aw-btn-outline" data-action="export-json">Export</button>
              <button type="button" class="aw-btn aw-btn-outline" data-action="open-import">Import</button>
              <button type="button" class="aw-btn aw-btn-outline" data-action="reset-defaults">Reset</button>
            </div>
          </section>

          <section class="aw-grid">
            <article class="aw-panel card">
              <div class="aw-panel-head">
                <h2>Where are we now?</h2>
                <span class="aw-badge">Overall: ${overallStrength}%</span>
              </div>
              <p class="aw-muted">
                Primary: <strong>${escapeHtml(headline.primary)}</strong>
                ${headline.secondary ? ` | Secondary: <strong>${escapeHtml(headline.secondary)}</strong>` : ''}
              </p>
              <div class="aw-meter">
                <div class="aw-meter-label">
                  <span>Strength</span>
                  <span>${overallStrength}%</span>
                </div>
                <div class="aw-progress-track">
                  <span class="aw-progress-fill" style="width:${overallStrength}%"></span>
                </div>
              </div>
              <div class="aw-wave-grid">
                ${stageOrder.map((stage) => renderStageCard(stage, stats)).join('')}
              </div>
              <div class="aw-lens card">
                <h3>Active stage lens mix</h3>
                <div class="aw-lens-row">
                  ${lensPills
                    .map(
                      (entry) =>
                        `<span class="aw-pill">${escapeHtml(entry.lens)}: ${entry.pct}%</span>`
                    )
                    .join('')}
                </div>
              </div>
            </article>

            <aside class="aw-controls card">
              <h2>Controls</h2>
              <p class="aw-muted">Make it readable and fast.</p>
              <div class="aw-switch">
                <span>Compact view</span>
                <input type="checkbox" ${state.ui.compact ? 'checked' : ''} data-action="toggle-compact" />
              </div>
              <div class="aw-switch">
                <span>Show help</span>
                <input type="checkbox" ${state.ui.showHelp ? 'checked' : ''} data-action="toggle-help" />
              </div>
              <div class="aw-field">
                <label class="aw-label" for="aw-search">Search items</label>
                <input
                  id="aw-search"
                  type="text"
                  value="${escapeHtml(query)}"
                  placeholder="Type: QA, connectors, wages, robotics..."
                  data-action="set-query"
                />
              </div>
              <p class="aw-muted">Snapshots stored locally: <strong>${state.snapshots.length}</strong></p>
            </aside>
          </section>

          <section class="aw-tabs card">
            <div class="aw-tab-list" role="tablist" aria-label="AI Transition tabs">
              <button type="button" role="tab" aria-selected="${activeTab === 'score'}" class="aw-tab ${activeTab === 'score' ? 'is-active' : ''}" data-action="set-tab" data-tab="score">Checklist</button>
              <button type="button" role="tab" aria-selected="${activeTab === 'snapshots'}" class="aw-tab ${activeTab === 'snapshots' ? 'is-active' : ''}" data-action="set-tab" data-tab="snapshots">Update Log</button>
              <button type="button" role="tab" aria-selected="${activeTab === 'how'}" class="aw-tab ${activeTab === 'how' ? 'is-active' : ''}" data-action="set-tab" data-tab="how">How to Use</button>
            </div>

            ${
              activeTab === 'score'
                ? `
              <div class="aw-tab-panel">
                <div class="aw-panel-head">
                  <h3>${escapeHtml(tabLabel)}</h3>
                  <span class="aw-badge aw-badge-secondary">Strength: ${activeStageStrength}%</span>
                </div>
                <p class="aw-muted">Score each signal and attach a small evidence note or link.</p>
                <div class="aw-item-list">
                  ${renderScoreItems()}
                </div>
              </div>
            `
                : ''
            }

            ${
              activeTab === 'snapshots'
                ? `
              <div class="aw-tab-panel">
                <div class="aw-panel-head">
                  <h3>Update Log</h3>
                  <button type="button" class="aw-btn aw-btn-soft" data-action="open-snapshot">New snapshot</button>
                </div>
                <p class="aw-muted">Snapshots capture a dated state of all scores and evidence.</p>
                <div class="aw-snapshot-list">
                  ${renderSnapshots()}
                </div>
              </div>
            `
                : ''
            }

            ${
              activeTab === 'how'
                ? `
              <div class="aw-tab-panel">
                <div class="aw-how-grid">
                  <article class="aw-how-block">
                    <h3>Monthly (10 min)</h3>
                    <ol>
                      <li>Adjust scores that changed.</li>
                      <li>Add one evidence note for any changed item.</li>
                      <li>Create a snapshot titled with the month.</li>
                    </ol>
                  </article>
                  <article class="aw-how-block">
                    <h3>Quarterly (30-45 min)</h3>
                    <ul>
                      <li>Update the item list (add/remove signals).</li>
                      <li>Revisit stage boundaries (esp. dividend rails).</li>
                      <li>Export JSON as a backup.</li>
                    </ul>
                  </article>
                </div>
                <div class="aw-how-block">
                  <h3>What does 100% mean?</h3>
                  <p class="aw-muted">Strength % is computed as: <strong>(sum of scores) / (3 x number of items)</strong>.</p>
                  <p class="aw-muted"><strong>100%</strong> means every item is scored 3 (Widespread/default).</p>
                  <p class="aw-muted">Overall % uses all items; each card % uses only items in that section.</p>
                  <p class="aw-muted">Everything saves locally in your browser. Export if you want portability.</p>
                </div>
              </div>
            `
                : ''
            }
          </section>

          <p class="aw-foot-note">
            Tip: If you want this dashboard restyled to match a specific visual direction, I can tune it.
          </p>

          ${renderModal()}
        `;
      };

      root.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target.closest('[data-action]') : null;
        if (!target) return;
        const action = target.getAttribute('data-action');
        if (!action) return;

        if (action === 'set-stage') {
          activeStage = Number(target.getAttribute('data-stage')) || 1;
          render();
          return;
        }

        if (action === 'set-tab') {
          const tab = target.getAttribute('data-tab');
          if (tab === 'score' || tab === 'snapshots' || tab === 'how') {
            activeTab = tab;
            render();
          }
          return;
        }

        if (action === 'open-snapshot') {
          snapDialogOpen = true;
          render();
          return;
        }

        if (action === 'close-snapshot') {
          snapDialogOpen = false;
          render();
          return;
        }

        if (action === 'save-snapshot') {
          makeSnapshot();
          return;
        }

        if (action === 'open-import') {
          importDialogOpen = true;
          render();
          return;
        }

        if (action === 'close-import') {
          importDialogOpen = false;
          render();
          return;
        }

        if (action === 'import-json') {
          importJson();
          return;
        }

        if (action === 'export-json') {
          exportJson();
          return;
        }

        if (action === 'reset-defaults') {
          resetToDefaults();
          return;
        }

        if (action === 'apply-snapshot') {
          const snapshotId = target.getAttribute('data-snapshot-id');
          if (snapshotId) applySnapshot(snapshotId);
          return;
        }

        if (action === 'delete-snapshot') {
          const snapshotId = target.getAttribute('data-snapshot-id');
          if (snapshotId) deleteSnapshot(snapshotId);
        }
      });

      root.addEventListener('input', (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        const action = target.getAttribute('data-action');
        if (!action) return;

        if (action === 'set-query' && target instanceof HTMLInputElement) {
          query = target.value;
          render();
          return;
        }

        if (action === 'toggle-compact' && target instanceof HTMLInputElement) {
          updateUi({ compact: target.checked });
          return;
        }

        if (action === 'toggle-help' && target instanceof HTMLInputElement) {
          updateUi({ showHelp: target.checked });
          return;
        }

        if (action === 'set-score' && target instanceof HTMLInputElement) {
          const itemId = target.getAttribute('data-item-id');
          if (!itemId) return;
          updateScore(itemId, Number(target.value));
          return;
        }

        if (action === 'set-evidence' && target instanceof HTMLInputElement) {
          const itemId = target.getAttribute('data-item-id');
          if (!itemId) return;
          updateEvidence(itemId, target.value);
          return;
        }

        if (action === 'snapshot-title-input' && target instanceof HTMLInputElement) {
          snapTitle = target.value;
          return;
        }

        if (action === 'snapshot-notes-input' && target instanceof HTMLTextAreaElement) {
          snapNotes = target.value;
          return;
        }

        if (action === 'import-text-input' && target instanceof HTMLTextAreaElement) {
          importText = target.value;
        }
      });

      render();
    })();
  </script>
</BaseLayout>

