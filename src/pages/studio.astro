---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { sortEntriesByDate } from '../lib/archive-entries';

const mediumOptions = [
  { value: 'writing', label: 'Writing' },
  { value: 'music', label: 'Music' },
  { value: 'video', label: 'Video' },
  { value: 'image', label: 'Image' },
  { value: 'note', label: 'Note' },
  { value: 'proposal', label: 'Proposal' }
];

const sourceOptions = [
  { value: 'manual', label: 'Manual' },
  { value: 'private-notes', label: 'Private notes' },
  { value: 'substack', label: 'Substack' },
  { value: 'youtube', label: 'YouTube' },
  { value: 'untitled', label: 'Untitled' },
  { value: 'linktree', label: 'Linktree' },
  { value: 'local-media', label: 'Local media' }
];

const statusOptions = [
  { value: 'in-progress', label: 'In progress' },
  { value: 'published', label: 'Published' },
  { value: 'featured', label: 'Featured' },
  { value: 'raw', label: 'Raw' },
  { value: 'withheld', label: 'Withheld' }
];

const relatedEntryOptions = sortEntriesByDate(await getCollection('entries')).map((entry) => ({
  slug: entry.slug,
  title: entry.data.title
}));
---

<BaseLayout title="Studio — a_e.s_" theme="archive" renderHeader={false} renderFooter={false}>
  <section class="studio-shell">
    <div class="studio-panel">
      <header class="studio-header">
        <p class="studio-kicker">Private authoring surface</p>
        <h1 class="font-display text-4xl md:text-5xl">Studio</h1>
        <p class="studio-copy">
          Phase 1 is tuned for text + URL intake: writing, notes, proposals, and link-first archive entries from
          YouTube, Substack, and untitled.stream.
        </p>
        <p class="studio-note">
          This form commits a new MDX file to the repo through the GitHub API. Cloudflare Pages will publish it after
          the rebuild finishes.
        </p>
      </header>

      <div class="studio-grid">
        <form class="studio-form" id="studio-form" method="post" action="/api/create-entry" data-studio-form>
          <div class="studio-section">
            <div class="studio-section__header">
              <h2>Entry frame</h2>
              <p>Choose the archive lane first, then give it the minimum metadata needed to land cleanly.</p>
            </div>

            <div class="studio-fields studio-fields--two">
              <label class="studio-field">
                <span>Lane</span>
                <select name="medium" required data-medium-select>
                  {mediumOptions.map((option) => (
                    <option value={option.value} selected={option.value === 'writing'}>{option.label}</option>
                  ))}
                </select>
              </label>

              <label class="studio-field">
                <span>Date</span>
                <input type="date" name="date" required data-date-input />
              </label>
            </div>

            <div class="studio-fields studio-fields--two">
              <label class="studio-field">
                <span>Source</span>
                <select name="source" required data-source-select>
                  {sourceOptions.map((option) => (
                    <option value={option.value} selected={option.value === 'manual'}>{option.label}</option>
                  ))}
                </select>
                <small>You can override the auto-suggested source if the URL points somewhere unexpected.</small>
              </label>

              <label class="studio-field">
                <span>Status</span>
                <select name="status" required>
                  {statusOptions.map((option) => (
                    <option value={option.value} selected={option.value === 'in-progress'}>{option.label}</option>
                  ))}
                </select>
              </label>
            </div>

            <label class="studio-field">
              <span>Title</span>
              <input type="text" name="title" maxlength="180" placeholder="Archive title" required />
            </label>

            <label class="studio-field">
              <span>Summary</span>
              <textarea
                name="summary"
                rows="3"
                maxlength="420"
                placeholder="Short archive-facing summary."
                required
              ></textarea>
            </label>

            <label class="studio-field">
              <span>Body</span>
              <textarea
                name="body"
                rows="9"
                maxlength="30000"
                placeholder="Optional for link-first entries. Use this for writing, notes, proposals, or any additional context you want in the MDX body."
              ></textarea>
            </label>
          </div>

          <div class="studio-section">
            <div class="studio-section__header">
              <h2>Links and archive ties</h2>
              <p>Keep this light. Phase 1 is happiest when you give it text, tags, and one external URL.</p>
            </div>

            <label class="studio-field">
              <span>External URL</span>
              <input
                type="url"
                name="external_url"
                inputmode="url"
                placeholder="https://www.youtube.com/... or https://untitled.stream/..."
                data-external-url
              />
            </label>

            <div class="studio-fields studio-fields--two">
              <label class="studio-field">
                <span>Tags</span>
                <input
                  type="text"
                  name="tags"
                  placeholder="ai, accountability, archive"
                />
                <small>Comma or line-break separated. Spaces become hyphens.</small>
              </label>

              <label class="studio-field">
                <span>Related entries</span>
                <textarea
                  name="related_entries"
                  rows="3"
                  placeholder="writing/archive-pass-after-midnight&#10;video/everyday-life"
                ></textarea>
                <small>Use archive slugs, separated by commas or line breaks.</small>
              </label>
            </div>
          </div>

          <fieldset class="studio-section studio-proposal" data-proposal-fields hidden>
            <div class="studio-section__header">
              <h2>Proposal details</h2>
              <p>These fields only write into frontmatter when the lane is set to proposal.</p>
            </div>

            <div class="studio-fields studio-fields--two">
              <label class="studio-field">
                <span>Audience</span>
                <input type="text" name="audience" maxlength="260" data-proposal-input />
              </label>

              <label class="studio-field">
                <span>Institution</span>
                <input type="text" name="institution" maxlength="260" data-proposal-input />
              </label>
            </div>

            <div class="studio-fields studio-fields--three">
              <label class="studio-field">
                <span>Proposal status</span>
                <input type="text" name="proposal_status" maxlength="160" data-proposal-input />
              </label>

              <label class="studio-field">
                <span>Place</span>
                <input type="text" name="place" maxlength="160" data-proposal-input />
              </label>

              <label class="studio-field">
                <span>Ask</span>
                <textarea name="ask" rows="3" maxlength="600" data-proposal-input></textarea>
              </label>
            </div>
          </fieldset>

          <div class="studio-section">
            <div class="studio-section__header">
              <h2>Commit</h2>
              <p>Password is the only gate in Phase 1. This is meant for personal authoring, not public submission.</p>
            </div>

            <label class="studio-field">
              <span>Password</span>
              <input type="password" name="password" autocomplete="current-password" required />
            </label>

            <div class="studio-submit">
              <button class="studio-submit__button" type="submit" data-submit-button>Commit entry</button>
              <p class="studio-submit__status" data-studio-status aria-live="polite"></p>
            </div>
          </div>
        </form>

        <aside class="studio-sidebar">
          <section class="studio-sidebar__panel">
            <p class="studio-sidebar__kicker">Phase 1</p>
            <h2>Included now</h2>
            <ul>
              <li>Writing, note, proposal, music, video, and image lanes</li>
              <li>Text-first frontmatter plus optional MDX body</li>
              <li>YouTube, Substack, untitled.stream, and similar URL intake</li>
              <li>GitHub-backed file creation on the configured branch</li>
            </ul>
          </section>

          <section class="studio-sidebar__panel">
            <p class="studio-sidebar__kicker">Deferred</p>
            <h2>Phase 2</h2>
            <p>
              Local image/MOV upload, asset storage, automatic `asset` frontmatter generation, and richer media ingest
              are intentionally deferred so Phase 1 stays light and reliable.
            </p>
          </section>

          <section class="studio-sidebar__panel">
            <p class="studio-sidebar__kicker">Recent entry slugs</p>
            <h2>Related entry examples</h2>
            <ul class="studio-related-list">
              {relatedEntryOptions.slice(0, 10).map((entry) => (
                <li>
                  <code>{entry.slug}</code>
                  <span>{entry.title}</span>
                </li>
              ))}
            </ul>
          </section>
        </aside>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const form = document.querySelector('[data-studio-form]');
      if (!(form instanceof HTMLFormElement)) return;

      const mediumSelect = form.querySelector('[data-medium-select]');
      const sourceSelect = form.querySelector('[data-source-select]');
      const externalUrlInput = form.querySelector('[data-external-url]');
      const dateInput = form.querySelector('[data-date-input]');
      const proposalFields = form.querySelector('[data-proposal-fields]');
      const statusNode = form.querySelector('[data-studio-status]');
      const submitButton = form.querySelector('[data-submit-button]');

      if (!(mediumSelect instanceof HTMLSelectElement)) return;
      if (!(sourceSelect instanceof HTMLSelectElement)) return;
      if (!(externalUrlInput instanceof HTMLInputElement)) return;
      if (!(dateInput instanceof HTMLInputElement)) return;
      if (!(proposalFields instanceof HTMLElement)) return;
      if (!(statusNode instanceof HTMLElement)) return;
      if (!(submitButton instanceof HTMLButtonElement)) return;

      let sourceTouched = false;
      let mediumTouched = false;

      const proposalInputs = Array.from(proposalFields.querySelectorAll('input, textarea'));

      const inferFromUrl = (value) => {
        if (!value) return null;

        try {
          const url = new URL(value);
          const host = url.hostname.toLowerCase();

          if (host === 'youtu.be' || host.includes('youtube.com')) {
            return { source: 'youtube', medium: 'video' };
          }

          if (host.includes('substack.com')) {
            return { source: 'substack', medium: 'writing' };
          }

          if (host.includes('untitled.stream')) {
            return { source: 'untitled', medium: 'music' };
          }

          if (host.includes('linktr.ee') || host.includes('linktree')) {
            return { source: 'linktree', medium: null };
          }
        } catch {}

        return null;
      };

      const setStatus = (message, state = 'idle') => {
        statusNode.textContent = message;
        statusNode.dataset.state = state;
      };

      const syncProposalFields = () => {
        const isProposal = mediumSelect.value === 'proposal';
        proposalFields.hidden = !isProposal;

        proposalInputs.forEach((input) => {
          input.disabled = !isProposal;
        });
      };

      const seedDate = () => {
        if (dateInput.value) return;
        const today = new Date();
        const offsetDate = new Date(today.getTime() - today.getTimezoneOffset() * 60000);
        dateInput.value = offsetDate.toISOString().slice(0, 10);
      };

      seedDate();
      syncProposalFields();

      mediumSelect.addEventListener('change', () => {
        mediumTouched = true;
        syncProposalFields();
      });

      sourceSelect.addEventListener('change', () => {
        sourceTouched = true;
      });

      externalUrlInput.addEventListener('input', () => {
        const inferred = inferFromUrl(externalUrlInput.value.trim());
        if (!inferred) return;

        if (!sourceTouched || sourceSelect.value === 'manual') {
          sourceSelect.value = inferred.source;
        }

        if (inferred.medium && (!mediumTouched || mediumSelect.value === 'writing')) {
          mediumSelect.value = inferred.medium;
          syncProposalFields();
        }
      });

      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        if (!form.reportValidity()) return;

        submitButton.disabled = true;
        setStatus('Committing entry…', 'pending');

        try {
          const response = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: {
              accept: 'application/json'
            }
          });

          const payload = await response.json().catch(() => ({
            ok: false,
            message: 'The studio request failed before it could return a readable response.'
          }));

          if (!response.ok || !payload.ok) {
            throw new Error(payload.message || 'The entry could not be committed.');
          }

          const details = [payload.filePath, payload.commitSha].filter(Boolean).join(' · ');
          setStatus(
            `${payload.message}${details ? ` ${details}` : ''}`,
            'success'
          );
          form.reset();
          seedDate();
          sourceTouched = false;
          mediumTouched = false;
          mediumSelect.value = 'writing';
          sourceSelect.value = 'manual';
          syncProposalFields();
        } catch (error) {
          setStatus(error instanceof Error ? error.message : 'The entry could not be committed.', 'error');
        } finally {
          submitButton.disabled = false;
        }
      });
    })();
  </script>
</BaseLayout>

<style>
  .studio-shell {
    display: grid;
    place-items: center;
  }

  .studio-panel {
    width: min(100%, 82rem);
    display: grid;
    gap: 1.35rem;
  }

  .studio-header {
    display: grid;
    gap: 0.72rem;
    max-width: 62rem;
  }

  .studio-kicker,
  .studio-copy,
  .studio-note {
    margin: 0;
  }

  .studio-kicker {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: color-mix(in srgb, var(--tone-accent-glow) 72%, var(--tone-muted) 28%);
  }

  .studio-copy {
    max-width: 56ch;
    color: color-mix(in srgb, var(--tone-text) 90%, var(--tone-muted) 10%);
  }

  .studio-note {
    max-width: 62ch;
    color: color-mix(in srgb, var(--tone-text) 78%, var(--tone-muted) 22%);
  }

  .studio-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(0, 1.6fr) minmax(18rem, 0.85fr);
    align-items: start;
  }

  .studio-form,
  .studio-sidebar {
    display: grid;
    gap: 1rem;
  }

  .studio-section,
  .studio-sidebar__panel {
    border: 1px solid color-mix(in srgb, var(--tone-accent) 14%, var(--line2));
    border-radius: 1.15rem;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--tone-accent) 8%, transparent), transparent 68%),
      color-mix(in srgb, var(--tone-surface-strong) 92%, transparent);
    box-shadow:
      0 20px 44px rgba(0, 0, 0, 0.22),
      0 1px 0 rgba(255, 255, 255, 0.03) inset;
  }

  .studio-section {
    padding: clamp(1rem, 2.4vw, 1.35rem);
    display: grid;
    gap: 0.95rem;
  }

  .studio-sidebar__panel {
    padding: 1rem 1.05rem;
    display: grid;
    gap: 0.68rem;
  }

  .studio-section__header {
    display: grid;
    gap: 0.3rem;
  }

  .studio-section__header h2,
  .studio-section__header p,
  .studio-sidebar__panel h2,
  .studio-sidebar__panel p,
  .studio-sidebar__panel ul {
    margin: 0;
  }

  .studio-section__header p,
  .studio-sidebar__panel p,
  .studio-sidebar__panel li {
    color: color-mix(in srgb, var(--tone-text) 78%, var(--tone-muted) 22%);
  }

  .studio-sidebar__kicker {
    margin: 0;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: color-mix(in srgb, var(--tone-accent-glow) 76%, var(--tone-muted) 24%);
  }

  .studio-fields {
    display: grid;
    gap: 0.9rem;
  }

  .studio-fields--two {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .studio-fields--three {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .studio-field {
    display: grid;
    gap: 0.4rem;
  }

  .studio-field span {
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: color-mix(in srgb, var(--tone-text) 82%, var(--tone-muted) 18%);
  }

  .studio-field small {
    color: color-mix(in srgb, var(--tone-text) 64%, var(--tone-muted) 36%);
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .studio-field input,
  .studio-field select,
  .studio-field textarea {
    width: 100%;
    border: 1px solid color-mix(in srgb, var(--tone-accent) 18%, var(--line2));
    border-radius: 0.9rem;
    background: color-mix(in srgb, var(--tone-bg-deep) 48%, rgba(255, 255, 255, 0.02));
    color: var(--tone-text);
    padding: 0.72rem 0.86rem;
    line-height: 1.5;
  }

  .studio-field textarea {
    resize: vertical;
    min-height: 7.2rem;
  }

  .studio-field input:focus-visible,
  .studio-field select:focus-visible,
  .studio-field textarea:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--tone-accent) 48%, transparent);
    outline-offset: 2px;
    border-color: color-mix(in srgb, var(--tone-accent) 36%, var(--line2));
  }

  .studio-submit {
    display: grid;
    gap: 0.7rem;
  }

  .studio-submit__button {
    width: fit-content;
    min-height: 2.8rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--tone-accent) 38%, var(--line2));
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--tone-accent) 16%, transparent), transparent 72%),
      color-mix(in srgb, var(--tone-surface-strong) 90%, transparent);
    color: color-mix(in srgb, var(--tone-accent-glow) 82%, white 18%);
    padding: 0.65rem 1rem;
  }

  .studio-submit__button:disabled {
    opacity: 0.7;
    cursor: wait;
  }

  .studio-submit__status {
    margin: 0;
    min-height: 1.5rem;
    color: color-mix(in srgb, var(--tone-text) 80%, var(--tone-muted) 20%);
  }

  .studio-submit__status[data-state='success'] {
    color: color-mix(in srgb, var(--tone-accent-glow) 82%, white 18%);
  }

  .studio-submit__status[data-state='error'] {
    color: #efb2ab;
  }

  .studio-related-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.72rem;
  }

  .studio-related-list li {
    display: grid;
    gap: 0.18rem;
  }

  .studio-related-list code {
    width: fit-content;
    padding: 0.16rem 0.38rem;
    border-radius: 0.45rem;
    background: color-mix(in srgb, var(--tone-bg-deep) 54%, transparent);
    color: color-mix(in srgb, var(--tone-accent-glow) 80%, white 20%);
  }

  @media (max-width: 980px) {
    .studio-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .studio-fields--two,
    .studio-fields--three {
      grid-template-columns: 1fr;
    }

    .studio-panel {
      gap: 1rem;
    }

    .studio-section,
    .studio-sidebar__panel {
      border-radius: 1rem;
    }

    .studio-submit__button {
      width: 100%;
      justify-content: center;
    }
  }
</style>
