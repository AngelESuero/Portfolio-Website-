---
import BaseLayout from '../../layouts/BaseLayout.astro';
import featuredThreadsData from '../../data/featured_threads.json';
import { getCollection, type CollectionEntry } from 'astro:content';
import { resolveProjectTimeline } from '../../data/linktree-timeline';

type PreparedLink = {
  key: string;
  label: string;
  url: string;
  isExternal: boolean;
};

type RelatedProject = {
  slug: string;
  title: string;
  yearLabel: string;
};

type RelatedThread = {
  title: string;
  href: string;
};

type PreparedProject = {
  slug: string;
  title: string;
  yearLabel: string;
  type: string;
  status: string;
  role: string | null;
  description: string;
  coverImage: string;
  tools: string[];
  notes: string[];
  focusCopy: string;
  detailPath: string;
  links: PreparedLink[];
  relatedProjects: RelatedProject[];
  hasCuratedRelations: boolean;
  relatedThread: RelatedThread | null;
  hasCuratedThread: boolean;
  isLead: boolean;
};

const linkLabels: Record<string, string> = {
  untitled: 'Untitled',
  youtube: 'YouTube',
  instagram: 'Instagram',
  linktree: 'Linktree',
  github: 'GitHub'
};

const typeLabels: Record<string, string> = {
  music: 'Music',
  video: 'Video',
  writing: 'Writing',
  civic: 'Civic'
};

const compareProjectsByRecency = (a: CollectionEntry<'projects'>, b: CollectionEntry<'projects'>) => {
  const yearDelta = resolveProjectTimeline(b.data).sortYear - resolveProjectTimeline(a.data).sortYear;
  if (yearDelta !== 0) return yearDelta;

  const timelineOrderA = a.data.timeline_order ?? Number.MAX_SAFE_INTEGER;
  const timelineOrderB = b.data.timeline_order ?? Number.MAX_SAFE_INTEGER;
  if (timelineOrderA !== timelineOrderB) return timelineOrderA - timelineOrderB;

  return a.data.title.localeCompare(b.data.title);
};

const collapseMarkdown = (value: string): string =>
  value
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/[*_`>#]/g, '')
    .replace(/\s+/g, ' ')
    .trim();

const extractNotes = (body: string): string[] =>
  String(body || '')
    .split(/\n{2,}/)
    .map((part) => collapseMarkdown(part))
    .filter(Boolean)
    .slice(0, 2);

const formatRole = (value: string | null): string | null => {
  if (!value) return null;
  const normalized = value
    .split('/')
    .map((part) => part.trim())
    .filter(Boolean)
    .join(' · ');
  return normalized || null;
};

const outwardLabel = (link: PreparedLink): string => {
  switch (link.key) {
    case 'untitled':
      return 'Listen on Untitled';
    case 'youtube':
      return 'Watch on YouTube';
    case 'instagram':
      return 'See it on Instagram';
    case 'linktree':
      return 'Open release links';
    case 'github':
      return 'Browse the code';
    default:
      return `Visit ${link.label}`;
  }
};

const allProjects = (await getCollection('projects')).sort(compareProjectsByRecency);
const projectIndex = new Map(allProjects.map((project) => [project.slug, project]));
const scoreLeadProject = (project: CollectionEntry<'projects'>) => {
  const timeline = resolveProjectTimeline(project.data);
  const notes = extractNotes(project.body);
  const noteWeight = Math.min(notes.join(' ').length, 160);
  const featuredWeight = project.data.featured ? 360 : 0;
  const statusWeight = /published/i.test(project.data.status) ? 90 : 0;
  const leadPriorityWeight = (project.data.leadPriority ?? 0) * 1000;
  return leadPriorityWeight + featuredWeight + statusWeight + noteWeight + timeline.sortYear;
};

const leadProject =
  [...allProjects].sort((a, b) => {
    const scoreDelta = scoreLeadProject(b) - scoreLeadProject(a);
    if (scoreDelta !== 0) return scoreDelta;
    return compareProjectsByRecency(a, b);
  })[0] ?? allProjects[0];
const remainingProjects = allProjects
  .filter((project) => project.slug !== leadProject.slug)
  .sort((a, b) => {
    const featuredDelta = Number(b.data.featured) - Number(a.data.featured);
    if (featuredDelta !== 0) return featuredDelta;
    return compareProjectsByRecency(a, b);
  });
const orderedProjects = [leadProject, ...remainingProjects];

const threadsByType = new Map(
  featuredThreadsData.featured_threads.map((thread) => [
    thread.type,
    { title: thread.title, href: thread.href }
  ])
);

const threadsByHref = new Map(
  featuredThreadsData.featured_threads.map((thread) => [
    thread.href,
    { title: thread.title, href: thread.href }
  ])
);

const inferRelatedProjects = (
  project: CollectionEntry<'projects'>,
  excludedSlugs: string[] = []
): RelatedProject[] => {
  const excluded = new Set([project.slug, ...excludedSlugs]);
  return allProjects
    .filter((candidate) => !excluded.has(candidate.slug) && candidate.data.type === project.data.type)
    .sort((a, b) => {
      const featuredDelta = Number(b.data.featured) - Number(a.data.featured);
      if (featuredDelta !== 0) return featuredDelta;
      return compareProjectsByRecency(a, b);
    })
    .slice(0, 2)
    .map((candidate) => ({
      slug: candidate.slug,
      title: candidate.data.title,
      yearLabel: resolveProjectTimeline(candidate.data).yearLabel
    }));
};

const resolveRelatedProjects = (
  project: CollectionEntry<'projects'>
): { items: RelatedProject[]; hasCuratedRelations: boolean } => {
  const explicitSlugs = Array.isArray(project.data.relatedProjects) ? project.data.relatedProjects : [];
  const seen = new Set<string>();
  const explicitMatches = explicitSlugs
    .map((slug) => projectIndex.get(slug))
    .filter((candidate): candidate is CollectionEntry<'projects'> => {
      if (!candidate || candidate.slug === project.slug || seen.has(candidate.slug)) return false;
      seen.add(candidate.slug);
      return true;
    })
    .map((candidate) => ({
      slug: candidate.slug,
      title: candidate.data.title,
      yearLabel: resolveProjectTimeline(candidate.data).yearLabel
    }));

  if (explicitMatches.length >= 2) {
    return {
      items: explicitMatches.slice(0, 2),
      hasCuratedRelations: true
    };
  }

  const inferredMatches = inferRelatedProjects(
    project,
    explicitMatches.map((candidate) => candidate.slug)
  );

  return {
    items: [...explicitMatches, ...inferredMatches].slice(0, 2),
    hasCuratedRelations: explicitMatches.length > 0
  };
};

const resolveRelatedThread = (
  project: CollectionEntry<'projects'>
): { item: RelatedThread | null; hasCuratedThread: boolean } => {
  const explicitHref = typeof project.data.relatedThread === 'string' ? project.data.relatedThread.trim() : '';
  const explicitThread = explicitHref ? threadsByHref.get(explicitHref) ?? null : null;

  if (explicitThread) {
    return {
      item: explicitThread,
      hasCuratedThread: true
    };
  }

  return {
    item: threadsByType.get(project.data.type) ?? null,
    hasCuratedThread: false
  };
};

const preparedProjects: PreparedProject[] = orderedProjects.map((project) => {
  const timeline = resolveProjectTimeline(project.data);
  const notes = extractNotes(project.body);
  const links = Object.entries(project.data.links)
    .map(([key, value]) => {
      const url = typeof value === 'string' ? value.trim() : '';
      if (!url) return null;
      return {
        key,
        label: linkLabels[key] || key,
        url,
        isExternal: /^https?:\/\//i.test(url)
      };
    })
    .filter((entry): entry is PreparedLink => Boolean(entry));
  const relatedProjectData = resolveRelatedProjects(project);
  const relatedThreadData = resolveRelatedThread(project);

  return {
    slug: project.slug,
    title: project.data.title,
    yearLabel: timeline.yearLabel,
    type: typeLabels[project.data.type] ?? project.data.type,
    status: project.data.status,
    role: formatRole(typeof project.data.role === 'string' && project.data.role.trim() ? project.data.role.trim() : null),
    description: project.data.description,
    coverImage: project.data.cover_image,
    tools: project.data.tools,
    notes: notes.length > 0 ? notes : [project.data.description],
    focusCopy: notes[0] ?? project.data.description,
    detailPath: `/work/${project.slug}`,
    links,
    relatedProjects: relatedProjectData.items,
    hasCuratedRelations: relatedProjectData.hasCuratedRelations,
    relatedThread: relatedThreadData.item,
    hasCuratedThread: relatedThreadData.hasCuratedThread,
    isLead: project.slug === leadProject.slug
  };
});

const leadSignal = preparedProjects.find((project) => project.isLead) ?? preparedProjects[0];
const defaultStatus =
  'Stay with one piece to let process, context, and adjacent work gather around it without leaving the page.';
---
<BaseLayout title="Work — a_e.s_" theme="work">
  <section class="work-page">
    <header class="work-intro" aria-labelledby="work-title">
      <p class="work-intro__eyebrow">Work</p>
      <h1 id="work-title" class="work-intro__title">A field that narrows with attention.</h1>
      <p class="work-intro__lede">
        Music, video, and archive work live here as a quiet field first. Nothing asks for everything at once.
      </p>
      <p class="work-intro__signal">
        Leading signal:
        <a href={`#${leadSignal.slug}`}>{leadSignal.title}</a>
        sits nearest the surface right now. Follow that thread, or let another piece come forward in its own time.
      </p>
    </header>

    <section class="work-field" data-work-field data-has-selection="false" aria-labelledby="work-field-heading">
      <div class="work-field__header">
        <h2 id="work-field-heading" class="work-field__heading">Current field</h2>
        <p class="work-field__status" data-work-status aria-live="polite">{defaultStatus}</p>
      </div>

      <ol class="work-field__list" role="list">
        {preparedProjects.map((project, index) => (
          <li
            class:list={['work-field__entry', project.isLead && 'is-leading']}
            data-work-entry
            data-leading={project.isLead ? 'true' : 'false'}
            data-selected="false"
          >
            <article
              class:list={['work-chamber', project.isLead && 'is-leading']}
              data-work-item
              data-slug={project.slug}
              data-title={project.title}
              data-focus-copy={project.focusCopy}
              data-selected="false"
            >
              <button
                type="button"
                class="work-chamber__summary"
                data-work-toggle
                aria-expanded="false"
                aria-controls={`work-panel-${project.slug}`}
              >
                <div class="work-chamber__copy">
                  <div class="work-chamber__meta">
                    <span>{project.yearLabel}</span>
                    <span>{project.type}</span>
                    <span>{project.status}</span>
                    {project.isLead && <span class="work-chamber__lead-badge">Leading signal</span>}
                  </div>
                  <h3 id={`work-heading-${project.slug}`} class="work-chamber__title">{project.title}</h3>
                  <p class="work-chamber__description">{project.description}</p>
                  <span class="work-chamber__prompt">
                    {index === 0 ? 'Begin here if you want a first thread' : 'Let this one come forward'}
                  </span>
                </div>

                <div class="work-chamber__media">
                  <img
                    src={project.coverImage}
                    alt={project.title}
                    loading={index === 0 ? 'eager' : 'lazy'}
                    decoding="async"
                  />
                </div>
              </button>

              <div
                id={`work-panel-${project.slug}`}
                class="work-chamber__detail"
                data-work-panel
                aria-labelledby={`work-heading-${project.slug}`}
                hidden
              >
                <div class="work-chamber__detail-grid">
                  <div class="work-chamber__detail-copy">
                    <p class="work-chamber__detail-kicker">Resolution</p>
                    {project.notes.map((note) => (
                      <p>{note}</p>
                    ))}

                    <dl class="work-chamber__facts">
                      <div>
                        <dt>Year</dt>
                        <dd>{project.yearLabel}</dd>
                      </div>
                      <div>
                        <dt>Form</dt>
                        <dd>{project.type}</dd>
                      </div>
                      {project.role && (
                        <div>
                          <dt>Made as</dt>
                          <dd>{project.role}</dd>
                        </div>
                      )}
                      <div>
                        <dt>Status</dt>
                        <dd>{project.status}</dd>
                      </div>
                    </dl>

                    <div class="work-chamber__tools" aria-label="Process tools">
                      {project.tools.map((tool) => (
                        <span class="work-chamber__tool">{tool}</span>
                      ))}
                    </div>
                  </div>

                  <aside class="work-chamber__detail-aside">
                    {project.relatedProjects.length > 0 && (
                      <section class="work-chamber__group work-chamber__group--adjacency" aria-labelledby={`work-related-${project.slug}`}>
                        <h4 id={`work-related-${project.slug}`}>Stays close to this piece</h4>
                        <p class="work-chamber__group-copy">
                          {project.hasCuratedRelations
                            ? 'Chosen adjacencies in the body of work.'
                            : 'Nearby work in the same part of the archive.'}
                        </p>
                        <ul class="work-chamber__list">
                          {project.relatedProjects.map((related) => (
                            <li>
                              <a href={`/work/${related.slug}`}>
                                <span>{related.title}</span>
                                <small>{related.yearLabel}</small>
                              </a>
                            </li>
                          ))}
                        </ul>
                      </section>
                    )}

                    {project.relatedThread && (
                      <p class="work-chamber__thread-note">
                        {project.hasCuratedThread
                          ? 'One thread stays deliberately in conversation with this piece:'
                          : 'A nearby thread keeps the wider process open:'}
                        {' '}
                        <a class="work-chamber__thread-link" href={project.relatedThread.href}>
                          {project.relatedThread.title}
                        </a>
                        .
                      </p>
                    )}

                    <section class="work-chamber__continuation" aria-labelledby={`work-links-${project.slug}`}>
                      <h4 id={`work-links-${project.slug}`}>Continue with this work</h4>
                      <div class="work-chamber__action-row">
                        <a class="work-chamber__action work-chamber__action--primary" href={project.detailPath}>
                          Read the fuller project page
                        </a>
                        {project.links.length > 0 && (
                          <ul class="work-chamber__quiet-links">
                            {project.links.map((link) => (
                              <li>
                                <a
                                  class="work-chamber__quiet-link"
                                  href={link.url}
                                  {...(link.isExternal ? { target: '_blank', rel: 'noopener' } : {})}
                                >
                                  {outwardLabel(link)}
                                </a>
                              </li>
                            ))}
                          </ul>
                        )}
                      </div>
                    </section>
                  </aside>
                </div>
              </div>
            </article>
          </li>
        ))}
      </ol>
    </section>
  </section>
</BaseLayout>

<script is:inline>
  (() => {
    const field = document.querySelector('[data-work-field]');
    if (!(field instanceof HTMLElement)) return;

    const items = Array.from(field.querySelectorAll('[data-work-item]'));
    const status = field.querySelector('[data-work-status]');
    const defaultStatus = status instanceof HTMLElement ? status.textContent?.trim() || '' : '';

    const sync = (slug, updateHash = true) => {
      const hasSelection = Boolean(slug);
      field.dataset.hasSelection = hasSelection ? 'true' : 'false';

      items.forEach((item) => {
        const active = hasSelection && item.getAttribute('data-slug') === slug;
        item.setAttribute('data-selected', active ? 'true' : 'false');
        const entry = item.closest('[data-work-entry]');
        if (entry instanceof HTMLElement) {
          entry.dataset.selected = active ? 'true' : 'false';
        }

        const toggle = item.querySelector('[data-work-toggle]');
        const panel = item.querySelector('[data-work-panel]');

        if (toggle instanceof HTMLElement) {
          toggle.setAttribute('aria-expanded', String(active));
        }

        if (panel instanceof HTMLElement) {
          panel.hidden = !active;
        }
      });

      if (status instanceof HTMLElement) {
        if (!hasSelection) {
          status.textContent = defaultStatus;
        } else {
          const selected = items.find((item) => item.getAttribute('data-slug') === slug);
          status.textContent =
            selected?.getAttribute('data-focus-copy') || selected?.getAttribute('data-title') || defaultStatus;
        }
      }

      if (!updateHash) return;

      if (!hasSelection) {
        const cleanUrl = `${window.location.pathname}${window.location.search}`;
        window.history.replaceState({}, '', cleanUrl);
        return;
      }

      window.history.replaceState({}, '', `#${slug}`);
    };

    items.forEach((item) => {
      const toggle = item.querySelector('[data-work-toggle]');
      if (!(toggle instanceof HTMLButtonElement)) return;

      toggle.addEventListener('click', () => {
        const slug = item.getAttribute('data-slug') || '';
        const isSelected = item.getAttribute('data-selected') === 'true';
        sync(isSelected ? '' : slug);
      });
    });

    const initialSlug = window.location.hash.replace(/^#/, '');
    const hasInitialMatch = items.some((item) => item.getAttribute('data-slug') === initialSlug);
    sync(hasInitialMatch ? initialSlug : '', false);

    window.addEventListener('hashchange', () => {
      const hashSlug = window.location.hash.replace(/^#/, '');
      const hasMatch = items.some((item) => item.getAttribute('data-slug') === hashSlug);
      sync(hasMatch ? hashSlug : '', false);
    });
  })();
</script>

<style>
  .work-page {
    display: grid;
    gap: clamp(1.35rem, 2vw, 1.9rem);
  }

  .work-intro {
    display: grid;
    gap: 0.8rem;
    max-width: 58rem;
  }

  .work-intro__eyebrow,
  .work-intro__lede,
  .work-intro__signal,
  .work-field__heading,
  .work-field__status,
  .work-chamber__description,
  .work-chamber__detail-kicker,
  .work-chamber__detail-copy p,
  .work-chamber__group h4,
  .work-chamber__facts dt,
  .work-chamber__facts dd {
    margin: 0;
  }

  .work-intro__eyebrow {
    font-size: 0.74rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--tone-text) 78%, var(--tone-muted) 22%);
  }

  .work-intro__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 4.35rem);
    line-height: 0.96;
    letter-spacing: -0.03em;
    max-width: 12ch;
  }

  .work-intro__lede {
    max-width: 40rem;
    font-size: clamp(1rem, 1.5vw, 1.14rem);
    color: color-mix(in srgb, var(--tone-text) 90%, var(--tone-muted) 10%);
  }

  .work-intro__signal {
    max-width: 42rem;
    color: color-mix(in srgb, var(--tone-text) 82%, var(--tone-muted) 18%);
  }

  .work-intro__signal a {
    color: var(--tone-accent-glow);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--tone-accent) 48%, transparent);
    text-underline-offset: 0.14em;
  }

  .work-field {
    display: grid;
    gap: 0.95rem;
  }

  .work-field__header {
    display: grid;
    gap: 0.45rem;
    max-width: 44rem;
  }

  .work-field__heading {
    font-family: var(--font-display);
    font-size: 1.2rem;
    letter-spacing: 0.01em;
  }

  .work-field__status {
    color: color-mix(in srgb, var(--tone-text) 82%, var(--tone-muted) 18%);
  }

  .work-field__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.95rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-items: start;
  }

  .work-field__entry {
    margin: 0;
  }

  .work-field__entry[data-leading='true'],
  .work-field__entry[data-selected='true'] {
    grid-column: 1 / -1;
  }

  .work-chamber {
    opacity: 0.84;
    border: 1px solid color-mix(in srgb, var(--tone-accent) 14%, var(--line2));
    border-radius: 1.45rem;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--tone-accent) 8%, transparent), transparent 58%),
      color-mix(in srgb, var(--tone-surface-strong) 88%, transparent);
    box-shadow:
      0 18px 48px rgba(7, 9, 12, 0.12),
      inset 0 1px 0 color-mix(in srgb, white 7%, transparent);
    transition:
      opacity 160ms ease,
      border-color 160ms ease,
      transform 160ms ease,
      filter 160ms ease,
      background-color 160ms ease;
    overflow: clip;
  }

  .work-chamber.is-leading {
    opacity: 1;
    border-color: color-mix(in srgb, var(--tone-accent) 28%, var(--line2));
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--tone-accent) 12%, transparent), transparent 62%),
      color-mix(in srgb, var(--tone-surface-strong) 92%, transparent);
  }

  .work-chamber__summary {
    width: 100%;
    padding: clamp(1rem, 2vw, 1.25rem);
    border: 0;
    background: transparent;
    color: inherit;
    text-align: left;
    display: grid;
    gap: 0.9rem;
    grid-template-columns: 1fr;
    align-items: start;
    cursor: pointer;
  }

  .work-field__entry[data-leading='true'] .work-chamber__summary,
  .work-field__entry[data-selected='true'] .work-chamber__summary {
    gap: 1rem;
    grid-template-columns: minmax(0, 1.18fr) minmax(15.5rem, 0.92fr);
    align-items: center;
  }

  .work-chamber__copy {
    display: grid;
    gap: 0.7rem;
    min-width: 0;
  }

  .work-chamber__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.6rem;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--tone-text) 72%, var(--tone-muted) 28%);
  }

  .work-chamber__lead-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.18rem 0.48rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--tone-accent) 28%, var(--line2));
    color: color-mix(in srgb, var(--tone-accent-glow) 84%, white 16%);
    letter-spacing: 0.1em;
  }

  .work-chamber__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.38rem, 2.1vw, 2rem);
    line-height: 1;
    letter-spacing: -0.02em;
    max-width: 15ch;
  }

  .work-field__entry[data-leading='true'] .work-chamber__title,
  .work-field__entry[data-selected='true'] .work-chamber__title {
    font-size: clamp(1.55rem, 2.8vw, 2.35rem);
  }

  .work-chamber__description {
    max-width: 42rem;
    color: color-mix(in srgb, var(--tone-text) 88%, var(--tone-muted) 12%);
  }

  .work-chamber__prompt {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: color-mix(in srgb, var(--tone-text) 76%, var(--tone-muted) 24%);
  }

  .work-chamber__prompt::after {
    content: '↗';
    font-size: 0.9em;
  }

  .work-chamber__media {
    position: relative;
    border-radius: 1.1rem;
    overflow: hidden;
    aspect-ratio: 16 / 9.25;
    border: 1px solid color-mix(in srgb, var(--tone-accent) 18%, var(--line2));
    background: color-mix(in srgb, var(--tone-bg) 82%, black 18%);
    max-height: 12rem;
  }

  .work-field__entry[data-leading='true'] .work-chamber__media,
  .work-field__entry[data-selected='true'] .work-chamber__media {
    aspect-ratio: 16 / 11;
    max-height: none;
  }

  .work-chamber__media img {
    display: block;
    width: 100%;
