---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import ProjectCard from '../../components/ProjectCard.astro';
import { resolveProjectTimeline } from '../../data/linktree-timeline';

const allProjects = (await getCollection('projects')).sort((a, b) => {
  const yearDelta = resolveProjectTimeline(a.data).sortYear - resolveProjectTimeline(b.data).sortYear;
  if (yearDelta !== 0) return yearDelta;

  const timelineOrderA = a.data.timeline_order ?? Number.MAX_SAFE_INTEGER;
  const timelineOrderB = b.data.timeline_order ?? Number.MAX_SAFE_INTEGER;
  if (timelineOrderA !== timelineOrderB) return timelineOrderA - timelineOrderB;

  return a.data.title.localeCompare(b.data.title);
});
const types = ['all', 'music', 'video', 'writing', 'civic'];
const isDraftDescription = (value: string): boolean => {
  const normalized = String(value || '').trim();
  if (!normalized) return true;
  if (/^\[[^\]]+\]$/.test(normalized)) return true;
  return /^(add description|tbd|coming soon|placeholder)$/i.test(normalized);
};
const projectCards = allProjects.map((project) => ({
  project,
  isDraft: isDraftDescription(project.data.description)
}));
---
<BaseLayout title="Work — a_e.s_" theme="work">
  <div class="work-overview">
    <h1 class="font-display text-4xl">Work / Projects</h1>
    <p class="mt-3">Timeline order (oldest to newest). Filter by type and explore the archive.</p>
    <div class="mt-4 flex flex-wrap gap-2" id="filters">
      {types.map((type) => <button class="filter rounded border border-zinc-400 px-3 py-1 text-sm dark:border-zinc-600" data-filter={type}>{type}</button>)}
    </div>
  </div>
  <div class="mt-6 flex gap-4 overflow-x-auto pb-2 md:grid md:grid-cols-3 md:overflow-visible" id="project-grid">
    {projectCards.map(({ project, isDraft }) => (
      <div class="project-item" data-type={project.data.type} data-draft={isDraft ? 'true' : 'false'}>
        <ProjectCard project={project} isDraft={isDraft} />
      </div>
    ))}
  </div>
</BaseLayout>

<script is:inline>
  (() => {
    const buttons = Array.from(document.querySelectorAll('.filter'));
    const items = Array.from(document.querySelectorAll('.project-item'));
    if (!buttons.length || !items.length) return;

    let activeFilter = 'all';
    const isLabMode = () => window.__modeSettings?.getState?.()?.surfaceMode === 'lab';
    const applyFilters = () => {
      const labMode = isLabMode();
      items.forEach((item) => {
        const type = item.getAttribute('data-type');
        const isDraft = item.getAttribute('data-draft') === 'true';
        const typeMatch = activeFilter === 'all' || activeFilter === type;
        const visible = typeMatch && (labMode || !isDraft);
        item.style.display = visible ? 'block' : 'none';
      });
    };

    const syncButtonState = () => {
      buttons.forEach((button) => {
        const selected = button.getAttribute('data-filter') === activeFilter;
        button.setAttribute('aria-pressed', String(selected));
      });
    };

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        activeFilter = button.getAttribute('data-filter') || 'all';
        syncButtonState();
        applyFilters();
      });
    });

    window.addEventListener('modesettings:change', applyFilters);
    syncButtonState();
    applyFilters();
  })();
</script>

<style>
  .work-overview {
    position: relative;
    isolation: isolate;
  }

  .work-overview::before {
    content: '';
    position: absolute;
    inset: -0.8rem -0.9rem -0.95rem;
    z-index: -1;
    border-radius: 1rem;
    background: color-mix(in srgb, var(--tone-surface) 10%, transparent);
    pointer-events: none;
  }

  #project-grid :global(.card) {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.075), rgba(255, 255, 255, 0.024)),
      radial-gradient(
        120% 140% at 0% 0%,
        color-mix(in srgb, var(--tone-accent) 7%, transparent),
        transparent 44%
      ),
      color-mix(in srgb, var(--tone-surface-strong) 82%, transparent);
  }
</style>
