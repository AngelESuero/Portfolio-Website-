---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { resolveProjectTimeline } from '../../data/linktree-timeline';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({ params: { slug: project.slug }, props: { project } }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const timeline = resolveProjectTimeline(project.data);
const linkLabels: Record<string, string> = {
  untitled: 'Untitled',
  youtube: 'YouTube',
  instagram: 'Instagram',
  linktree: 'Linktree',
  github: 'GitHub'
};
const projectLinks = Object.entries(project.data.links)
  .map(([key, value]) => {
    const url = typeof value === 'string' ? value.trim() : '';
    if (!url) return null;
    const label = linkLabels[key] || key;
    const isExternal = /^https?:\/\//i.test(url);
    return { key, label, url, isExternal };
  })
  .filter((entry): entry is { key: string; label: string; url: string; isExternal: boolean } => Boolean(entry));
const projectMedia = Array.isArray(project.data.media) ? project.data.media : [];
---
<BaseLayout title={`${project.data.title} — Work`} theme="work">
  <div class="work-entry">
    <a href="/work" class="text-sm underline">← Back to Work</a>
    <h1 class="mt-2 font-display text-4xl">{project.data.title}</h1>
    <p class="mt-1 text-zinc-600 dark:text-zinc-300">{timeline.yearLabel} · {project.data.status}</p>
    <img src={project.data.cover_image} alt={project.data.title} class="mt-6 h-72 w-full rounded object-cover"/>
    <p class="mt-4">{project.data.description}</p>
    <div class="mt-4 flex flex-wrap gap-2">
      {project.data.tools.map((tool) => <span class="rounded border px-2 py-1 text-sm">{tool}</span>)}
    </div>
    {projectLinks.length > 0 && (
      <div class="mt-5 flex flex-wrap gap-2">
        {projectLinks.map((link) => (
          <a
            href={link.url}
            class="rounded border px-3 py-1 text-sm underline"
            {...(link.isExternal ? { target: '_blank', rel: 'noopener' } : {})}
          >
            Open {link.label}
          </a>
        ))}
      </div>
    )}
    <article class="reading-prose mt-8"><Content /></article>
    {projectMedia.length > 0 && (
      <section class="project-media" aria-label="Selected frames">
        <p class="project-media__eyebrow">Selected frames</p>
        <div class="project-media__grid">
          {projectMedia.map((item) => (
            <figure class="project-media__item">
              <img src={item.src} alt={item.alt} loading="lazy" decoding="async" />
              {item.caption && <figcaption>{item.caption}</figcaption>}
            </figure>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .work-entry {
    position: relative;
    isolation: isolate;
  }

  .work-entry::before {
    content: '';
    position: absolute;
    inset: -0.95rem -1rem -1rem;
    z-index: -1;
    border-radius: 1rem;
    background: color-mix(in srgb, var(--tone-surface) 12%, transparent);
    pointer-events: none;
  }

  .project-media {
    margin-top: 2rem;
  }

  .project-media__eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.76rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--tone-text) 72%, var(--tone-muted) 28%);
  }

  .project-media__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 0.75rem;
  }

  .project-media__item {
    margin: 0;
  }

  .project-media__item img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 14px;
  }

  .project-media__item figcaption {
    margin-top: 0.45rem;
    font-size: 0.82rem;
    line-height: 1.4;
    color: color-mix(in srgb, var(--tone-text) 78%, var(--tone-muted) 22%);
  }

  @media (max-width: 480px) {
    .project-media__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
