---
import BaseLayout from '../layouts/BaseLayout.astro';
import profile from '../data/profile';
import CopyButton from '../components/CopyButton.astro';

const sent = Astro.url.searchParams.get('sent') === '1';
const error = Astro.url.searchParams.get('error');
const deliveryUnavailable = error === 'unavailable';
const deliveryFailed = error === 'failed';
---

<BaseLayout title="Contact - a_e.s_" theme="contact">
  <h1 class="font-display text-4xl">Contact</h1>
  <p class="mt-2">Use the form for inquiries. Messages are forwarded only when contact delivery is configured.</p>

  {sent && !error && (
    <p class="mt-4 rounded border border-emerald-300/70 bg-emerald-100/20 px-3 py-2 text-sm" role="status">
      Message sent. Thank you.
    </p>
  )}

  {(deliveryUnavailable || deliveryFailed) && (
    <p class="mt-4 rounded border border-amber-300/70 bg-amber-100/20 px-3 py-2 text-sm" role="alert">
      {deliveryUnavailable
        ? 'Contact delivery is not configured right now. Please use one of the direct links below.'
        : 'Contact delivery failed. Please try again later or use one of the direct links below.'}
    </p>
  )}

  <form class="mt-6 grid max-w-xl gap-3" method="post" action="/contact">
    <label>Name <input required name="name" class="mt-1 w-full rounded border p-2 text-black" /></label>
    <label>Email <input required type="email" name="email" class="mt-1 w-full rounded border p-2 text-black" /></label>
    <label>Message <textarea required name="message" rows="5" class="mt-1 w-full rounded border p-2 text-black"></textarea></label>
    <button class="rounded bg-accent px-4 py-2 text-white">Send</button>
  </form>

  <div class="mt-8 space-y-2">
    <p><a href={profile.social_links.instagram} class="underline">Instagram @a_e_s_</a> <CopyButton value={profile.social_links.instagram} /></p>
    <p><a href={profile.social_links.youtube} class="underline">YouTube @a_e_s_</a> <CopyButton value={profile.social_links.youtube} /></p>
    <p><a href={profile.social_links.discord} class="underline">Discord</a> <CopyButton value={profile.social_links.discord} /></p>
    <p><a href={profile.link_hub_url} class="underline">Link hub</a> <CopyButton value={profile.link_hub_url} /></p>
  </div>
</BaseLayout>
