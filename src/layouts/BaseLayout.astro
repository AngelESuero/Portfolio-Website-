              applyFocusPoint(focusX, focusY);
            },
            { passive: true }
          );

          document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
              focusPinned = false;
              setInactive(600, true);
              return;
            }

            if (scheduleFocusedDwell(document.activeElement)) return;
            scheduleDwell();
          });
        };

        const initHeaderMetrics = () => {
          const header = document.querySelector('.site-header');
          if (!(header instanceof HTMLElement)) {
            root.style.setProperty('--site-header-size', '0px');
            root.style.setProperty('--header-height', '0px');
            return;
          }

          const syncHeaderHeight = () => {
            const height = Math.max(52, Math.round(header.getBoundingClientRect().height));
            const body = document.body;
            const headerMode = body instanceof HTMLBodyElement ? body.dataset.headerMode : 'pinned';
            root.style.setProperty('--site-header-size', `${height}px`);
            root.style.setProperty('--header-height', headerMode === 'peek' ? '0px' : `${height}px`);
          };

          syncHeaderHeight();
          window.addEventListener('resize', syncHeaderHeight, { passive: true });

          if ('ResizeObserver' in window) {
            const observer = new ResizeObserver(() => {
              syncHeaderHeight();
            });
            observer.observe(header);
          }
        };

        const initSiteActivity = () => {
          const ACTIVITY_IDLE_MS = 2240;
          let activityTimer = null;
          let siteIsActive = false;

          const setSiteActive = (isActive) => {
            if (siteIsActive === isActive) return;
            siteIsActive = isActive;
            root.dataset.siteActive = isActive ? 'true' : 'false';
          };

          const markSiteActive = () => {
            setSiteActive(true);
            if (activityTimer) window.clearTimeout(activityTimer);
            activityTimer = window.setTimeout(() => {
              setSiteActive(false);
            }, ACTIVITY_IDLE_MS);
          };

          setSiteActive(false);

          const listenerOptions = { passive: true };
          window.addEventListener('pointermove', markSiteActive, listenerOptions);
          window.addEventListener('pointerdown', markSiteActive, listenerOptions);
          window.addEventListener('touchstart', markSiteActive, listenerOptions);
          window.addEventListener('keydown', markSiteActive);

          document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
              if (activityTimer) window.clearTimeout(activityTimer);
              setSiteActive(false);
              return;
            }
            markSiteActive();
          });
        };

        const initHeaderReveal = () => {
          const body = document.body;
          const header = document.querySelector('.site-header');
          if (!(body instanceof HTMLBodyElement) || !(header instanceof HTMLElement)) return;

          if (body.dataset.headerMode !== 'peek') {
            body.dataset.headerReveal = 'visible';
            return;
          }

          const canHover = typeof window.matchMedia === 'function'
            ? window.matchMedia('(hover: hover) and (pointer: fine)').matches
            : false;

          if (!canHover) {
            body.dataset.headerReveal = 'visible';
            return;
          }

          const SHOW_EDGE_PX = 44;
          const HIDE_BUFFER_PX = 36;
          const HIDE_DELAY_MS = 90;
          let hideTimer = null;
          let pointerY = Number.POSITIVE_INFINITY;
          let hoveringHeader = false;
          let headerHasFocus = false;

          const clearHideTimer = () => {
            if (!hideTimer) return;
            window.clearTimeout(hideTimer);
            hideTimer = null;
          };

          const readHeaderSize = () => {
            const raw = window.getComputedStyle(root).getPropertyValue('--site-header-size');
            const parsed = Number.parseFloat(raw);
            if (Number.isFinite(parsed) && parsed > 0) return parsed;
            return Math.max(52, Math.round(header.getBoundingClientRect().height));
          };

          const setHeaderReveal = (nextState) => {
            if (body.dataset.headerReveal === nextState) return;
            body.dataset.headerReveal = nextState;
          };

          const scheduleHide = () => {
            if (hoveringHeader || headerHasFocus) return;
            clearHideTimer();
            hideTimer = window.setTimeout(() => {
              const hideThreshold = readHeaderSize() + HIDE_BUFFER_PX;
              if (pointerY > hideThreshold && !hoveringHeader && !headerHasFocus) {
                setHeaderReveal('hidden');
              }
            }, HIDE_DELAY_MS);
          };

          header.addEventListener('pointerenter', () => {
            hoveringHeader = true;
            clearHideTimer();
            setHeaderReveal('visible');
          });

          header.addEventListener('pointerleave', (event) => {
            hoveringHeader = false;
            if (event instanceof PointerEvent) {
              pointerY = event.clientY;
            }
            scheduleHide();
          });

          header.addEventListener('focusin', () => {
            headerHasFocus = true;
            clearHideTimer();
            setHeaderReveal('visible');
          });

          header.addEventListener('focusout', () => {
            headerHasFocus = header.contains(document.activeElement);
            if (!headerHasFocus) scheduleHide();
          });

          window.addEventListener(
            'pointermove',
            (event) => {
              pointerY = event.clientY;
              if (event.clientY <= SHOW_EDGE_PX) {
                clearHideTimer();
                setHeaderReveal('visible');
                return;
              }

              const hideThreshold = readHeaderSize() + HIDE_BUFFER_PX;
              if (event.clientY > hideThreshold) {
                scheduleHide();
              }
            },
            { passive: true }
          );

          window.addEventListener(
            'scroll',
            () => {
              if (window.scrollY <= 12) {
                clearHideTimer();
                setHeaderReveal('visible');
                return;
              }
              scheduleHide();
            },
            { passive: true }
          );

          document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
              clearHideTimer();
            }
          });
        };

        const initScrollWind = () => {
          const SCROLL_IDLE_MS = 140;
          let scrollTimer = null;
          let scrollOptimizing = false;

          const setScrollOptimizing = (isActive) => {
            if (scrollOptimizing === isActive) return;
            scrollOptimizing = isActive;
            root.dataset.scrollOptimizing = isActive ? 'true' : 'false';
          };

          const clearWind = () => {
            if (scrollTimer) {
              window.clearTimeout(scrollTimer);
              scrollTimer = null;
            }

            setScrollOptimizing(false);
            root.dataset.siteScrollActive = 'false';
            root.style.setProperty('--garland-wind-x', '0px');
            root.style.setProperty('--garland-wind-strength', '0');
          };

          const markScrolling = () => {
            setScrollOptimizing(true);
            if (scrollTimer) window.clearTimeout(scrollTimer);
            scrollTimer = window.setTimeout(() => {
              setScrollOptimizing(false);
              scrollTimer = null;
            }, SCROLL_IDLE_MS);
          };

          clearWind();
          window.addEventListener('scroll', markScrolling, { passive: true });
          window.addEventListener('wheel', markScrolling, { passive: true });
          window.addEventListener('touchmove', markScrolling, { passive: true });
          document.addEventListener('visibilitychange', () => {
            if (document.hidden) clearWind();
          });
        };

        const handleColorClick = (event) => {
          if (
            event instanceof MouseEvent &&
            (event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey)
          ) {
            return;
          }

          if (!(event.target instanceof Element)) return;
          const trigger = event.target.closest('[data-color], [data-tone]');
          if (!(trigger instanceof HTMLElement)) return;

          const color = trigger.getAttribute('data-color');
          const tone = trigger.getAttribute('data-tone');
          if (color) {
            setSiteAccent(color, { animate: true, duration: 240 });
          }
          if (tone) {
            setSiteTone(tone, { animate: true, duration: 320 });
          }

          if (!(trigger instanceof HTMLAnchorElement)) return;
          if (trigger.target && trigger.target !== '_self') return;
          if (trigger.hasAttribute('download')) return;

          const href = trigger.getAttribute('href');
          if (!href || href.startsWith('#')) return;

          let url;
          try {
            url = new URL(href, window.location.href);
          } catch {
            return;
          }

          if (url.origin !== window.location.origin) return;
          if (url.pathname === window.location.pathname && url.search === window.location.search) return;
          if (color) writeAccentHandoff(color);
          if (tone) writeToneHandoff(tone);
        };

        const init = () => {
          initCircadianMode();
          initTone();
          initAccent();
          initCircadianClock();
          initHeaderMetrics();
          initHeaderReveal();
          initSiteActivity();
          initScrollWind();
          initCursorLight();
          initFocusZoom();
          document.addEventListener('click', handleColorClick, { capture: true });
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init, { once: true });
        } else {
          init();
        }
      })();
    </script>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
  </head>
  <body
    data-theme={theme}
    data-header-mode={showHeader ? 'pinned' : 'peek'}
    data-header-reveal={showHeader ? 'visible' : 'hidden'}
    data-nav-phase="idle"
  >
    <div class="site-depth-stage" aria-hidden="true">
      <div id="cursor-aura"></div>
      <HallwayBackdrop accent="var(--accent)" />
      <div class="site-overlay"></div>
    </div>
    <GarlandFrame />
    <Header />
    <div class="site-content-stage">
      <main class="page-shell w-full">
        <div class="mode-normal">
          <slot />
        </div>

        <section class="mode-walk view-surface" aria-labelledby="walkthrough-heading">
          <header class="view-surface-header">
            <p class="view-surface-kicker">Walkthrough mode</p>
            <h1 id="walkthrough-heading">Walkthrough</h1>
            <p>Use Next and Back to follow a simple guided sequence. Your current step is saved.</p>
          </header>

          <ol class="walkthrough-list" aria-live="polite">
            {walkthroughSteps.map((step, index) => (
              <li class="walkthrough-step" data-step={String(index + 1)} hidden={index !== 0}>
                <p class="walkthrough-step-meta">Step {index + 1} of {walkthroughSteps.length}</p>
                <h2>{step.title}</h2>
                <p>{step.text}</p>
                <a href={step.href} class="walkthrough-step-link">{step.cta}</a>
              </li>
            ))}
          </ol>

          <div class="walkthrough-controls">
            <button type="button" id="walkthrough-back">Back</button>
            <p id="walkthrough-step-indicator">Step 1 / {walkthroughSteps.length}</p>
            <button type="button" id="walkthrough-next">Next</button>
          </div>
        </section>

        <section class="mode-explore view-surface" aria-labelledby="explore-heading">
          <header class="view-surface-header">
            <p class="view-surface-kicker">Explore mode</p>
            <h1 id="explore-heading">Explore</h1>
            <p>Scan sections quickly, then jump directly to the page you want.</p>
          </header>
          <div class="explore-grid">
            {exploreLinks.map((item) => (
              <a href={item.href} class="explore-card">{item.label}</a>
            ))}
          </div>
        </section>
      </main>
      <Footer />
    </div>
    <script is:inline>
      (() => {
        const body = document.body;
        if (!(body instanceof HTMLBodyElement)) return;

        const EXIT_DELAY_MS = 320;
        const prefersReducedMotion =
          typeof window.matchMedia === 'function' ? window.matchMedia('(prefers-reduced-motion: reduce)') : null;
        let isNavigating = false;

        const isEligibleLink = (event, link) => {
          if (event.defaultPrevented || isNavigating) return false;
          if (prefersReducedMotion?.matches) return false;
          if (event.button !== 0) return false;
          if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return false;
          if (link.target && link.target !== '_self') return false;
          if (link.hasAttribute('download') || link.hasAttribute('data-no-route-transition')) return false;

          const rawHref = link.getAttribute('href');
          if (!rawHref || rawHref.startsWith('#')) return false;

          let url;
          try {
            url = new URL(link.href, window.location.href);
          } catch {
            return false;
          }

          if (url.origin !== window.location.origin) return false;
          if (url.protocol !== 'http:' && url.protocol !== 'https:') return false;
          if (url.pathname === window.location.pathname && url.search === window.location.search) return false;

          return true;
        };

        document.addEventListener('click', (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;

          const link = target.closest('a[href]');
          if (!(link instanceof HTMLAnchorElement)) return;
          if (!isEligibleLink(event, link)) return;

          event.preventDefault();
          isNavigating = true;
          body.dataset.navPhase = 'exiting';

          window.setTimeout(() => {
            window.location.assign(link.href);
          }, EXIT_DELAY_MS);
        });

        window.addEventListener('pageshow', () => {
          isNavigating = false;
          body.dataset.navPhase = 'idle';
        });
      })();
    </script>
    <script is:inline define:vars={{ walkthroughCount: walkthroughSteps.length }}>
      (() => {
        const list = Array.from(document.querySelectorAll('.walkthrough-step'));
        const backBtn = document.getElementById('walkthrough-back');
        const nextBtn = document.getElementById('walkthrough-next');
        const indicator = document.getElementById('walkthrough-step-indicator');
        if (!list.length || !backBtn || !nextBtn || !indicator) return;

        const max = Number(walkthroughCount) || 1;

        const clampStep = (value) => {
          const parsed = Number.parseInt(String(value || ''), 10);
          if (Number.isNaN(parsed)) return 1;
          return Math.min(max, Math.max(1, parsed));
        };

        const paint = () => {
          const state = window.__modeSettings?.getState?.() || { walkStep: 1 };
          const step = clampStep(state.walkStep);
          list.forEach((item, index) => {
            const active = index + 1 === step;
            item.hidden = !active;
            item.setAttribute('aria-current', active ? 'step' : 'false');
          });
          indicator.textContent = `Step ${step} / ${max}`;
          backBtn.disabled = step <= 1;
          nextBtn.disabled = step >= max;
        };

        backBtn.addEventListener('click', () => {
          const state = window.__modeSettings?.getState?.() || { walkStep: 1 };
          window.__modeSettings?.setWalkStep?.(clampStep(state.walkStep - 1));
          paint();
        });

        nextBtn.addEventListener('click', () => {
          const state = window.__modeSettings?.getState?.() || { walkStep: 1 };
          window.__modeSettings?.setWalkStep?.(clampStep(state.walkStep + 1));
          paint();
        });

        window.addEventListener('modesettings:change', paint);
        paint();
      })();
    </script>
    <style is:global>
      .mode-normal {
        display: block;
      }

      .mode-walk,
      .mode-explore {
        display: none;
      }

      html[data-mode='walk'] .mode-normal,
      html[data-mode='explore'] .mode-normal {
        display: none;
      }

      html[data-mode='walk'] .mode-walk {
        display: block;
      }

      html[data-mode='explore'] .mode-explore {
        display: block;
      }
    </style>
  </body>
</html>
