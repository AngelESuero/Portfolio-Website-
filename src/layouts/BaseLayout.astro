          });

          window.addEventListener(
            'scroll',
            () => {
              if (!focusPinned) {
                cancelAmbientZoom();
                if (scheduleFocusedDwell(document.activeElement)) return;
                scheduleDwell();
              }
            },
            { passive: true }
          );

          window.addEventListener(
            'wheel',
            () => {
              if (!focusPinned) {
                cancelAmbientZoom();
                if (scheduleFocusedDwell(document.activeElement)) return;
                scheduleDwell();
              }
            },
            { passive: true }
