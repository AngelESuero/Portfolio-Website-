            clearDwellTimer();
            if (focusPinned && !force) return;

            setZoomDuration(duration);
            root.dataset.focusZoomActive = 'false';
            root.style.setProperty('--focus-zoom-scale', '1');
            root.style.setProperty('--focus-zoom-pan-x', '0px');
            root.style.setProperty('--focus-zoom-pan-y', '0px');
          };

          const engage = (x, y, duration = ACTIVATE_DURATION_MS) => {
            const next = applyFocusPoint(x, y);
            setZoomDuration(duration);
            root.dataset.focusZoomActive = 'true';
            root.style.setProperty('--focus-zoom-scale', String(ZOOM_SCALE));
            root.style.setProperty('--focus-zoom-pan-x', next.panX);
            root.style.setProperty('--focus-zoom-pan-y', next.panY);
          };

          const getFocusableTarget = (node) => {
            if (!(node instanceof HTMLElement) || node === document.body) return null;
            const anchor = node.closest(
              'a, button, input, textarea, select, summary, [tabindex]:not([tabindex="-1"])'
            );
            return anchor instanceof HTMLElement ? anchor : node;
          };

          const hasFocusedIntent = () => Boolean(getFocusableTarget(document.activeElement));

          const syncFocusedElement = (node, duration = FOCUS_DURATION_MS) => {
            const target = getFocusableTarget(node);
            if (!target) return false;
            const rect = target.getBoundingClientRect();
            if (!rect.width && !rect.height) return false;

            focusPinned = true;
            clearDwellTimer();
            engage(rect.left + rect.width / 2, rect.top + rect.height / 2, duration);
            return true;
          };

          const scheduleFocusedDwell = (node, duration = FOCUS_DURATION_MS) => {
            const target = getFocusableTarget(node);
            if (!target) return false;

            clearDwellTimer();
            dwellTimer = window.setTimeout(() => {
              const activeTarget = getFocusableTarget(document.activeElement);
              if (!activeTarget || activeTarget !== target) return;
              syncFocusedElement(target, duration);
            }, DWELL_DELAY_MS);
            return true;
          };

          const scheduleDwell = () => {
            if (!canTrackPointer || focusPinned || hasFocusedIntent()) return;
            clearDwellTimer();
            dwellTimer = window.setTimeout(() => {
              engage(focusX, focusY, ACTIVATE_DURATION_MS);
            }, DWELL_DELAY_MS);
          };

          const cancelAmbientZoom = () => {
            clearDwellTimer();
            if (!focusPinned && root.dataset.focusZoomActive === 'true') {
              setInactive(RELEASE_DURATION_MS);
            }
          };

          applyFocusPoint(focusX, focusY);
          setZoomDuration(0);

          if (canTrackPointer) {
            window.addEventListener(
              'pointermove',
              (event) => {
                if (focusPinned || hasFocusedIntent()) return;

                const nextX = event.clientX;
                const nextY = event.clientY;
                const distance = Math.hypot(nextX - focusX, nextY - focusY);
                focusX = nextX;
                focusY = nextY;

                if (distance < MOVE_TOLERANCE_PX) return;
                cancelAmbientZoom();
                scheduleDwell();
              },
              { passive: true }
            );

            window.addEventListener(
              'pointerdown',
              () => {
                if (!focusPinned && !hasFocusedIntent()) cancelAmbientZoom();
              },
              { passive: true }
            );
          }

          document.addEventListener('focusin', (event) => {
            if (root.dataset.focusZoomActive === 'true') {
              syncFocusedElement(event.target, 1800);
              return;
            }
            scheduleFocusedDwell(event.target);
          });

          document.addEventListener('focusout', () => {
            window.requestAnimationFrame(() => {
              if (root.dataset.focusZoomActive === 'true') {
                if (syncFocusedElement(document.activeElement, 1800)) return;
              } else if (scheduleFocusedDwell(document.activeElement)) {
                return;
              }
              focusPinned = false;
              setInactive(RELEASE_DURATION_MS, true);
