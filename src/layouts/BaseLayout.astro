          const DWELL_DELAY_MS = 60 * 1000;
          const ACTIVATE_DURATION_MS = 18000;
          const FOCUS_DURATION_MS = 12000;
          const RELEASE_DURATION_MS = 2600;
          const MOVE_TOLERANCE_PX = 18;
          const CENTER_Y_RATIO = 0.42;
          const ZOOM_SCALE = 1.32;
          const MAX_PAN_X = 110;
          const MAX_PAN_Y = 84;
          let dwellTimer = null;
          let focusPinned = false;
          let focusX = window.innerWidth / 2;
          let focusY = window.innerHeight * CENTER_Y_RATIO;

          const clearDwellTimer = () => {
            if (!dwellTimer) return;
            window.clearTimeout(dwellTimer);
            dwellTimer = null;
          };

          const setZoomDuration = (durationMs) => {
            const ms = Math.max(0, Math.round(Number(durationMs) || 0));
            root.style.setProperty('--focus-zoom-duration', `${ms}ms`);
          };

          const applyFocusPoint = (x, y) => {
            const width = Math.max(window.innerWidth, 1);
            const height = Math.max(window.innerHeight, 1);
            focusX = clamp(x, 0, width);
            focusY = clamp(y, 0, height);

            const originX = clamp((focusX / width) * 100, 8, 92);
            const originY = clamp((focusY / height) * 100, 8, 92);
            const panX = clamp((width * 0.5 - focusX) * 0.12, -MAX_PAN_X, MAX_PAN_X);
            const panY = clamp((height * CENTER_Y_RATIO - focusY) * 0.14, -MAX_PAN_Y, MAX_PAN_Y);

            root.style.setProperty('--focus-zoom-origin-x', `${originX.toFixed(2)}%`);
            root.style.setProperty('--focus-zoom-origin-y', `${originY.toFixed(2)}%`);

            return {
              panX: `${panX.toFixed(2)}px`,
              panY: `${panY.toFixed(2)}px`
            };
          };

