---
import mapRegions, { type MapRegion } from '../data/map-regions';

interface MapRegionLayout extends MapRegion {
  x: number;
  y: number;
  width: number;
  height: number;
}

const regionLayout: Record<string, Omit<MapRegionLayout, keyof MapRegion>> = {
  work: { x: 58, y: 58, width: 148, height: 54 },
  writing: { x: 430, y: 58, width: 154, height: 54 },
  map: { x: 246, y: 144, width: 150, height: 60 },
  'ai-accountability': { x: 44, y: 254, width: 194, height: 56 },
  now: { x: 278, y: 282, width: 96, height: 50 },
  contact: { x: 444, y: 252, width: 138, height: 54 }
};

const homeMapRegions = mapRegions
  .map((region) => {
    const layout = regionLayout[region.id];
    return layout ? { ...region, ...layout } : null;
  })
  .filter((region): region is MapRegionLayout => Boolean(region));

const defaultRegionId = homeMapRegions.find((region) => region.id === 'work')?.id ?? homeMapRegions[0]?.id ?? '';
const mapAnchor = homeMapRegions.find((region) => region.id === 'map');
const mapCenterX = mapAnchor ? mapAnchor.x + mapAnchor.width / 2 : 320;
const mapCenterY = mapAnchor ? mapAnchor.y + mapAnchor.height / 2 : 174;
---

<section class="home-map-preview card" data-home-map data-default-region={defaultRegionId} aria-labelledby="home-map-preview-heading">
  <div class="home-map-preview__header">
    <div class="space-y-2">
      <p class="home-map-preview__kicker">Orientation</p>
      <h2 id="home-map-preview-heading" class="font-display text-2xl">Map Preview</h2>
      <p class="home-map-preview__copy">A lightweight route atlas for the portfolio. Select a region to preview the path below.</p>
    </div>
    <a class="home-map-preview__full-link" href="/map">Explore full map →</a>
  </div>

  <div class="home-map-preview__canvas">
    <svg viewBox="0 0 640 360" role="img" aria-labelledby="home-map-preview-title home-map-preview-description">
      <title id="home-map-preview-title">Homepage map preview</title>
      <desc id="home-map-preview-description">A simplified clickable site map that reveals a short card for each region.</desc>

      <g class="home-map-preview__connectors" aria-hidden="true">
        {homeMapRegions
          .filter((region) => region.id !== 'map')
          .map((region) => (
            <line
              x1={mapCenterX}
              y1={mapCenterY}
              x2={region.x + region.width / 2}
              y2={region.y + region.height / 2}
            />
          ))}
      </g>

      <g class="home-map-preview__regions">
        {homeMapRegions.map((region) => (
          <g
            tabindex="0"
            role="button"
            aria-label={`Show ${region.label} preview`}
            aria-controls={`home-map-card-${region.id}`}
            aria-pressed={region.id === defaultRegionId ? 'true' : 'false'}
            data-region={region.id}
            class:list={['home-map-preview__region', region.id === defaultRegionId && 'is-active']}
            style={`--region-color:${region.color}`}
          >
            <rect x={region.x} y={region.y} width={region.width} height={region.height} rx="18" ry="18"></rect>
            <text x={region.x + region.width / 2} y={region.y + region.height / 2 + 4} text-anchor="middle">
              {region.label}
            </text>
          </g>
        ))}
      </g>
    </svg>
  </div>

  <div class="home-map-preview__cards">
    {homeMapRegions.map((region) => (
      <article
        id={`home-map-card-${region.id}`}
        data-region-card={region.id}
        class:list={['home-map-preview__card', region.id === defaultRegionId && 'is-active']}
        hidden={region.id !== defaultRegionId}
      >
        <p class="home-map-preview__card-kicker">Preview</p>
        <h3 class="home-map-preview__card-title">{region.label}</h3>
        <p class="home-map-preview__card-copy">{region.summary}</p>
        <a class="home-map-preview__card-link" href={region.route}>Open {region.label}</a>
      </article>
    ))}
  </div>
</section>

<script is:inline>
  (() => {
    const root = document.currentScript?.previousElementSibling;
    if (!(root instanceof HTMLElement) || !root.matches('[data-home-map]')) return;

    const regions = Array.from(root.querySelectorAll('[data-region]'));
    const cards = Array.from(root.querySelectorAll('[data-region-card]'));
    const defaultRegionId = root.getAttribute('data-default-region') || regions[0]?.getAttribute('data-region') || '';

    const activate = (id) => {
      if (!id) return;

      regions.forEach((region) => {
        const active = region.getAttribute('data-region') === id;
        region.classList.toggle('is-active', active);
        region.setAttribute('aria-pressed', String(active));
      });

      cards.forEach((card) => {
        const active = card.getAttribute('data-region-card') === id;
        card.classList.toggle('is-active', active);
        if (card instanceof HTMLElement) {
          card.hidden = !active;
        }
      });
    };

    regions.forEach((region) => {
      region.addEventListener('click', () => activate(region.getAttribute('data-region')));
      region.addEventListener('keydown', (event) => {
        if (event.key !== 'Enter' && event.key !== ' ') return;
        event.preventDefault();
        activate(region.getAttribute('data-region'));
      });
    });

    activate(defaultRegionId);
  })();
</script>

<style>
  .home-map-preview {
    display: grid;
    gap: 1rem;
    padding: clamp(1rem, 2vw, 1.35rem);
    border: 1px solid color-mix(in srgb, var(--tone-accent) 18%, var(--line2));
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--tone-accent) 10%, transparent), transparent 62%),
      color-mix(in srgb, var(--tone-surface-strong) 90%, transparent);
  }

  .home-map-preview__header {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 0.85rem;
  }

  .home-map-preview__kicker,
  .home-map-preview__copy,
  .home-map-preview__card-kicker,
  .home-map-preview__card-title,
  .home-map-preview__card-copy {
    margin: 0;
  }

  .home-map-preview__kicker,
  .home-map-preview__card-kicker {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: color-mix(in srgb, var(--tone-text) 80%, var(--tone-muted) 20%);
  }

  .home-map-preview__copy {
    max-width: 42rem;
    color: color-mix(in srgb, var(--tone-text) 86%, var(--tone-muted) 14%);
  }

  .home-map-preview__full-link,
  .home-map-preview__card-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    padding: 0.5rem 0.9rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--tone-accent) 24%, var(--line2));
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--tone-accent) 12%, transparent), transparent 68%),
      color-mix(in srgb, var(--tone-surface) 88%, transparent);
    color: color-mix(in srgb, var(--tone-accent-glow) 84%, white 16%);
    text-decoration: none;
    transition:
      transform 140ms ease,
      border-color 140ms ease,
      color 140ms ease;
  }

  .home-map-preview__full-link:hover,
  .home-map-preview__full-link:focus-visible,
  .home-map-preview__card-link:hover,
  .home-map-preview__card-link:focus-visible {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--tone-accent) 54%, var(--line2));
    color: var(--tone-accent-glow);
  }

  .home-map-preview__canvas {
    border-radius: 1rem;
    border: 1px solid color-mix(in srgb, var(--tone-accent) 14%, var(--line2));
    background:
      radial-gradient(circle at top, color-mix(in srgb, var(--tone-accent) 12%, transparent), transparent 56%),
      color-mix(in srgb, var(--tone-bg) 90%, transparent);
    overflow: hidden;
  }

  .home-map-preview__canvas svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .home-map-preview__connectors line {
    stroke: color-mix(in srgb, var(--tone-text) 18%, transparent);
    stroke-width: 1.5;
    stroke-dasharray: 5 7;
  }

  .home-map-preview__region {
    cursor: pointer;
    transform-box: fill-box;
    transform-origin: center;
    transition: transform 140ms ease;
  }

  .home-map-preview__region rect {
    fill: color-mix(in srgb, var(--region-color) 14%, rgba(8, 13, 22, 0.8));
    stroke: color-mix(in srgb, var(--region-color) 62%, transparent);
    stroke-width: 1.4;
    transition:
      fill 140ms ease,
      stroke 140ms ease,
      filter 140ms ease;
  }

  .home-map-preview__region text {
    fill: color-mix(in srgb, var(--tone-text) 88%, white 12%);
    font-family: var(--font-display);
    font-size: 13px;
    letter-spacing: 0.02em;
    pointer-events: none;
  }

  .home-map-preview__region[data-region='ai-accountability'] text {
    font-size: 11.5px;
  }

  .home-map-preview__region:hover,
  .home-map-preview__region:focus-visible,
  .home-map-preview__region.is-active {
    transform: translateY(-2px);
  }

  .home-map-preview__region:hover rect,
  .home-map-preview__region:focus-visible rect,
  .home-map-preview__region.is-active rect {
    fill: color-mix(in srgb, var(--region-color) 22%, rgba(8, 13, 22, 0.78));
    stroke: color-mix(in srgb, var(--region-color) 88%, white 12%);
    filter: drop-shadow(0 12px 18px color-mix(in srgb, var(--region-color) 18%, transparent));
  }

  .home-map-preview__region:focus-visible {
    outline: none;
  }

  .home-map-preview__cards {
    min-height: 9.5rem;
  }

  .home-map-preview__card {
    display: grid;
    gap: 0.55rem;
    padding: 1rem;
    border: 1px solid color-mix(in srgb, var(--tone-accent) 18%, var(--line2));
    border-radius: 1rem;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--tone-accent) 8%, transparent), transparent 68%),
      color-mix(in srgb, var(--tone-surface) 92%, transparent);
  }

  .home-map-preview__card-title {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    line-height: 1.15;
  }

  .home-map-preview__card-copy {
    max-width: 34rem;
    color: color-mix(in srgb, var(--tone-text) 88%, var(--tone-muted) 12%);
  }

  @media (max-width: 860px) {
    .home-map-preview__header {
      align-items: start;
    }

    .home-map-preview__cards {
      min-height: auto;
    }
  }
</style>
