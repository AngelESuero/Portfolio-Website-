---
import mapRegions, { type MapRegion } from '../data/map-regions';

interface MapRegionLayout extends MapRegion {
  cx: number;
  cy: number;
  width: number;
  height: number;
  scale: number;
  emphasis: 'held' | 'soft' | 'thin';
}

const regionLayout: Record<string, Omit<MapRegionLayout, keyof MapRegion>> = {
  work: { cx: 182, cy: 136, width: 128, height: 46, scale: 1, emphasis: 'held' },
  writing: { cx: 470, cy: 110, width: 136, height: 42, scale: 0.84, emphasis: 'soft' },
  'ai-accountability': { cx: 120, cy: 248, width: 188, height: 44, scale: 0.9, emphasis: 'soft' },
  now: { cx: 334, cy: 276, width: 88, height: 34, scale: 0.72, emphasis: 'thin' },
  contact: { cx: 540, cy: 234, width: 118, height: 38, scale: 0.76, emphasis: 'thin' }
};

const homeMapRegions = mapRegions
  .map((region) => {
    const layout = regionLayout[region.id];
    return layout ? { ...region, ...layout } : null;
  })
  .filter((region): region is MapRegionLayout => Boolean(region));

const ambientRegionId = homeMapRegions.find((region) => region.id === 'work')?.id ?? '';
const previewConnections = [
  { from: 'work', to: 'writing', bend: -18 },
  { from: 'work', to: 'ai-accountability', bend: 24 },
  { from: 'work', to: 'now', bend: 18 },
  { from: 'writing', to: 'contact', bend: 14 }
];

const findRegion = (id: string) => homeMapRegions.find((region) => region.id === id);

const curvePath = (fromId: string, toId: string, bend = 0) => {
  const from = findRegion(fromId);
  const to = findRegion(toId);
  if (!from || !to) return '';

  const midX = (from.cx + to.cx) / 2;
  const midY = (from.cy + to.cy) / 2;
  return `M ${from.cx} ${from.cy} Q ${midX} ${midY + bend} ${to.cx} ${to.cy}`;
};
---

<section
  class="home-map-preview card"
  data-home-map
  data-empty-copy="The field stays lightly held until one region asks for closer attention."
  aria-labelledby="home-map-preview-heading"
>
  <div class="home-map-preview__header">
    <div class="space-y-2">
      <p class="home-map-preview__kicker">Orientation</p>
      <h2 id="home-map-preview-heading" class="font-display text-2xl">Map Preview</h2>
      <p class="home-map-preview__copy">
        A partial glimpse into the site map. Select a region only when you want the nearby cards to gather around it.
      </p>
    </div>
    <a class="home-map-preview__full-link" href="/map">See the full map</a>
  </div>

  <div class="home-map-preview__canvas">
    <svg viewBox="48 56 552 268" role="img" aria-labelledby="home-map-preview-title home-map-preview-description">
      <title id="home-map-preview-title">Homepage map preview</title>
      <desc id="home-map-preview-description">A simplified clickable site map that reveals a short card for each region.</desc>

      <defs>
        <radialGradient id="home-map-preview-field" cx="28%" cy="34%" r="72%">
          <stop offset="0%" stop-color="rgba(255,255,255,0.06)" />
          <stop offset="42%" stop-color="rgba(255,255,255,0.02)" />
          <stop offset="100%" stop-color="rgba(255,255,255,0)" />
        </radialGradient>
        <linearGradient id="home-map-preview-fade" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="rgba(7,11,18,0.96)" />
          <stop offset="10%" stop-color="rgba(7,11,18,0.1)" />
          <stop offset="90%" stop-color="rgba(7,11,18,0.08)" />
          <stop offset="100%" stop-color="rgba(7,11,18,0.96)" />
        </linearGradient>
      </defs>

      <rect x="36" y="52" width="576" height="276" fill="url(#home-map-preview-field)"></rect>

      <g class="home-map-preview__connectors" aria-hidden="true">
        {previewConnections.map((connection) => {
          const d = curvePath(connection.from, connection.to, connection.bend);
          return d ? <path d={d} /> : null;
        })}
      </g>

      <g class="home-map-preview__regions">
        {homeMapRegions.map((region) => (
          <g
            tabindex="0"
            role="button"
            aria-label={`Show ${region.label} preview`}
            aria-pressed="false"
            data-region={region.id}
            data-label={region.label}
            data-summary={region.summary}
            data-color={region.color}
            data-related-cards={region.relatedCards.join(' ')}
            class:list={[
              'home-map-preview__region',
              region.id === ambientRegionId && 'is-ambient'
            ]}
            style={`--region-color:${region.color};--region-scale:${region.scale};`}
            transform={`translate(${region.cx} ${region.cy}) scale(${region.scale})`}
          >
            <rect
              class="home-map-preview__region-hit"
              x={-region.width / 2 - 18}
              y={-region.height / 2 - 16}
              width={region.width + 36}
              height={region.height + 32}
              rx="26"
              ry="26"
            ></rect>
            <ellipse
              class="home-map-preview__region-halo"
              cx="0"
              cy="0"
              rx={region.width / 2}
              ry={region.height / 2}
            ></ellipse>
            <ellipse
              class="home-map-preview__region-shell"
              cx="0"
              cy="0"
              rx={region.width / 2}
              ry={region.height / 2}
            ></ellipse>
            <text y="4" text-anchor="middle">
              {region.label}
            </text>
          </g>
        ))}
      </g>

      <rect x="48" y="56" width="552" height="268" fill="url(#home-map-preview-fade)" pointer-events="none"></rect>
    </svg>
  </div>

  <p class="home-map-preview__status" data-home-map-status aria-live="polite">
    The field stays lightly held until one region asks for closer attention.
  </p>
</section>

<script is:inline>
  (() => {
    const root = document.currentScript?.previousElementSibling;
    if (!(root instanceof HTMLElement) || !root.matches('[data-home-map]')) return;

    const regions = Array.from(root.querySelectorAll('[data-region]'));
    const status = root.querySelector('[data-home-map-status]');
    const emptyCopy = root.getAttribute('data-empty-copy') || 'All paths stay open until one asks for closer attention.';
    let activeRegionId = '';

    const emitSelection = (detail) => {
      window.dispatchEvent(
        new CustomEvent('home-map:region-change', {
          detail
        })
      );
    };

    const activate = (id) => {
      activeRegionId = id && activeRegionId !== id ? id : '';
      root.dataset.hasSelection = activeRegionId ? 'true' : 'false';

      regions.forEach((region) => {
        const active = region.getAttribute('data-region') === activeRegionId;
        region.classList.toggle('is-active', active);
        region.setAttribute('aria-pressed', String(active));
      });

      const activeRegion = regions.find((region) => region.getAttribute('data-region') === activeRegionId);
      const relatedCards = activeRegion?.getAttribute('data-related-cards')?.split(/\s+/).filter(Boolean) || [];
      const summary = activeRegion?.getAttribute('data-summary') || '';

      if (status instanceof HTMLElement) {
        status.textContent = activeRegionId && summary ? summary : emptyCopy;
      }

      emitSelection(
        activeRegionId
          ? {
              regionId: activeRegionId,
              label: activeRegion?.getAttribute('data-label') || '',
              summary,
              color: activeRegion?.getAttribute('data-color') || '',
              relatedCards
            }
          : {
              regionId: '',
              label: '',
              summary: '',
              color: '',
              relatedCards: []
            }
      );
    };

    regions.forEach((region) => {
      region.addEventListener('click', () => activate(region.getAttribute('data-region')));
      region.addEventListener('keydown', (event) => {
        if (event.key !== 'Enter' && event.key !== ' ') return;
        event.preventDefault();
        activate(region.getAttribute('data-region'));
      });
    });

    activate('');
  })();
</script>

<style>
  .home-map-preview {
    display: grid;
    gap: 1rem;
    padding: clamp(1rem, 2vw, 1.35rem);
    border: 1px solid color-mix(in srgb, var(--tone-accent) 18%, var(--line2));
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--tone-accent) 10%, transparent), transparent 62%),
      color-mix(in srgb, var(--tone-surface-strong) 90%, transparent);
  }

  .home-map-preview__header {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 0.85rem;
  }

  .home-map-preview__kicker,
  .home-map-preview__copy,
  .home-map-preview__status {
    margin: 0;
  }

  .home-map-preview__kicker {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: color-mix(in srgb, var(--tone-text) 80%, var(--tone-muted) 20%);
  }

  .home-map-preview__copy {
    max-width: 42rem;
    color: color-mix(in srgb, var(--tone-text) 86%, var(--tone-muted) 14%);
  }

  .home-map-preview__full-link,
  .home-map-preview__card-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    padding: 0.5rem 0.9rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--tone-accent) 24%, var(--line2));
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--tone-accent) 12%, transparent), transparent 68%),
      color-mix(in srgb, var(--tone-surface) 88%, transparent);
    color: color-mix(in srgb, var(--tone-accent-glow) 84%, white 16%);
    text-decoration: none;
    transition:
      border-color 140ms ease,
      color 140ms ease;
  }

  .home-map-preview__full-link:hover,
  .home-map-preview__full-link:focus-visible,
  .home-map-preview__card-link:hover,
  .home-map-preview__card-link:focus-visible {
    border-color: color-mix(in srgb, var(--tone-accent) 54%, var(--line2));
    color: var(--tone-accent-glow);
  }

  .home-map-preview__canvas {
    border-radius: 1rem;
    border: 1px solid color-mix(in srgb, var(--tone-accent) 10%, var(--line2));
    background:
      radial-gradient(circle at 18% 22%, color-mix(in srgb, var(--tone-accent) 10%, transparent), transparent 52%),
      radial-gradient(circle at 82% 12%, color-mix(in srgb, var(--tone-accent) 6%, transparent), transparent 42%),
      color-mix(in srgb, var(--tone-bg) 90%, transparent);
    overflow: hidden;
  }

  .home-map-preview__canvas svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .home-map-preview__connectors path {
    fill: none;
    stroke: color-mix(in srgb, var(--tone-text) 14%, transparent);
    stroke-width: 1.2;
    stroke-opacity: 0.3;
  }

  .home-map-preview__region {
    cursor: pointer;
    transition:
      opacity 160ms ease,
      filter 160ms ease;
  }

  .home-map-preview__region-hit {
    fill: transparent;
    stroke: transparent;
  }

  .home-map-preview__region-halo,
  .home-map-preview__region-shell {
    transition:
      fill 140ms ease,
      stroke 140ms ease,
      filter 140ms ease;
  }

  .home-map-preview__region-halo {
    fill: color-mix(in srgb, var(--region-color) 9%, rgba(10, 14, 22, 0.02));
    stroke: none;
  }

  .home-map-preview__region-shell {
    fill: color-mix(in srgb, var(--region-color) 8%, rgba(8, 13, 22, 0.06));
    stroke: color-mix(in srgb, var(--region-color) 34%, transparent);
    stroke-width: 1.05;
  }

  .home-map-preview__region text {
    fill: color-mix(in srgb, var(--tone-text) 88%, white 12%);
    font-family: var(--font-display);
    font-size: 14px;
    letter-spacing: 0.02em;
    pointer-events: none;
  }

  .home-map-preview__region[data-region='ai-accountability'] text {
    font-size: 12.6px;
  }

  .home-map-preview__region[data-region='now'] text,
  .home-map-preview__region[data-region='contact'] text {
    font-size: 13px;
  }

  .home-map-preview__region[data-region='writing'],
  .home-map-preview__region[data-region='contact'],
  .home-map-preview__region[data-region='now'] {
    opacity: 0.76;
  }

  .home-map-preview__region[data-region='ai-accountability'] {
    opacity: 0.82;
  }

  .home-map-preview__region.is-ambient {
    filter: drop-shadow(0 14px 22px color-mix(in srgb, var(--region-color) 8%, transparent));
  }

  .home-map-preview__region.is-ambient .home-map-preview__region-shell {
    stroke: color-mix(in srgb, var(--region-color) 54%, transparent);
    stroke-width: 1.3;
  }

  .home-map-preview__region.is-ambient text {
    fill: color-mix(in srgb, var(--tone-text) 94%, white 6%);
  }

  .home-map-preview[data-has-selection='true'] .home-map-preview__region:not(.is-active) {
    opacity: 0.58;
  }

  .home-map-preview__region:hover,
  .home-map-preview__region:focus-visible,
  .home-map-preview__region.is-active {
    opacity: 1;
  }

  .home-map-preview__region:hover .home-map-preview__region-halo,
  .home-map-preview__region:focus-visible .home-map-preview__region-halo,
  .home-map-preview__region.is-active .home-map-preview__region-halo {
    fill: color-mix(in srgb, var(--region-color) 14%, rgba(8, 13, 22, 0.1));
  }

  .home-map-preview__region:hover .home-map-preview__region-shell,
  .home-map-preview__region:focus-visible .home-map-preview__region-shell,
  .home-map-preview__region.is-active .home-map-preview__region-shell {
    fill: color-mix(in srgb, var(--region-color) 12%, rgba(8, 13, 22, 0.1));
    stroke: color-mix(in srgb, var(--region-color) 76%, white 8%);
    filter: drop-shadow(0 10px 16px color-mix(in srgb, var(--region-color) 10%, transparent));
  }

  .home-map-preview__region:focus,
  .home-map-preview__region:focus-visible {
    outline: none;
  }

  .home-map-preview__status {
    max-width: 40rem;
    color: color-mix(in srgb, var(--tone-text) 88%, var(--tone-muted) 12%);
  }

  @media (max-width: 860px) {
    .home-map-preview__header {
      align-items: start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-map-preview__region,
    .home-map-preview__full-link,
    .home-map-preview__card-link {
      transition: none;
    }
  }
</style>
