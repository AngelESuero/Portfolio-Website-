---
import type { CollectionEntry } from 'astro:content';
import { getEntryDisplaySource, isLocalImageAsset, isLocalVideoAsset } from '../lib/archive-entries';
import {
  getEmbedAspectRatio,
  getEmbedViewMode,
  getLinkCtaLabel,
  getProviderBadgeLabel,
  providerFromUrl,
  resolveEmbed
} from '../lib/embed-resolver';

interface Props {
  entry: CollectionEntry<'entries'>;
  compact?: boolean;
}

const { entry, compact = false } = Astro.props as Props;

const externalUrl = typeof entry.data.external_url === 'string' ? entry.data.external_url.trim() : '';
const assetSrc = typeof entry.data.asset?.src === 'string' ? entry.data.asset.src.trim() : '';
const assetAlt = typeof entry.data.asset?.alt === 'string' && entry.data.asset.alt.trim()
  ? entry.data.asset.alt.trim()
  : entry.data.title;
const assetPoster = typeof entry.data.asset?.poster === 'string' ? entry.data.asset.poster.trim() : '';
const assetCaption = typeof entry.data.asset?.caption === 'string' ? entry.data.asset.caption.trim() : '';

const provider = externalUrl ? providerFromUrl(externalUrl) : null;
const resolution = externalUrl ? resolveEmbed(externalUrl, provider) : null;
const embedUrl = resolution?.embedUrl ?? null;
const hasEmbed = Boolean(externalUrl && resolution?.embeddable && embedUrl);
const aspectRatio = getEmbedAspectRatio(provider, externalUrl || undefined);
const viewMode = getEmbedViewMode(provider, externalUrl || undefined);
const frameStyle = aspectRatio ? `--entry-media-aspect:${aspectRatio}` : undefined;
const linkLabel = externalUrl ? getLinkCtaLabel(externalUrl, provider) : '';
const providerLabel = externalUrl ? getProviderBadgeLabel(provider, externalUrl) : getEntryDisplaySource(entry.data.source);
const isImageAsset = isLocalImageAsset(assetSrc);
const isVideoAsset = isLocalVideoAsset(assetSrc);
const isExternal = /^https?:\/\//i.test(externalUrl);
---
{entry.data.medium === 'image' && assetSrc && isImageAsset ? (
  <figure class:list={['entry-media-block', compact && 'entry-media-block--compact']}>
    <img src={assetSrc} alt={assetAlt} loading="lazy" class="entry-media-block__image" />
    {assetCaption && <figcaption>{assetCaption}</figcaption>}
  </figure>
) : entry.data.medium === 'video' && assetSrc && isVideoAsset ? (
  <figure class:list={['entry-media-block', compact && 'entry-media-block--compact']}>
    <video controls preload="metadata" poster={assetPoster || undefined} class="entry-media-block__video">
      <source src={assetSrc} />
    </video>
    {assetCaption && <figcaption>{assetCaption}</figcaption>}
  </figure>
) : hasEmbed && embedUrl ? (
  <div class:list={['entry-media-block', 'entry-media-block--embed', compact && 'entry-media-block--compact']} data-view-mode={viewMode}>
    <div class:list={['entry-media-block__frame', aspectRatio && 'has-aspect-ratio']} style={frameStyle}>
      <iframe
        src={embedUrl}
        width="100%"
        loading="lazy"
        frameborder="0"
        allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
        allowFullScreen
        title={`${entry.data.title} embed`}
      ></iframe>
    </div>
  </div>
) : externalUrl ? (
  <div class:list={['entry-media-block', 'entry-media-block--fallback', compact && 'entry-media-block--compact']}>
    <p class="entry-media-block__badge">{providerLabel}</p>
    <a href={externalUrl} class="entry-media-block__link" {...(isExternal ? { target: '_blank', rel: 'noopener' } : {})}>
      {linkLabel}
    </a>
  </div>
) : null}

<style>
  .entry-media-block {
    margin: 0;
    border: 1px solid var(--line2);
    border-radius: 0.95rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.025), transparent 68%),
      color-mix(in srgb, var(--tone-surface-strong) 90%, transparent);
    overflow: hidden;
  }

  .entry-media-block--compact {
    border-radius: 0.82rem;
  }

  .entry-media-block__frame {
    width: 100%;
    min-height: 12rem;
    background: rgba(4, 7, 12, 0.72);
  }

  .entry-media-block__frame.has-aspect-ratio {
    min-height: 0;
    aspect-ratio: var(--entry-media-aspect, 16 / 9);
  }

  .entry-media-block__frame iframe,
  .entry-media-block__image,
  .entry-media-block__video {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .entry-media-block__image,
  .entry-media-block__video {
    object-fit: cover;
    max-height: 32rem;
  }

  .entry-media-block figcaption {
    margin: 0;
    padding: 0.68rem 0.82rem 0.78rem;
    border-top: 1px solid var(--line2);
    font-size: 0.78rem;
    color: color-mix(in srgb, var(--tone-text) 82%, var(--tone-muted) 18%);
  }

  .entry-media-block--fallback {
    display: grid;
    gap: 0.4rem;
    padding: 0.82rem 0.88rem;
  }

  .entry-media-block__badge {
    margin: 0;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--tone-text) 76%, var(--tone-muted) 24%);
  }

  .entry-media-block__link {
    width: fit-content;
    color: var(--tone-accent-glow);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--tone-accent) 38%, transparent);
  }

  .entry-media-block__link:hover,
  .entry-media-block__link:focus-visible {
    border-color: color-mix(in srgb, var(--tone-accent) 72%, transparent);
  }
</style>
