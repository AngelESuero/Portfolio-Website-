---
interface Props {
  lane: string;
  submitLabel?: string;
}

const { lane, submitLabel = 'Commit entry' } = Astro.props as Props;
---

<section class="studio-section">
  <div class="studio-section__header">
    <h2>Commit</h2>
    <p>Password is still the only gate here. This is a private personal authoring tool, not a public submission surface.</p>
  </div>

  <p class="studio-path-preview studio-notation font-archive">
    <span>Path preview</span>
    <code data-path-preview>{`src/content/entries/${lane}/untitled-entry.mdx`}</code>
  </p>

  <div class="studio-commit-meta font-archive">
    <span data-autosave-state>Local autosave enabled on this device.</span>
    <button type="button" data-clear-draft>Clear local draft</button>
  </div>

  <label class="studio-field">
    <span>Password</span>
    <input type="password" name="password" autocomplete="current-password" required data-password-input />
  </label>

  <div class="studio-submit">
    <button class="studio-button" type="submit" data-submit-button>{submitLabel}</button>
    <p class="studio-submit__status" data-studio-status aria-live="polite"></p>
  </div>
</section>
