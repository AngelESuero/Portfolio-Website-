---
interface Props {
  lane: 'music' | 'video' | 'image';
}

const { lane } = Astro.props as Props;

const accept = lane === 'music'
  ? '.mp3,.wav,.m4a,.aac,.flac,.ogg,audio/*'
  : lane === 'video'
    ? '.mp4,.mov,.m4v,.webm,.ogg,video/*'
    : '.jpg,.jpeg,.png,.webp,.gif,.avif,.svg,image/*';
---

<section class="studio-section">
  <div class="studio-section__header">
    <h2>Upload</h2>
    <p>Select a file and the upload starts right away. You can preview it, adjust the title, and publish when ready.</p>
  </div>

  <input type="hidden" name="media_mode" value="upload" data-media-mode-input />

  <div class="studio-media-pane studio-upload-box" data-media-pane="upload">
    <label class="studio-upload-picker">
      <span>Choose file</span>
      <input type="file" accept={accept} data-upload-file />
      <small>Uploads go to Cloudflare R2 immediately. Nothing is published until you hit Publish.</small>
    </label>

    <div class="studio-upload-preview" data-upload-preview hidden>
      <img alt="" data-upload-preview-image hidden />
      <video controls muted playsinline data-upload-preview-video hidden></video>
      <audio controls preload="metadata" data-upload-preview-audio hidden></audio>
      <code data-upload-preview-name>No file selected yet.</code>
      <p class="studio-helper-copy" data-upload-preview-copy>Select a file to prepare the upload.</p>
    </div>

    <progress class="studio-upload-progress" max="100" value="0" data-upload-progress hidden></progress>
    <p class="studio-submit__status" data-upload-status aria-live="polite"></p>

    <div class="studio-upload-actions">
      <button class="studio-button" type="button" data-upload-retry hidden>Retry upload</button>
      <button class="studio-button--ghost" type="button" data-upload-reset>Clear</button>
    </div>
  </div>

  <details class="studio-disclosure studio-disclosure--secondary" data-external-details>
    <summary>Use an external URL instead</summary>

    <div class="studio-disclosure__body studio-media-pane" data-media-pane="external" hidden>
      <label class="studio-field">
        <span>External URL</span>
        <input
          type="url"
          name="external_url"
          inputmode="url"
          placeholder={lane === 'music' ? 'https://untitled.stream/...' : lane === 'video' ? 'https://www.youtube.com/...' : 'https://example.com/image.jpg'}
          data-external-url
        />
        <small>Use this when the media already lives on YouTube, untitled.stream, or another public URL.</small>
      </label>
    </div>
  </details>

  <input type="hidden" name="asset_src" value="" data-asset-field="asset_src" />
  <input type="hidden" name="asset_type" value="" data-asset-field="asset_type" />
  <input type="hidden" name="original_filename" value="" data-asset-field="original_filename" />
  <input type="hidden" name="mime_type" value="" data-asset-field="mime_type" />
  <input type="hidden" name="file_size" value="" data-asset-field="file_size" />
  <input type="hidden" name="upload_source" value="" data-asset-field="upload_source" />
</section>
