---
import profile from '../data/profile';
import ViewSettings from './ViewSettings.astro';

const ACCENT_SWATCHES: Record<string, string> = {
  ochre: '#b97a2d',
  blue: '#587a95',
  red: '#a64a3b',
  white: '#ede3d1',
  black: '#171715'
};
const getAccentSwatch = (value?: string) => ACCENT_SWATCHES[String(value || '').trim().toLowerCase()] || ACCENT_SWATCHES.blue;

const primaryNav = [
  { label: 'Home', href: '/', color: 'ochre', tone: 'presence' },
  { label: 'Work', href: '/work', color: 'ochre', tone: 'seva' },
  { label: 'Writing', href: '/writing', color: 'white', tone: 'contemplation' },
  { label: 'About', href: '/about', color: 'blue', tone: 'clarity' },
  { label: 'Contact', href: '/contact', color: 'white', tone: 'harmony' }
];

const secondaryNav = [
  { label: 'AGI Timeline', href: '/agi', color: 'blue', tone: 'discernment' },
  { label: 'AI x Survival', href: '/survival-os', color: 'red', tone: 'grounding' },
  { label: 'Survival Support', href: '/survival-support', color: 'ochre', tone: 'grounding' },
  { label: 'Map', href: '/map', color: 'blue', tone: 'presence' }
];

const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
const normalize = (path: string) => path.replace(/\/+$/, '') || '/';
const isActive = (href: string) => {
  const target = normalize(href);
  return currentPath === target || (target !== '/' && currentPath.startsWith(`${target}/`));
};
---

<header class="site-header sticky top-0 z-50">
  <div class="site-shell-row header-row flex w-full items-center justify-between py-3 md:py-4">
    <a href="/" class="header-brand font-display text-lg font-bold tracking-tight text-accent">A Path Toward Life</a>
    <nav aria-label="Main navigation" class="header-nav hidden md:flex md:items-center">
      {primaryNav.map((item) => (
        <a
          href={item.href}
          class="header-link text-sm no-underline"
          style={`--link-accent:${getAccentSwatch(item.color)}`}
          {...(item.color ? { 'data-color': item.color } : {})}
          {...(item.tone ? { 'data-tone': item.tone } : {})}
          {...(isActive(item.href) ? { 'aria-current': 'page' } : {})}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <div class="header-actions flex items-center gap-2">
      <button
        id="mobile-nav-toggle"
        aria-expanded="false"
        aria-controls="mobile-nav"
        class="pill rounded px-3 py-1 text-sm md:hidden"
        type="button"
      >
        Menu
      </button>
      <div class="header-mode-toggle lab-access-only-inline-flex" role="group" aria-label="Site mode">
        <button type="button" class="header-mode-btn is-active" data-surface-mode-btn="viewer" aria-pressed="true">Viewer</button>
        <button type="button" class="header-mode-btn" data-surface-mode-btn="lab" aria-pressed="false">Lab</button>
      </div>
      <a href={profile.site_url} class="header-live lab-only-inline-flex pill rounded px-3 py-1 text-sm" aria-label="Open live site">
        Live
      </a>
      <span
        id="theme-sensor-status"
        class="header-theme-status lab-only-inline-flex pill rounded px-3 py-1 text-sm"
        role="status"
        aria-live="polite"
        aria-label="Theme follows your local time"
      >
        Auto
      </span>
      <div class="lab-only">
        <ViewSettings />
      </div>
    </div>
  </div>
  <div class="site-shell-row header-secondary hidden md:block">
    <nav aria-label="Secondary navigation" class="header-secondary-nav">
      <p class="header-secondary-label">Elsewhere</p>
      {secondaryNav.map((item) => (
        <a
          href={item.href}
          class="header-link header-link--secondary text-sm no-underline"
          style={`--link-accent:${getAccentSwatch(item.color)}`}
          {...(item.color ? { 'data-color': item.color } : {})}
          {...(item.tone ? { 'data-tone': item.tone } : {})}
          {...(isActive(item.href) ? { 'aria-current': 'page' } : {})}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
  <nav id="mobile-nav" aria-label="Mobile navigation" class="mobile-nav md:hidden" hidden>
    <div class="site-shell-row mobile-nav-inner">
      <div class="header-mode-toggle lab-access-only-inline-flex" role="group" aria-label="Site mode">
        <button type="button" class="header-mode-btn is-active" data-surface-mode-btn="viewer" aria-pressed="true">Viewer</button>
        <button type="button" class="header-mode-btn" data-surface-mode-btn="lab" aria-pressed="false">Lab</button>
      </div>
      {primaryNav.map((item) => (
        <a
          href={item.href}
          class="header-link mobile-nav-link no-underline"
          style={`--link-accent:${getAccentSwatch(item.color)}`}
          {...(item.color ? { 'data-color': item.color } : {})}
          {...(item.tone ? { 'data-tone': item.tone } : {})}
          {...(isActive(item.href) ? { 'aria-current': 'page' } : {})}
        >
          {item.label}
        </a>
      ))}
      <div class="mobile-nav-section">
        <p class="mobile-nav-label">Elsewhere</p>
        {secondaryNav.map((item) => (
          <a
            href={item.href}
            class="header-link mobile-nav-link header-link--secondary no-underline"
            style={`--link-accent:${getAccentSwatch(item.color)}`}
            {...(item.color ? { 'data-color': item.color } : {})}
            {...(item.tone ? { 'data-tone': item.tone } : {})}
            {...(isActive(item.href) ? { 'aria-current': 'page' } : {})}
          >
            {item.label}
          </a>
        ))}
      </div>
      <a href={profile.site_url} class="lab-only-inline-flex pill rounded px-3 py-1 text-sm w-fit mt-2" aria-label="Open live site">
        Live
      </a>
    </div>
  </nav>
</header>

<script is:inline>
  (() => {
    const root = document.documentElement;
    const THEME_DAY_START_HOUR = 6;
    const THEME_NIGHT_START_HOUR = 18;
    const themeStatus = document.getElementById('theme-sensor-status');
    const mobileToggle = document.getElementById('mobile-nav-toggle');
    const mobileNav = document.getElementById('mobile-nav');
    const surfaceModeButtons = Array.from(document.querySelectorAll('[data-surface-mode-btn]'));
    let currentTheme = root.classList.contains('light') ? 'light' : 'dark';
    let themeClockTimer = null;
    let renderedSurfaceMode = '';

    const getClockTheme = (date = new Date()) => {
      const decimalHour = date.getHours() + date.getMinutes() / 60;
      return decimalHour >= THEME_DAY_START_HOUR && decimalHour < THEME_NIGHT_START_HOUR ? 'light' : 'dark';
    };
    const normalizeTheme = (value) => (value === 'light' ? 'light' : 'dark');
    const getThemeStatusLabel = (value) => (value === 'light' ? 'Day' : 'Night');
    const applyTheme = (value) => {
      const nextTheme = normalizeTheme(value);
      const isDark = nextTheme === 'dark';
      root.classList.toggle('dark', isDark);
      root.classList.toggle('light', !isDark);
      root.style.colorScheme = nextTheme;
      root.dataset.themeMode = nextTheme;
      root.dataset.themeSource = 'clock';
      root.dataset.themePeriod = isDark ? 'night' : 'day';
      currentTheme = nextTheme;
      if (themeStatus instanceof HTMLElement) {
        themeStatus.textContent = getThemeStatusLabel(nextTheme);
        themeStatus.setAttribute(
          'aria-label',
          isDark ? 'Automatic theme active: night mode' : 'Automatic theme active: daylight mode'
        );
      }
      return nextTheme;
    };

    const syncThemeWithClock = () => {
      const nextTheme = getClockTheme();
      const previousTheme = currentTheme;
      const appliedTheme = applyTheme(nextTheme);
      if (previousTheme !== appliedTheme) {
        window.dispatchEvent(
          new CustomEvent('theme:change', {
            detail: { theme: appliedTheme, source: 'clock' }
          })
        );
      }
    };

    const scheduleThemeSync = () => {
      if (themeClockTimer) {
        window.clearTimeout(themeClockTimer);
      }
      const now = new Date();
      const delay = Math.max(1000, (60 - now.getSeconds()) * 1000 - now.getMilliseconds() + 120);
      themeClockTimer = window.setTimeout(() => {
        syncThemeWithClock();
        scheduleThemeSync();
      }, delay);
    };

    syncThemeWithClock();
    scheduleThemeSync();

    const getModeState = () =>
      typeof window.__modeSettings?.getState === 'function' ? window.__modeSettings.getState() : { surfaceMode: 'viewer' };
    const syncSurfaceModeUi = () => {
      const state = getModeState();
      const activeSurfaceMode = state?.surfaceMode === 'lab' ? 'lab' : 'viewer';
      if (activeSurfaceMode === renderedSurfaceMode) return;
      renderedSurfaceMode = activeSurfaceMode;

      surfaceModeButtons.forEach((button) => {
        if (!(button instanceof HTMLElement)) return;
        const targetSurfaceMode = button.getAttribute('data-surface-mode-btn') === 'lab' ? 'lab' : 'viewer';
        const isActive = targetSurfaceMode === activeSurfaceMode;
        if (button.classList.contains('is-active') !== isActive) {
          button.classList.toggle('is-active', isActive);
        }
        const nextPressed = String(isActive);
        if (button.getAttribute('aria-pressed') !== nextPressed) {
          button.setAttribute('aria-pressed', nextPressed);
        }
      });
    };

    surfaceModeButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const nextSurfaceMode = button.getAttribute('data-surface-mode-btn') === 'lab' ? 'lab' : 'viewer';
        window.__modeSettings?.setSurfaceMode?.(nextSurfaceMode);
      });
    });

    window.addEventListener('modesettings:change', syncSurfaceModeUi);
    syncSurfaceModeUi();
    const closeMobileNav = () => {
      if (!mobileNav || !mobileToggle) return;
      mobileNav.hidden = true;
      mobileToggle.setAttribute('aria-expanded', 'false');
      mobileToggle.textContent = 'Menu';
    };

    mobileToggle?.addEventListener('click', () => {
      if (!mobileNav) return;
      const nextHidden = !mobileNav.hidden;
      mobileNav.hidden = nextHidden;
      mobileToggle.setAttribute('aria-expanded', String(!nextHidden));
      mobileToggle.textContent = nextHidden ? 'Menu' : 'Close';
    });

    mobileNav?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMobileNav);
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 768) closeMobileNav();
    });

    document.addEventListener('visibilitychange', () => {
      if (!document.hidden) {
        syncThemeWithClock();
        scheduleThemeSync();
      }
    });
  })();
</script>
