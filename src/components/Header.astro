---
import profile from '../data/profile';
import ViewSettings from './ViewSettings.astro';

const ACCENT_SWATCHES: Record<string, string> = {
  yellow: '#A79A62',
  blue: '#6D8488',
  orange: '#9B7653',
  red: '#8B5952',
  white: '#C3BCA9',
  black: '#49433E',
  violet: '#7D7688',
  indigo: '#5F6C7A'
};
const getAccentSwatch = (value?: string) => ACCENT_SWATCHES[String(value || '').trim().toLowerCase()] || ACCENT_SWATCHES.blue;

const nav = [
  { label: 'Home', href: '/', color: 'white', tone: 'presence' },
  { label: 'About', href: '/about', color: 'blue', tone: 'clarity' },
  { label: 'Work', href: '/work', color: 'orange', tone: 'seva' },
  { label: 'Writing', href: '/writing', color: 'black', tone: 'contemplation' },
  { label: 'Social', href: '/social', color: 'red', tone: 'vitality' },
  { label: 'AGI Timeline', href: '/agi', color: 'black', tone: 'discernment' },
  { label: 'AI x Survival', href: '/survival-os', color: 'red', tone: 'vitality' },
  { label: 'Survival Support', href: '/survival-support', color: 'yellow', tone: 'grounding' },
  { label: 'Map', href: '/map', color: 'yellow', tone: 'grounding' },
  { label: 'Now', href: '/now', color: 'white', tone: 'presence' },
  { label: 'Contact', href: '/contact', color: 'white', tone: 'harmony' },
  { label: 'Link Hub', href: '/link-hub', color: 'blue', tone: 'harmony' }
];

const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
const normalize = (path: string) => path.replace(/\/+$/, '') || '/';
const isActive = (href: string) => {
  const target = normalize(href);
  return currentPath === target || (target !== '/' && currentPath.startsWith(`${target}/`));
};
---

<header class="site-header sticky top-0 z-50">
  <div class="site-shell-row header-row flex w-full items-center justify-between py-3 md:py-4">
    <a href="/" class="header-brand font-display text-lg font-bold tracking-tight text-accent">A Path Toward Life</a>
    <nav aria-label="Main navigation" class="header-nav hidden md:flex md:items-center">
      {nav.map((item) => (
        <a
          href={item.href}
          class="header-link text-sm no-underline"
          style={`--link-accent:${getAccentSwatch(item.color)}`}
          {...(item.color ? { 'data-color': item.color } : {})}
          {...(item.tone ? { 'data-tone': item.tone } : {})}
          {...(isActive(item.href) ? { 'aria-current': 'page' } : {})}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <div class="header-actions flex items-center gap-2">
      <button
        id="mobile-nav-toggle"
        aria-expanded="false"
        aria-controls="mobile-nav"
        class="pill rounded px-3 py-1 text-sm md:hidden"
        type="button"
      >
        Menu
      </button>
      <a href={profile.site_url} class="pill rounded px-3 py-1 text-sm hidden sm:inline-flex" aria-label="Open live site">
        Live
      </a>
      <button id="theme-toggle" aria-label="Toggle dark mode" class="pill rounded px-3 py-1 text-sm">Theme</button>
      <ViewSettings />
    </div>
  </div>
  <nav id="mobile-nav" aria-label="Mobile navigation" class="mobile-nav md:hidden" hidden>
    <div class="site-shell-row mobile-nav-inner">
      {nav.map((item) => (
        <a
          href={item.href}
          class="header-link mobile-nav-link no-underline"
          style={`--link-accent:${getAccentSwatch(item.color)}`}
          {...(item.color ? { 'data-color': item.color } : {})}
          {...(item.tone ? { 'data-tone': item.tone } : {})}
          {...(isActive(item.href) ? { 'aria-current': 'page' } : {})}
        >
          {item.label}
        </a>
      ))}
      <a href={profile.site_url} class="pill rounded px-3 py-1 text-sm w-fit mt-2" aria-label="Open live site">
        Live
      </a>
    </div>
  </nav>
</header>

<script is:inline>
  (() => {
    const root = document.documentElement;
    const themeStorage = (() => {
      try {
        return window.localStorage;
      } catch {
        return null;
      }
    })();
    const readTheme = () => {
      try {
        return typeof themeStorage?.getItem === 'function' ? themeStorage.getItem('theme') : null;
      } catch {
        return null;
      }
    };
    const writeTheme = (value) => {
      try {
        themeStorage?.setItem?.('theme', value);
      } catch {}
    };

    const saved = readTheme();
    if (saved === 'dark') root.classList.add('dark');

    const themeToggle = document.getElementById('theme-toggle');
    const mobileToggle = document.getElementById('mobile-nav-toggle');
    const mobileNav = document.getElementById('mobile-nav');

    const closeMobileNav = () => {
      if (!mobileNav || !mobileToggle) return;
      mobileNav.hidden = true;
      mobileToggle.setAttribute('aria-expanded', 'false');
      mobileToggle.textContent = 'Menu';
    };

    themeToggle?.addEventListener('click', () => {
      root.classList.toggle('dark');
      writeTheme(root.classList.contains('dark') ? 'dark' : 'light');
    });

    mobileToggle?.addEventListener('click', () => {
      if (!mobileNav) return;
      const nextHidden = !mobileNav.hidden;
      mobileNav.hidden = nextHidden;
      mobileToggle.setAttribute('aria-expanded', String(!nextHidden));
      mobileToggle.textContent = nextHidden ? 'Menu' : 'Close';
    });

    mobileNav?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMobileNav);
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 768) closeMobileNav();
    });
  })();
</script>
