---
interface HomeReflection {
  id: string;
  title: string;
  href: string;
  summary: string;
  meta: string;
  cta: string;
}

interface Props {
  items: HomeReflection[];
  sectionTitle?: string;
  variant?: 'desktop' | 'mobile';
}

const { items = [], sectionTitle = 'Tab Reflections', variant = 'desktop' } = Astro.props as Props;
const headingId = `home-reflections-${variant}`;
const isExternal = (href: string) => /^https?:\/\//i.test(href);
---

<section class:list={['home-reflections', variant === 'mobile' && 'is-mobile']} aria-labelledby={headingId}>
  <header class="home-reflections-head">
    <p class="home-reflections-kicker">Bite-sized previews</p>
    <h2 id={headingId} class="home-reflections-title">{sectionTitle}</h2>
  </header>

  {items.length > 0 ? (
    <ul class="home-reflections-grid">
      {items.map((item) => (
        <li>
          <a
            href={item.href}
            class="home-reflection-card"
            {...(isExternal(item.href) ? { target: '_blank', rel: 'noopener' } : {})}
          >
            <span class="home-reflection-title">{item.title}</span>
            <span class="home-reflection-summary">{item.summary}</span>
            <span class="home-reflection-meta">{item.meta}</span>
            <span class="home-reflection-cta">{item.cta}</span>
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <p class="home-reflections-empty">No reflections are configured yet.</p>
  )}
</section>

<style>
  .home-reflections {
    margin-top: clamp(2.2rem, 5vw, 3.1rem);
  }

  .home-reflections-head {
    display: grid;
    gap: 0.3rem;
    margin-bottom: 0.9rem;
    position: relative;
    padding-right: clamp(1rem, 8vw, 8rem);
  }

  .home-reflections-head::after {
    content: '';
    position: absolute;
    right: 0;
    top: calc(50% + 0.15rem);
    width: clamp(2.5rem, 14vw, 9rem);
    height: 1px;
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--tone-accent) 58%, transparent),
      transparent
    );
    opacity: 0.7;
  }

  .home-reflections-kicker {
    margin: 0;
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: color-mix(in srgb, var(--tone-text) 82%, var(--tone-muted) 18%);
  }

  .home-reflections-title {
    margin: 0;
    font-size: clamp(1.35rem, 2.5vw, 1.75rem);
    line-height: 1.15;
  }

  .home-reflections-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 0.7rem;
  }

  .home-reflections-grid li {
    margin: 0;
  }

  .home-reflection-card {
    position: relative;
    isolation: isolate;
    display: grid;
    gap: 0.48rem;
    height: 100%;
    padding: 0.88rem 0.92rem;
    text-decoration: none;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--tone-accent) 12%, var(--line2));
    border-radius: 1rem;
    background:
      linear-gradient(160deg, color-mix(in srgb, var(--tone-accent) 16%, transparent) 0%, rgba(255, 255, 255, 0.015) 46%),
      radial-gradient(140% 120% at 0% 0%, rgba(255, 255, 255, 0.03), transparent 44%),
      rgba(8, 12, 22, 0.62);
    color: color-mix(in srgb, var(--tone-text) 94%, var(--tone-muted) 6%);
    box-shadow:
      0 14px 28px rgba(0, 0, 0, 0.16),
      0 1px 0 rgba(255, 255, 255, 0.03) inset;
    transition:
      border-color 150ms ease,
      transform 150ms ease,
      color 150ms ease,
      box-shadow 150ms ease;
  }

  .home-reflection-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        120deg,
        rgba(255, 255, 255, 0.045),
        transparent 32%,
        transparent 68%,
        rgba(242, 184, 75, 0.045)
      );
    pointer-events: none;
  }

  .home-reflection-card > * {
    position: relative;
    z-index: 1;
  }

  .home-reflection-card:hover,
  .home-reflection-card:focus-visible {
    border-color: color-mix(in srgb, var(--tone-accent) 45%, var(--line2));
    color: var(--tone-accent-glow);
    transform: translateY(-1px);
    box-shadow:
      0 18px 34px rgba(0, 0, 0, 0.22),
      0 0 18px color-mix(in srgb, var(--tone-accent) 10%, transparent);
  }

  .home-reflection-title {
    font-family: var(--font-display);
    font-size: 1rem;
    line-height: 1.24;
  }

  .home-reflection-summary {
    font-size: 0.88rem;
    line-height: 1.45;
    color: color-mix(in srgb, var(--tone-text) 90%, var(--tone-muted) 10%);
  }

  .home-reflection-meta {
    margin-top: auto;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: color-mix(in srgb, var(--tone-text) 84%, var(--tone-muted) 16%);
  }

  .home-reflection-cta {
    display: inline-flex;
    width: fit-content;
    font-size: 0.8rem;
    border-bottom: 1px solid color-mix(in srgb, var(--tone-accent) 35%, transparent);
    color: var(--tone-accent-glow);
  }

  .home-reflections-empty {
    margin: 0;
    font-size: 0.92rem;
    color: var(--tone-muted);
  }

  .home-reflections.is-mobile {
    margin-top: 1.15rem;
  }

  .home-reflections.is-mobile .home-reflections-grid {
    grid-template-columns: 1fr;
  }

  @media (max-width: 640px) {
    .home-reflections-head {
      padding-right: 0;
    }

    .home-reflections-head::after {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-reflection-card {
      transition: none;
    }

    .home-reflection-card:hover,
    .home-reflection-card:focus-visible {
      transform: none;
    }
  }
</style>
